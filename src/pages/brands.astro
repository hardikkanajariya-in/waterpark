---
import Layout from '../layouts/Layout.astro';
import brands from '../data/brands.json';
import categories from '../data/categories.json';
import config from '../data/config.json';

const seoTitle = `Product Collections & Brands | ${config.brandName}`;
const seoDescription = `Explore our premium aquatic brands including elite competition swimwear, WaveGrip water park tubes, and HydroShield waterproof covers.`;

const getCategoryNames = (slugList: string[]) => {
  return categories
    .filter(c => slugList.includes(c.slug))
    .map(c => c.name);
};
---

<Layout title={seoTitle} description={seoDescription}>
  
  <!-- Page Title and Breadcrumb (Clean & Standard Width) -->
  <div class="mx-auto max-w-7xl px-6 md:px-8 pt-8 pb-4 font-sans bg-white border-b border-light-darker">
    <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2 mb-2">
      <a href="/" class="hover:text-primary">Home</a>
      <span>/</span>
      <span class="text-primary">Brands</span>
    </nav>
    <h1 class="text-2xl font-bold tracking-tight text-dark font-heading">
      Product Collections
    </h1>
  </div>

  <!-- Brands List -->
  <section class="py-12 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {brands.map((brand) => {
          const categoryNames = getCategoryNames(brand.categories);

          return (
            <div class="group bg-white rounded-2xl border border-light-darker p-6 shadow-soft hover:shadow-soft-lg transition-all duration-300 flex flex-col justify-between font-sans">
              <div class="space-y-4">
                <div class="space-y-1">
                  <span class="text-[9px] font-bold text-primary uppercase tracking-wider block">Featured Brand</span>
                  <h2 class="text-lg font-bold text-dark font-heading group-hover:text-primary transition-colors">
                    {brand.name}
                  </h2>
                </div>
                
                <p class="text-xs text-dark-muted leading-relaxed font-medium">
                  {brand.description}
                </p>

                <!-- Categories list -->
                <div class="flex flex-wrap gap-1.5 pt-2">
                  {categoryNames.map(name => (
                    <span class="px-2.5 py-0.5 rounded bg-light border border-light-darker text-[9px] text-dark font-bold">
                      {name}
                    </span>
                  ))}
                </div>
              </div>

              <div class="pt-6 mt-6 border-t border-light-darker/60 flex items-center justify-between">
                <a
                  href={`/products?search=${brand.name.split(' ')[0].toLowerCase()}`}
                  class="inline-flex justify-center rounded-full bg-primary px-5 py-2.5 text-xs font-bold text-white hover:bg-primary-dark transition-all focus:outline-none"
                >
                  Shop Brand
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
