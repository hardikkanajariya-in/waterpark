---
import Layout from '../layouts/Layout.astro';
import brands from '../data/brands.json';
import categories from '../data/categories.json';

const seoTitle = "Represented Brands & Product Collections | Aquadura";
const seoDescription = "Review Aquadura's specialized sub-brands including Aquadura Pro competition gear, WaveGrip commercial inflatables, and HydroShield watertight covers.";

const getCategoryNames = (slugList: string[]) => {
  return categories
    .filter(c => slugList.includes(c.slug))
    .map(c => c.name);
};
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Header -->
  <section class="bg-white py-16 border-b border-light-darker">
    <div class="mx-auto max-w-4xl px-6 md:px-8 space-y-4">
      <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
        <a href="/" class="hover:text-primary font-sans">Home</a>
        <span>/</span>
        <span class="text-primary font-sans">Brands</span>
      </nav>
      <h1 class="text-4xl font-extrabold tracking-tight text-dark font-heading">
        Product Collections
      </h1>
      <p class="text-sm text-dark-muted font-sans max-w-xl leading-relaxed">
        Our products are grouped into three distinct sub-brands, each corresponding to specialized deployment standards and materials.
      </p>
    </div>
  </section>

  <!-- Brands List -->
  <section class="py-20 bg-light">
    <div class="mx-auto max-w-5xl px-6 md:px-8 space-y-12">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {brands.map((brand) => {
          const categoryNames = getCategoryNames(brand.categories);
          return (
            <div class="flex flex-col justify-between p-8 rounded-2xl border border-light-darker bg-white shadow-soft hover:shadow-soft-lg transition-all duration-300">
              <div class="space-y-4">
                <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">{brand.tagline}</span>
                <h2 class="text-xl font-bold text-dark font-heading">{brand.name}</h2>
                <p class="text-xs text-dark-muted leading-relaxed font-sans">{brand.description}</p>
                
                <div class="pt-4 border-t border-light-darker/60 space-y-2">
                  <span class="text-[10px] font-bold text-dark-muted uppercase tracking-wider block">Scope divisions</span>
                  <div class="flex flex-wrap gap-1.5">
                    {categoryNames.map(cat => (
                      <span class="px-2 py-0.5 bg-light border border-light-darker rounded text-[10px] text-dark font-medium font-sans">
                        {cat}
                      </span>
                    ))}
                  </div>
                </div>
              </div>

              <div class="pt-8">
                <a
                  href={`/products?search=${brand.name.split(' ')[0].toLowerCase()}`}
                  class="w-full text-center inline-flex justify-center items-center rounded-full bg-primary px-4 py-2.5 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-colors font-sans"
                >
                  View Collection
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
