---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';

const seoTitle = `Custom Branding & Printing | ${config.brandName}`;
const seoDescription = `Design customized team caps and goggles with custom logos, team colors, and custom packaging. Order directly online.`;
---

<Layout title={seoTitle} description={seoDescription}>

  <!-- Page Title and Breadcrumb (Clean & Standard Width) -->
  <div class="mx-auto max-w-7xl px-6 md:px-8 pt-8 pb-4 font-sans bg-white border-b border-light-darker">
    <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2 mb-2">
      <a href="/" class="hover:text-primary">Home</a>
      <span>/</span>
      <span class="text-primary">Team Branding</span>
    </nav>
    <h1 class="text-2xl font-bold tracking-tight text-dark font-heading">
      Team Personalization Desk
    </h1>
  </div>

  <!-- Interactive Customizer Section -->
  <section class="py-12 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Left Column: Live Canvas Preview -->
        <div class="lg:col-span-6 bg-white border border-light-darker rounded-2xl p-6 shadow-soft flex flex-col items-center justify-center min-h-[460px]">
          <span class="text-[9px] font-bold text-dark-muted uppercase tracking-widest mb-6 font-sans">Live 3D-Style Design Canvas</span>
          
          <!-- Cap SVG wrapper -->
          <div id="custom-cap-canvas" class="relative w-80 h-72 transition-colors duration-300 rounded-full flex items-center justify-center" style="background-color: #0F5FA8;">
            
            <!-- Swim Cap Silhouette SVG -->
            <svg class="absolute inset-0 w-full h-full text-white/5 opacity-20 pointer-events-none" viewBox="0 0 100 100" fill="currentColor">
              <path d="M50 15 C20 15 15 35 15 65 C15 75 25 80 50 80 C75 80 85 75 85 65 C85 35 80 15 50 15 Z" />
            </svg>

            <!-- Dynamic Cap Detail lines -->
            <div class="absolute inset-x-8 bottom-12 h-1 border-t-2 border-dashed border-white/35"></div>

            <!-- Logo Overlay Container -->
            <div class="relative z-10 text-center select-none p-4 max-w-[200px] border-2 border-dashed border-white/20 rounded-xl bg-black/10 backdrop-blur-sm">
              <div id="preview-logo-logo" class="h-10 w-10 mx-auto bg-white/20 rounded-full flex items-center justify-center mb-1 text-white">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              </div>
              <span id="preview-logo-text" class="block text-xs font-black uppercase text-white tracking-widest font-heading leading-tight">
                YOUR SQUAD
              </span>
              <span class="block text-[8px] text-white/60 tracking-wider mt-1 uppercase">Printed Logo Zone</span>
            </div>
          </div>

          <div class="mt-8 text-center text-xs text-dark-muted font-sans font-medium">
            <span>Selected Colorway: </span>
            <strong id="active-color-name" class="text-primary uppercase">Elite Ocean Blue</strong>
          </div>
        </div>

        <!-- Right Column: Control Panel Form -->
        <div class="lg:col-span-6 space-y-6">
          <div class="bg-white border border-light-darker rounded-2xl p-6 shadow-soft space-y-6 font-sans">
            <h2 class="text-sm font-bold text-dark font-heading uppercase tracking-wider border-b border-light-darker pb-3">Personalization Parameters</h2>
            
            <form id="custom-branding-form" class="space-y-5">
              
              <!-- Color picker -->
              <div class="space-y-3">
                <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Cap Base Color</span>
                <div class="flex gap-3">
                  <button type="button" class="color-picker-btn h-8 w-8 rounded-full border-2 border-primary focus:outline-none transition-all" style="background-color: #0F5FA8;" data-color="#0F5FA8" data-color-name="Elite Ocean Blue"></button>
                  <button type="button" class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none transition-all" style="background-color: #1E293B;" data-color="#1E293B" data-color-name="Midnight Charcoal"></button>
                  <button type="button" class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none transition-all" style="background-color: #E11D48;" data-color="#E11D48" data-color-name="Crimson Red"></button>
                  <button type="button" class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none transition-all" style="background-color: #059669;" data-color="#059669" data-color-name="Forest Green"></button>
                  <button type="button" class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none transition-all" style="background-color: #D97706;" data-color="#D97706" data-color-name="Amber Gold"></button>
                </div>
              </div>

              <!-- Text alignment -->
              <div class="space-y-2">
                <label for="branding-text-input" class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Custom Team Text</label>
                <input
                  type="text"
                  id="branding-text-input"
                  maxlength="14"
                  placeholder="YOUR SQUAD"
                  class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:outline-none transition-all font-bold text-dark"
                />
              </div>

              <!-- Symbol Select -->
              <div class="space-y-3">
                <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Center Logo Emblem</span>
                <div class="grid grid-cols-5 gap-2">
                  <button type="button" class="emblem-picker-btn border-2 border-primary rounded-lg p-2.5 text-xs font-bold bg-light focus:outline-none flex items-center justify-center" data-symbol="star" aria-label="Star Emblem">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                  </button>
                  <button type="button" class="emblem-picker-btn border border-light-darker rounded-lg p-2.5 text-xs font-bold hover:bg-light focus:outline-none flex items-center justify-center" data-symbol="bolt" aria-label="Bolt Emblem">
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                  </button>
                  <button type="button" class="emblem-picker-btn border border-light-darker rounded-lg p-2.5 text-xs font-bold hover:bg-light focus:outline-none flex items-center justify-center" data-symbol="anchor" aria-label="Anchor Emblem">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="5" r="3"></circle><line x1="12" y1="22" x2="12" y2="8"></line><path d="M5 12H2a10 10 0 0 0 20 0h-3"></path></svg>
                  </button>
                  <button type="button" class="emblem-picker-btn border border-light-darker rounded-lg p-2.5 text-xs font-bold hover:bg-light focus:outline-none flex items-center justify-center" data-symbol="trophy" aria-label="Trophy Emblem">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"></path><path d="M12 2a7 7 0 0 0-7 7c0 3.18 2.12 5.86 5 6.71V2h2z"></path></svg>
                  </button>
                  <button type="button" class="emblem-picker-btn border border-light-darker rounded-lg p-2.5 text-xs font-bold hover:bg-light focus:outline-none flex items-center justify-center" data-symbol="waves" aria-label="Waves Emblem">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M2 6c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1"></path><path d="M2 12c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1"></path></svg>
                  </button>
                </div>
              </div>

              <!-- Packaging -->
              <div class="space-y-3">
                <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Branded Packaging Option</span>
                <select
                  id="custom-packaging-select"
                  class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs text-dark focus:bg-white focus:outline-none transition-all font-semibold"
                >
                  <option value="standard">Standard Polybag (Included)</option>
                  <option value="premium">Premium Matte Matte Carton (+ ₹25 / item)</option>
                  <option value="eco">Eco-Friendly Recycled Pouch (+ ₹15 / item)</option>
                </select>
              </div>

              <!-- Qty & Pricing -->
              <div class="grid grid-cols-2 gap-4 border-t border-light-darker pt-4">
                <div>
                  <label for="custom-qty" class="block font-bold text-dark mb-1">Quantity</label>
                  <input type="number" id="custom-qty" min="1" value="10" required class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:outline-none font-bold text-dark" />
                </div>
                <div>
                  <span class="block font-bold text-dark-muted mb-1 text-[9px] uppercase">Unit Price</span>
                  <span class="text-sm font-bold text-primary block mt-1.5">₹499.00</span>
                </div>
              </div>

              <!-- Success Message -->
              <div id="branding-success" class="hidden rounded-xl bg-emerald-50 border border-emerald-200 p-4 text-emerald-800 text-xs font-sans">
                Proposal submitted successfully! An art team director will contact you with a digital layout vector mock within 24 hours.
              </div>

              <div class="flex flex-col gap-2 pt-2">
                <button
                  type="submit"
                  class="w-full inline-flex items-center justify-center rounded-xl bg-primary py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all focus:outline-none"
                >
                  Send Design Inquiries
                </button>
                <button
                  type="button"
                  id="add-custom-to-quote-cart-btn"
                  class="w-full inline-flex items-center justify-center rounded-xl border border-light-darker bg-white py-3 text-xs font-bold text-dark hover:bg-light transition-all focus:outline-none"
                >
                  Add Custom Design to Cart
                </button>
              </div>
            </form>
          </div>

        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('custom-cap-canvas');
    const textInput = document.getElementById('branding-text-input') as HTMLInputElement;
    const textPreview = document.getElementById('preview-logo-text');
    const emblemPreview = document.getElementById('preview-logo-logo');
    const colorNameEl = document.getElementById('active-color-name');
    
    // Color Swapper
    document.querySelectorAll('.color-picker-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const color = target.getAttribute('data-color') || '#0F5FA8';
        const colorName = target.getAttribute('data-color-name') || 'Ocean Blue';
        
        if (canvas) {
          canvas.style.backgroundColor = color;
        }

        if (colorNameEl) {
          colorNameEl.textContent = colorName;
        }

        document.querySelectorAll('.color-picker-btn').forEach(b => {
          b.classList.remove('border-primary', 'border-2');
          b.classList.add('border-light-darker', 'border');
        });
        target.classList.remove('border-light-darker', 'border');
        target.classList.add('border-primary', 'border-2');
      });
    });

    // Text Live Sync
    if (textInput && textPreview) {
      textInput.addEventListener('input', () => {
        textPreview.textContent = textInput.value.toUpperCase() || 'YOUR SQUAD';
      });
    }

    // Emblem Picker
    document.querySelectorAll('.emblem-picker-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target.closest('.emblem-picker-btn');
        if (!target) return;
        const symbol = target.getAttribute('data-symbol') || 'star';

        if (emblemPreview) {
          const emblemSVGs = {
            star: '<svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>',
            bolt: '<svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>',
            anchor: '<svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="5" r="3"></circle><line x1="12" y1="22" x2="12" y2="8"></line><path d="M5 12H2a10 10 0 0 0 20 0h-3"></path></svg>',
            trophy: '<svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"></path><path d="M12 2a7 7 0 0 0-7 7c0 3.18 2.12 5.86 5 6.71V2h2z"></path></svg>',
            waves: '<svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M2 6c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1"></path><path d="M2 12c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1c.6.5 1.2 1 2.5 1s1.9-.5 2.5-1c.6-.5 1.2-1 2.5-1s1.9.5 2.5 1"></path></svg>'
          };
          emblemPreview.innerHTML = emblemSVGs[symbol] || emblemSVGs.star;
        }

        document.querySelectorAll('.emblem-picker-btn').forEach(b => {
          b.classList.remove('border-primary', 'border-2');
          b.classList.add('border-light-darker', 'border');
        });
        target.classList.remove('border-light-darker', 'border');
        target.classList.add('border-primary', 'border-2');
      });
    });

    // Form Submit
    const form = document.getElementById('custom-branding-form') as HTMLFormElement;
    const successBanner = document.getElementById('branding-success');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      if (successBanner) {
        successBanner.classList.remove('hidden');
      }
      setTimeout(() => {
        form.reset();
        successBanner?.classList.add('hidden');
      }, 4000);
    });

    // Add Custom Design to Shopping Cart
    const addCartBtn = document.getElementById('add-custom-to-quote-cart-btn');
    addCartBtn?.addEventListener('click', (e) => {
      e.preventDefault();

      const capColor = canvas?.style.backgroundColor || '#0F5FA8';
      const text = textInput?.value.toUpperCase() || 'YOUR SQUAD';
      const qtyInput = document.getElementById('custom-qty') as HTMLInputElement;
      const qty = parseInt(qtyInput?.value) || 10;
      
      const customProjectSlug = `custom-swim-cap-${capColor.replace('#', '')}`;
      const projectName = `Custom Cap (${text} - Color: ${capColor})`;

      if ((window as any).ShoppingCart) {
        (window as any).ShoppingCart.addItem({
          slug: customProjectSlug,
          name: projectName,
          image: '/images/cat_caps.png',
          price: 499.00,
          qty: qty
        });
      }
    });

  });
</script>
