---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';

const seoTitle = `Custom Branding & Printing | ${config.brandName}`;
const seoDescription = `Design custom printed silicone dome swim caps and custom colorway goggles for swim squads, schools, water parks, and brands.`;
---

<Layout title={seoTitle} description={seoDescription}>
  <section class="bg-white py-16 border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="space-y-4">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
          <a href="/" class="hover:text-primary font-sans">Home</a>
          <span>/</span>
          <span class="text-primary font-sans">Custom Branding</span>
        </nav>
        <h1 class="text-4xl font-extrabold tracking-tight text-dark font-heading">
          Institutional Branding Desk
        </h1>
        <p class="text-sm text-dark-muted font-sans mt-2 max-w-2xl leading-relaxed">
          Incorporate team logo prints, pantone color alignments, and bespoke packaging configurations directly on your manufacturing orders.
        </p>
      </div>
    </div>
  </section>

  <!-- Interactive Customizer Section -->
  <section class="py-16 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left 60%: Interactive Preview Canvas -->
        <div class="lg:col-span-7 bg-white rounded-3xl border border-light-darker p-8 space-y-8 shadow-soft">
          <h2 class="text-xs font-black text-dark uppercase tracking-wider font-heading border-b border-light-darker pb-3">
            Digital Branding Customizer
          </h2>
          
          <div class="relative bg-light rounded-2xl p-12 border border-light-darker flex items-center justify-center min-h-[380px] sm:min-h-[440px]">
            <!-- Cap SVG wrapper -->
            <div id="custom-cap-canvas" class="relative w-80 h-72 transition-colors duration-300 rounded-full flex items-center justify-center" style="background-color: #0F5FA8;">
              
              <!-- Swim Cap Silhouette SVG -->
              <svg class="absolute inset-0 w-full h-full text-white/5 opacity-20 pointer-events-none" viewBox="0 0 100 100" fill="currentColor">
                <path d="M50 15 C20 15 15 35 15 65 C15 75 25 80 50 80 C75 80 85 75 85 65 C85 35 80 15 50 15 Z" />
              </svg>

              <!-- Dynamic Cap Detail lines -->
              <div class="absolute inset-x-8 bottom-12 h-1 border-t-2 border-dashed border-white/35"></div>

              <!-- Logo Overlay Container -->
              <div class="relative z-10 text-center select-none p-4 max-w-[200px] border-2 border-dashed border-white/20 rounded-xl bg-black/10 backdrop-blur-sm">
                <div id="preview-logo-logo" class="h-10 w-10 mx-auto bg-white/20 rounded-full flex items-center justify-center mb-1 text-white font-black text-xs">
                  ★
                </div>
                <span id="preview-logo-text" class="block text-xs font-black uppercase text-white tracking-widest font-heading leading-tight">
                  YOUR SQUAD
                </span>
                <span class="block text-[8px] text-white/60 tracking-wider mt-1 uppercase">Printed Logo Zone</span>
              </div>

            </div>

            <!-- Absolute badge -->
            <div class="absolute top-4 right-4 bg-dark text-white text-[9px] font-bold px-3 py-1.5 rounded-full shadow">
              Interactive 3D Dome Cap Mockup
            </div>
          </div>

          <!-- Technical parameters list -->
          <div class="grid grid-cols-2 gap-4 text-xs font-sans text-dark-muted">
            <div class="space-y-1">
              <span class="block font-bold text-dark">Printing Screen Resolution</span>
              <span>High-Definition Multi-Color Silkscreen</span>
            </div>
            <div class="space-y-1">
              <span class="block font-bold text-dark">Ink Integrity</span>
              <span>100% Chlorine & Tear Resistant Polymer Ink</span>
            </div>
            <div class="space-y-1">
              <span class="block font-bold text-dark">Minimum Order (MOQ)</span>
              <span>250 customized units per colorway</span>
            </div>
            <div class="space-y-1">
              <span class="block font-bold text-dark">Colorway Matching</span>
              <span>Pantone Matching System (PMS) Supported</span>
            </div>
          </div>
        </div>

        <!-- Right 50%: Controls & Order Intake -->
        <div class="lg:col-span-5 space-y-8">
          
          <!-- Control Panel -->
          <div class="bg-white rounded-3xl border border-light-darker p-6 sm:p-8 shadow-soft space-y-6">
            <h3 class="text-xs font-black text-dark uppercase tracking-wider font-heading">Configure Style Options</h3>
            
            <!-- Cap Base Color -->
            <div class="space-y-3">
              <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Cap Base Color</span>
              <div class="flex gap-3">
                <button class="color-picker-btn h-8 w-8 rounded-full border-2 border-primary focus:outline-none bg-primary" data-color="#0F5FA8" title="Royal Blue"></button>
                <button class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none bg-dark" data-color="#111827" title="Graphite Slate"></button>
                <button class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none bg-red-600" data-color="#DC2626" title="Crimson Red"></button>
                <button class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none bg-emerald-600" data-color="#059669" title="Team Emerald"></button>
                <button class="color-picker-btn h-8 w-8 rounded-full border border-light-darker focus:outline-none bg-yellow-500" data-color="#EAB308" title="Squad Gold"></button>
              </div>
            </div>

            <!-- Custom Logo / Typography -->
            <div class="space-y-3">
              <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Logo Branding Text</span>
              <input
                type="text"
                id="branding-text-input"
                value="YOUR SQUAD"
                maxlength="16"
                class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs text-dark focus:bg-white focus:border-primary focus:outline-none transition-all font-bold uppercase tracking-wider"
              />
            </div>

            <!-- Symbol Select -->
            <div class="space-y-3">
              <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Center Logo Emblem</span>
              <div class="grid grid-cols-5 gap-2">
                <button class="emblem-picker-btn border-2 border-primary rounded-lg p-2 text-xs font-bold bg-light focus:outline-none" data-symbol="★">★</button>
                <button class="emblem-picker-btn border border-light-darker rounded-lg p-2 text-xs font-bold hover:bg-light focus:outline-none" data-symbol="⚡">⚡</button>
                <button class="emblem-picker-btn border border-light-darker rounded-lg p-2 text-xs font-bold hover:bg-light focus:outline-none" data-symbol="⚓">⚓</button>
                <button class="emblem-picker-btn border border-light-darker rounded-lg p-2 text-xs font-bold hover:bg-light focus:outline-none" data-symbol="🏆">🏆</button>
                <button class="emblem-picker-btn border border-light-darker rounded-lg p-2 text-xs font-bold hover:bg-light focus:outline-none" data-symbol="🏊">🏊</button>
              </div>
            </div>

            <!-- Packaging -->
            <div class="space-y-3">
              <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Branded Packaging Option</span>
              <select
                id="custom-packaging-select"
                class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs text-dark focus:bg-white focus:outline-none transition-all font-semibold"
              >
                <option value="standard">None (Bulk zip-lock polybag)</option>
                <option value="custom-insert">Paper board insert card with company logo</option>
                <option value="custom-box">Recycled cardboard retail boxes (+ MOQ setup)</option>
              </select>
            </div>

          </div>

          <!-- Add Project to Quote -->
          <div class="bg-white rounded-3xl border border-light-darker p-6 sm:p-8 shadow-soft space-y-6">
            <h3 class="text-xs font-black text-dark uppercase tracking-wider font-heading">Submit Branding Proposal</h3>
            
            <form id="custom-branding-form" class="space-y-4">
              <div class="grid grid-cols-2 gap-4 font-sans text-xs">
                <div>
                  <label for="custom-name" class="block font-bold text-dark mb-1">Your Name *</label>
                  <input type="text" id="custom-name" required placeholder="John Doe" class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:outline-none" />
                </div>
                <div>
                  <label for="custom-org" class="block font-bold text-dark mb-1">Company / Team Name *</label>
                  <input type="text" id="custom-org" required placeholder="Water Academy Ltd" class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:outline-none" />
                </div>
              </div>
              
              <div class="grid grid-cols-2 gap-4 font-sans text-xs">
                <div>
                  <label for="custom-email" class="block font-bold text-dark mb-1">Corporate Email *</label>
                  <input type="email" id="custom-email" required placeholder="procurement@company.com" class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:outline-none" />
                </div>
                <div>
                  <label for="custom-qty" class="block font-bold text-dark mb-1">Required Volume (Min 250) *</label>
                  <input type="number" id="custom-qty" min="250" value="250" required class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:outline-none font-bold text-dark" />
                </div>
              </div>

              <!-- Success Message -->
              <div id="branding-success" class="hidden rounded-xl bg-emerald-50 border border-emerald-200 p-4 text-emerald-800 text-xs font-sans">
                Proposal submitted successfully! An art team director will contact you with a digital layout vector mock within 24 hours.
              </div>

              <div class="flex flex-col gap-2 pt-2">
                <button
                  type="submit"
                  class="w-full inline-flex items-center justify-center rounded-xl bg-primary py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all"
                >
                  Send Design Inquiries
                </button>
                <button
                  type="button"
                  id="add-custom-to-quote-cart-btn"
                  class="w-full inline-flex items-center justify-center rounded-xl border border-light-darker bg-white py-3 text-xs font-bold text-dark hover:bg-light transition-all"
                >
                  Add Design to Quote Sheet
                </button>
              </div>
            </form>
          </div>

        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('custom-cap-canvas');
    const textInput = document.getElementById('branding-text-input') as HTMLInputElement;
    const textPreview = document.getElementById('preview-logo-text');
    const emblemPreview = document.getElementById('preview-logo-logo');
    
    // Color Swapper
    document.querySelectorAll('.color-picker-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const color = target.getAttribute('data-color') || '#0F5FA8';
        
        // Update Canvas background color
        if (canvas) {
          canvas.style.backgroundColor = color;
        }

        // Highlight selected picker
        document.querySelectorAll('.color-picker-btn').forEach(b => {
          b.classList.remove('border-primary');
          b.classList.add('border-light-darker');
        });
        target.classList.remove('border-light-darker');
        target.classList.add('border-primary');
      });
    });

    // Text Live Sync
    if (textInput && textPreview) {
      textInput.addEventListener('input', () => {
        textPreview.textContent = textInput.value.toUpperCase() || 'YOUR SQUAD';
      });
    }

    // Emblem Picker
    document.querySelectorAll('.emblem-picker-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const symbol = target.getAttribute('data-symbol') || '★';

        if (emblemPreview) {
          emblemPreview.textContent = symbol;
        }

        // Highlight picker
        document.querySelectorAll('.emblem-picker-btn').forEach(b => {
          b.classList.remove('border-primary');
          b.classList.add('border-light-darker');
        });
        target.classList.remove('border-light-darker');
        target.classList.add('border-primary');
      });
    });

    // Form Submit
    const form = document.getElementById('custom-branding-form') as HTMLFormElement;
    const successBanner = document.getElementById('branding-success');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      if (successBanner) {
        successBanner.classList.remove('hidden');
      }
      setTimeout(() => {
        form.reset();
        successBanner?.classList.add('hidden');
      }, 4000);
    });

    // Add Custom Design to Quote Cart
    const addCartBtn = document.getElementById('add-custom-to-quote-cart-btn');
    addCartBtn?.addEventListener('click', (e) => {
      e.preventDefault();

      const capColor = canvas?.style.backgroundColor || '#0F5FA8';
      const text = textInput?.value.toUpperCase() || 'YOUR SQUAD';
      const emblem = emblemPreview?.textContent || '★';
      const qtyInput = document.getElementById('custom-qty') as HTMLInputElement;
      const qty = parseInt(qtyInput?.value) || 250;
      const pkgSelect = document.getElementById('custom-packaging-select') as HTMLSelectElement;
      const packaging = pkgSelect ? pkgSelect.value : 'standard';

      const customProjectSlug = `custom-swim-cap-${capColor.replace('#', '')}`;
      const projectName = `Custom Cap (${text} - Color: ${capColor})`;

      if ((window as any).QuoteCart) {
        (window as any).QuoteCart.addItem({
          slug: customProjectSlug,
          name: projectName,
          image: '/images/cat_caps.png', // Fallback to category cap photo
          moq: '250 units',
          numericMoq: 250,
          qty: qty,
          printing: true,
          packaging: packaging
        });
      }
    });

  });
</script>
