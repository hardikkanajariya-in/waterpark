---
import Layout from '../../layouts/Layout.astro';
import products from '../../data/products.json';
import categories from '../../data/categories.json';
import config from '../../data/config.json';

const seoTitle = `Product Catalogue & Specifications | ${config.brandName}`;
const seoDescription = `Browse through our premium B2C swimming goggles, caps, tubes, and aquatic accessories. Find specs and shop online.`;

const getCategoryName = (catSlug: string) => {
  return categories.find(c => c.slug === catSlug)?.name || "Aquatic Equipment";
};
---

<Layout title={seoTitle} description={seoDescription}>
  
  <!-- Page Header -->
  <section class="bg-white py-12 border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="space-y-3">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
          <a href="/" class="hover:text-primary font-sans">Home</a>
          <span>/</span>
          <span class="text-primary font-sans">Shop All</span>
        </nav>
        <h1 class="text-3xl font-bold tracking-tight text-dark font-heading">
          Product Catalogue
        </h1>
        <p class="text-xs sm:text-sm text-dark-muted font-sans mt-2 max-w-xl leading-relaxed font-medium">
          Filter and browse our premium retail swimming gear. Review features, specifications, and add items directly to your shopping cart.
        </p>
      </div>
    </div>
  </section>

  <!-- Catalogue Section -->
  <section class="py-10 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 lg:flex lg:gap-8">
      
      <!-- Sticky Sidebar Filters -->
      <aside class="w-full lg:w-72 shrink-0 mb-8 lg:mb-0">
        <div class="sticky top-28 bg-white border border-light-darker rounded-2xl p-5 shadow-soft space-y-6 font-sans">
          
          <!-- Search input -->
          <div class="space-y-2">
            <label for="catalog-search" class="block text-[9px] font-bold text-dark-muted uppercase tracking-wider">Search Catalogue</label>
            <div class="relative">
              <input
                type="text"
                id="catalog-search"
                placeholder="Search name or features..."
                class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs text-dark placeholder:text-dark-muted/50 focus:bg-white focus:border-primary focus:outline-none transition-all font-medium"
              />
              <svg class="absolute right-3 top-2.5 h-3.5 w-3.5 text-dark-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          </div>

          <!-- Sorting -->
          <div class="space-y-2">
            <label for="catalog-sort" class="block text-[9px] font-bold text-dark-muted uppercase tracking-wider">Sort Products</label>
            <select
              id="catalog-sort"
              class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs text-dark focus:bg-white focus:border-primary focus:outline-none transition-all font-medium"
            >
              <option value="default">Default Order</option>
              <option value="name-asc">Product Name (A-Z)</option>
              <option value="name-desc">Product Name (Z-A)</option>
              <option value="price-asc">Price (Low to High)</option>
              <option value="price-desc">Price (High to Low)</option>
            </select>
          </div>

          <!-- Category filter buttons -->
          <div class="space-y-2.5">
            <span class="block text-[9px] font-bold text-dark-muted uppercase tracking-wider border-b border-light-darker pb-2">Filter by Category</span>
            <nav class="flex flex-wrap gap-1.5 lg:flex-col lg:gap-1 text-xs">
              <button
                data-filter="all"
                class="cat-filter-btn text-left w-full rounded-lg px-3 py-1.5 font-semibold bg-primary text-white transition-all"
              >
                All Categories ({products.length})
              </button>
              
              {categories.map((cat) => {
                const count = products.filter(p => p.category === cat.slug).length;
                return (
                  <button
                    data-filter={cat.slug}
                    class="cat-filter-btn text-left w-full rounded-lg px-3 py-1.5 font-semibold text-dark-muted hover:bg-light hover:text-primary transition-all"
                  >
                    {cat.name} ({count})
                  </button>
                );
              })}
            </nav>
          </div>

          <!-- Specifications quick filters -->
          <div class="space-y-2.5 pt-2 border-t border-light-darker">
            <span class="block text-[9px] font-bold text-dark-muted uppercase tracking-wider">Product Features</span>
            <div class="space-y-2 text-xs text-dark font-medium">
              <label class="flex items-center gap-2 cursor-pointer select-none">
                <input type="checkbox" id="filter-antifog" class="spec-filter-checkbox rounded border-light-darker text-primary focus:ring-primary h-4 w-4" />
                Anti-Fog Lenses
              </label>
              <label class="flex items-center gap-2 cursor-pointer select-none">
                <input type="checkbox" id="filter-uv" class="spec-filter-checkbox rounded border-light-darker text-primary focus:ring-primary h-4 w-4" />
                UV Protection
              </label>
              <label class="flex items-center gap-2 cursor-pointer select-none">
                <input type="checkbox" id="filter-heavyduty" class="spec-filter-checkbox rounded border-light-darker text-primary focus:ring-primary h-4 w-4" />
                Heavy-Duty / Commercial
              </label>
              <label class="flex items-center gap-2 cursor-pointer select-none">
                <input type="checkbox" id="filter-kids" class="spec-filter-checkbox rounded border-light-darker text-primary focus:ring-primary h-4 w-4" />
                Junior / Kids Fit
              </label>
            </div>
          </div>

        </div>
      </aside>

      <!-- Catalogue Listings -->
      <div class="flex-grow space-y-5">
        
        <!-- Category description banner -->
        <div id="category-description-banner" class="bg-white border border-light-darker rounded-2xl p-5 shadow-soft hidden">
          <h2 id="category-banner-title" class="text-lg font-bold text-dark font-heading"></h2>
          <p id="category-banner-desc" class="text-xs text-dark-muted mt-1 leading-relaxed font-sans font-medium"></p>
        </div>

        <!-- Products List -->
        <div id="products-catalog-list" class="space-y-5 animate-fade-in">
          {products.map((product) => {
            const hasAntiFog = product.description.toLowerCase().includes("anti-fog") || product.features.some(f => f.toLowerCase().includes("anti-fog"));
            const hasUV = product.description.toLowerCase().includes("uv") || product.features.some(f => f.toLowerCase().includes("uv"));
            const isHeavyDuty = product.description.toLowerCase().includes("heavy-duty") || product.description.toLowerCase().includes("commercial") || product.description.toLowerCase().includes("reinforced") || product.category.includes("tube");
            const isKids = product.description.toLowerCase().includes("kids") || product.description.toLowerCase().includes("junior") || product.slug.includes("junior") || product.slug.includes("kid");

            return (
              <div
                data-prod-category={product.category}
                data-prod-name={product.name}
                data-prod-price={product.price}
                data-prod-antifog={hasAntiFog ? "true" : "false"}
                data-prod-uv={hasUV ? "true" : "false"}
                data-prod-heavyduty={isHeavyDuty ? "true" : "false"}
                data-prod-kids={isKids ? "true" : "false"}
                class="product-row bg-white border border-light-darker rounded-2xl p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300 grid grid-cols-1 md:grid-cols-12 gap-5 items-center"
              >
                <!-- Photo -->
                <div class="md:col-span-3">
                  <div class="overflow-hidden rounded-xl bg-light border border-light-darker aspect-[4/3] w-full relative">
                    <img
                      src={product.image}
                      alt={product.name}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                </div>

                <!-- Product Content -->
                <div class="md:col-span-6 space-y-2.5 font-sans">
                  <div class="flex items-center gap-2">
                    <span class="text-[9px] font-bold text-primary uppercase bg-primary-light px-2 py-0.5 rounded">
                      {getCategoryName(product.category)}
                    </span>
                    <span class="text-[9px] font-medium text-dark-muted uppercase">
                      SKU: AQ-{product.slug.slice(0,6).toUpperCase()}
                    </span>
                  </div>
                  <h3 class="text-base font-bold text-dark font-heading leading-snug">
                    {product.name}
                  </h3>
                  <p class="text-xs text-dark-muted leading-relaxed line-clamp-2">
                    {product.description}
                  </p>
                  <!-- Specs previews -->
                  <div class="flex flex-wrap gap-x-4 gap-y-1 pt-1 text-[10px] text-dark-muted font-medium">
                    {Object.entries(product.specifications).slice(0, 2).map(([k, v]) => (
                      <span class="flex items-center">
                        <strong class="text-dark mr-1">{k}:</strong> {v}
                      </span>
                    ))}
                  </div>
                </div>

                <!-- Price & Cart Actions -->
                <div class="md:col-span-3 border-t md:border-t-0 md:border-l border-light-darker pt-4 md:pt-0 md:pl-5 flex flex-col justify-center space-y-3.5 h-full">
                  <div>
                    <span class="block text-[8px] font-bold text-dark-muted uppercase tracking-wider">Retail Price</span>
                    <span class="text-sm font-bold text-primary">₹{product.price.toFixed(2)}</span>
                  </div>
                  <div class="flex flex-col gap-2">
                    <button
                      type="button"
                      class="quick-view-btn w-full inline-flex items-center justify-center rounded-lg bg-light border border-light-darker px-4 py-2 text-xs font-bold text-dark hover:bg-white hover:border-slate-300 transition-all focus:outline-none"
                      data-product-slug={product.slug}
                    >
                      Quick View
                    </button>
                    <button
                      type="button"
                      data-add-to-cart
                      data-slug={product.slug}
                      data-name={product.name}
                      data-image={product.image}
                      data-price={product.price.toString()}
                      class="w-full inline-flex items-center justify-center rounded-lg bg-primary px-4 py-2 text-xs font-bold text-white hover:bg-primary-dark transition-all focus:outline-none"
                    >
                      Add to Cart
                    </button>
                  </div>
                </div>

              </div>
            );
          })}
        </div>

        <!-- No Products Found Message -->
        <div id="no-products-message" class="hidden text-center py-16 bg-white border border-light-darker rounded-2xl p-8 shadow-soft font-sans">
          <svg class="mx-auto h-10 w-10 text-dark-muted/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <h3 class="mt-4 text-sm font-bold text-dark font-heading">No Products Found</h3>
          <p class="mt-1 text-xs text-dark-muted font-medium">Try refining your search keyword or reset category filters.</p>
        </div>

      </div>

    </div>
  </section>

  <!-- QUICK VIEW MODAL OVERLAY -->
  <div id="quick-view-modal-backdrop" class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-[10000] hidden opacity-0 transition-opacity duration-300"></div>
  
  <div id="quick-view-modal" class="fixed inset-6 sm:inset-auto sm:top-1/2 sm:left-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 sm:w-[620px] sm:h-auto bg-white border border-light-darker rounded-2xl shadow-2xl z-[10001] p-6 flex flex-col font-sans hidden opacity-0 transform scale-95 transition-all duration-300">
    <button id="close-quick-view-btn" class="absolute top-4 right-4 text-dark-muted hover:text-dark p-1 rounded-full hover:bg-light transition-all focus:outline-none">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-start overflow-y-auto max-h-[70vh] sm:max-h-none pr-1">
      <!-- Left: Image -->
      <div class="space-y-3">
        <div class="overflow-hidden rounded-xl border border-light-darker aspect-[4/3] bg-light">
          <img id="qv-image" src="" alt="" class="h-full w-full object-cover" />
        </div>
        <div>
          <span class="block text-[8px] font-bold text-dark-muted uppercase tracking-wider">Unit Price</span>
          <span id="qv-price-badge" class="inline-block text-sm font-bold text-primary mt-0.5"></span>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="space-y-3.5">
        <div class="space-y-1">
          <span id="qv-category" class="text-[9px] font-bold text-primary uppercase tracking-widest block font-sans"></span>
          <h3 id="qv-name" class="text-base font-bold text-dark font-heading leading-snug"></h3>
        </div>

        <p id="qv-description" class="text-xs text-dark-muted leading-relaxed font-sans font-medium"></p>

        <!-- Technical specs -->
        <div class="space-y-1.5 border-t border-light-darker pt-3">
          <h4 class="text-[9px] font-bold text-dark-muted uppercase tracking-wider">Specifications</h4>
          <div id="qv-specs" class="space-y-1 text-[11px] text-dark-muted font-sans font-medium"></div>
        </div>

        <!-- Add to Cart in modal -->
        <div class="border-t border-light-darker pt-3 flex items-end gap-3">
          <div class="flex flex-col gap-1 text-[9px]">
            <label class="font-bold uppercase tracking-wider text-dark-muted">Quantity</label>
            <input
              type="number"
              id="qv-qty-input"
              min="1"
              value="1"
              class="w-14 rounded-lg border border-light-darker bg-light px-2 py-1.5 font-bold text-dark text-xs focus:bg-white focus:outline-none"
            />
          </div>
          <button
            type="button"
            id="qv-add-cart-btn"
            class="flex-grow inline-flex items-center justify-center rounded-lg bg-primary py-2.5 text-xs font-bold text-white shadow hover:bg-primary-dark transition-all focus:outline-none font-sans"
          >
            Add to Cart
          </button>
        </div>
      </div>
    </div>
  </div>

</Layout>

<script define:vars={{ categories, products }}>
  document.addEventListener('DOMContentLoaded', () => {
    
    // DOM Elements
    const searchInput = document.getElementById('catalog-search');
    const sortSelect = document.getElementById('catalog-sort');
    const filterButtons = document.querySelectorAll('.cat-filter-btn');
    const specCheckboxes = document.querySelectorAll('.spec-filter-checkbox');
    const productRows = document.querySelectorAll('.product-row');
    const noProductsMsg = document.getElementById('no-products-message');
    const categoryBanner = document.getElementById('category-description-banner');
    const bannerTitle = document.getElementById('category-banner-title');
    const bannerDesc = document.getElementById('category-banner-desc');
    const catalogList = document.getElementById('products-catalog-list');

    let currentFilter = 'all';
    let searchQuery = '';
    let currentSort = 'default';
    
    let filterAntiFog = false;
    let filterUV = false;
    let filterHeavyDuty = false;
    let filterKids = false;

    // Apply URL search parameters if any
    const urlParams = new URLSearchParams(window.location.search);
    const urlCategory = urlParams.get('category');
    const urlSearch = urlParams.get('search');

    if (urlCategory) {
      currentFilter = urlCategory;
      filterButtons.forEach(btn => {
        const filterVal = btn.getAttribute('data-filter');
        btn.classList.remove('bg-primary', 'text-white', 'text-dark-muted');
        if (filterVal === currentFilter) {
          btn.classList.add('bg-primary', 'text-white');
        } else {
          btn.classList.add('text-dark-muted');
        }
      });
    }

    if (urlSearch) {
      searchQuery = urlSearch.toLowerCase();
      if (searchInput) {
        searchInput.value = urlSearch;
      }
    }

    // Refresh Category Banner Description
    const updateCategoryBanner = () => {
      if (currentFilter === 'all') {
        categoryBanner?.classList.add('hidden');
        return;
      }
      
      const cat = categories.find(c => c.slug === currentFilter);
      if (cat && bannerTitle && bannerDesc && categoryBanner) {
        bannerTitle.textContent = cat.name;
        bannerDesc.textContent = cat.description;
        categoryBanner.classList.remove('hidden');
      } else {
        categoryBanner?.classList.add('hidden');
      }
    };

    // Master Catalog Render Function
    const updateCatalogue = () => {
      let matchCount = 0;
      const visibleProducts = [];

      productRows.forEach((row) => {
        const category = row.getAttribute('data-prod-category');
        const name = row.getAttribute('data-prod-name')?.toLowerCase() || '';
        
        const hasAntiFog = row.getAttribute('data-prod-antifog') === 'true';
        const hasUV = row.getAttribute('data-prod-uv') === 'true';
        const isHeavyDuty = row.getAttribute('data-prod-heavyduty') === 'true';
        const isKids = row.getAttribute('data-prod-kids') === 'true';

        const matchesCategory = currentFilter === 'all' || category === currentFilter;
        const matchesSearch = name.includes(searchQuery);

        const matchesAntiFog = !filterAntiFog || hasAntiFog;
        const matchesUV = !filterUV || hasUV;
        const matchesHeavyDuty = !filterHeavyDuty || isHeavyDuty;
        const matchesKids = !filterKids || isKids;

        if (matchesCategory && matchesSearch && matchesAntiFog && matchesUV && matchesHeavyDuty && matchesKids) {
          row.style.display = 'grid';
          visibleProducts.push(row);
          matchCount++;
        } else {
          row.style.display = 'none';
        }
      });

      updateCategoryBanner();

      if (matchCount === 0) {
        noProductsMsg?.classList.remove('hidden');
      } else {
        noProductsMsg?.classList.add('hidden');
      }

      // Apply sorting on visible nodes
      if (currentSort !== 'default') {
        const sorted = [...visibleProducts].sort((a, b) => {
          const priceA = parseFloat(a.getAttribute('data-prod-price') || '0');
          const priceB = parseFloat(b.getAttribute('data-prod-price') || '0');

          if (currentSort === 'name-asc') {
            return (a.getAttribute('data-prod-name') || '').localeCompare(b.getAttribute('data-prod-name') || '');
          } else if (currentSort === 'name-desc') {
            return (b.getAttribute('data-prod-name') || '').localeCompare(a.getAttribute('data-prod-name') || '');
          } else if (currentSort === 'price-asc') {
            return priceA - priceB;
          } else if (currentSort === 'price-desc') {
            return priceB - priceA;
          }
          return 0;
        });

        sorted.forEach(node => catalogList?.appendChild(node));
      }
    };

    // Category Button clicks
    filterButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        currentFilter = btn.getAttribute('data-filter') || 'all';

        filterButtons.forEach(b => {
          b.classList.remove('bg-primary', 'text-white');
          b.classList.add('text-dark-muted');
        });
        btn.classList.remove('text-dark-muted');
        btn.classList.add('bg-primary', 'text-white');

        updateCatalogue();
      });
    });

    searchInput?.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
      updateCatalogue();
    });

    sortSelect?.addEventListener('change', (e) => {
      currentSort = (e.target as HTMLSelectElement).value;
      updateCatalogue();
    });

    document.getElementById('filter-antifog')?.addEventListener('change', (e) => {
      filterAntiFog = (e.target as HTMLInputElement).checked;
      updateCatalogue();
    });
    document.getElementById('filter-uv')?.addEventListener('change', (e) => {
      filterUV = (e.target as HTMLInputElement).checked;
      updateCatalogue();
    });
    document.getElementById('filter-heavyduty')?.addEventListener('change', (e) => {
      filterHeavyDuty = (e.target as HTMLInputElement).checked;
      updateCatalogue();
    });
    document.getElementById('filter-kids')?.addEventListener('change', (e) => {
      filterKids = (e.target as HTMLInputElement).checked;
      updateCatalogue();
    });

    updateCatalogue();


    // ----------------------------------------------------
    // QUICK VIEW MODAL CODE
    // ----------------------------------------------------
    const qvModal = document.getElementById('quick-view-modal');
    const qvBackdrop = document.getElementById('quick-view-modal-backdrop');
    const qvCloseBtn = document.getElementById('close-quick-view-btn');
    
    const qvImage = document.getElementById('qv-image') as HTMLImageElement;
    const qvName = document.getElementById('qv-name');
    const qvCategory = document.getElementById('qv-category');
    const qvDescription = document.getElementById('qv-description');
    const qvPriceBadge = document.getElementById('qv-price-badge');
    const qvSpecsContainer = document.getElementById('qv-specs');
    const qvQtyInput = document.getElementById('qv-qty-input') as HTMLInputElement;
    const qvAddBtn = document.getElementById('qv-add-cart-btn');

    let activeQvProduct = null;

    const openQuickView = (product) => {
      activeQvProduct = product;
      
      if (qvImage) qvImage.src = product.image;
      if (qvName) qvName.textContent = product.name;
      
      const cat = categories.find(c => c.slug === product.category);
      if (qvCategory) qvCategory.textContent = cat ? cat.name : "Aquatic Gear";
      if (qvDescription) qvDescription.textContent = product.description;
      if (qvPriceBadge) qvPriceBadge.textContent = `₹${product.price.toFixed(2)}`;
      
      if (qvQtyInput) {
        qvQtyInput.value = '1';
      }

      if (qvSpecsContainer) {
        qvSpecsContainer.innerHTML = Object.entries(product.specifications).map(([k, v]) => `
          <div class="flex justify-between py-1 border-b border-light-darker">
            <span class="font-bold text-dark-muted">${k}</span>
            <span class="text-dark font-semibold">${v}</span>
          </div>
        `).join('');
      }

      qvModal?.classList.remove('hidden');
      qvBackdrop?.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
      
      setTimeout(() => {
        qvModal?.classList.remove('opacity-0', 'scale-95');
        qvBackdrop?.classList.remove('opacity-0');
      }, 50);
    };

    const closeQuickView = () => {
      qvModal?.classList.add('opacity-0', 'scale-95');
      qvBackdrop?.classList.add('opacity-0');
      document.body.classList.remove('overflow-hidden');
      
      setTimeout(() => {
        qvModal?.classList.add('hidden');
        qvBackdrop?.classList.add('hidden');
        activeQvProduct = null;
      }, 300);
    };

    document.querySelectorAll('.quick-view-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const slug = btn.getAttribute('data-product-slug');
        const product = products.find(p => p.slug === slug);
        if (product) {
          openQuickView(product);
        }
      });
    });

    qvCloseBtn?.addEventListener('click', closeQuickView);
    qvBackdrop?.addEventListener('click', closeQuickView);

    qvAddBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      if (!activeQvProduct) return;

      const qty = parseInt(qvQtyInput.value) || 1;

      if ((window as any).ShoppingCart) {
        (window as any).ShoppingCart.addItem({
          slug: activeQvProduct.slug,
          name: activeQvProduct.name,
          image: activeQvProduct.image,
          price: activeQvProduct.price,
          qty: qty
        });
      }

      closeQuickView();
    });

  });
</script>
