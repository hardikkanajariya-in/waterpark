---
import Layout from '../../layouts/Layout.astro';
import products from '../../data/products.json';
import categories from '../../data/categories.json';

const seoTitle = "Product Catalogue & Specifications | Aquadura";
const seoDescription = "Review Aquadura's wholesale catalog of swimming goggles, caps, waterproof cases, pool ladders, and slide tubes. Filter by category, view detailed specs, and request bulk quotes.";

const getCategoryName = (catSlug: string) => {
  return categories.find(c => c.slug === catSlug)?.name || "Aquatic Equipment";
};
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Page Header -->
  <section class="bg-white py-16 border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="space-y-4">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
          <a href="/" class="hover:text-primary font-sans">Home</a>
          <span>/</span>
          <span class="text-primary font-sans">Products</span>
        </nav>
        <h1 class="text-4xl font-extrabold tracking-tight text-dark font-heading">
          Product Catalogue
        </h1>
        <p class="text-sm text-dark-muted font-sans mt-2 max-w-xl leading-relaxed">
          Filter and sort our wholesale catalog of certified commercial aquatic products. View exact dimensions, minimum order quantities (MOQ), and request direct B2B quote sheets.
        </p>
      </div>
    </div>
  </section>

  <!-- Catalogue Section -->
  <section class="py-12 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 lg:flex lg:gap-12">
      
      <!-- Sticky Sidebar Filters -->
      <aside class="w-full lg:w-72 shrink-0 mb-10 lg:mb-0">
        <div class="sticky top-28 bg-white border border-light-darker rounded-2xl p-6 shadow-soft space-y-8 font-sans">
          
          <!-- Search input -->
          <div class="space-y-2">
            <label for="catalog-search" class="block text-[10px] font-bold text-dark uppercase tracking-wider">Search Catalogue</label>
            <div class="relative">
              <input
                type="text"
                id="catalog-search"
                placeholder="Search name, features..."
                class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs text-dark placeholder:text-dark-muted/50 focus:bg-white focus:border-primary focus:outline-none transition-all"
              />
              <svg class="absolute right-3 top-2.5 h-3.5 w-3.5 text-dark-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          </div>

          <!-- Sorting -->
          <div class="space-y-2">
            <label for="catalog-sort" class="block text-[10px] font-bold text-dark uppercase tracking-wider">Sort Products</label>
            <select
              id="catalog-sort"
              class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs text-dark focus:bg-white focus:border-primary focus:outline-none transition-all"
            >
              <option value="default">Default Catalogue Order</option>
              <option value="name-asc">Product Name (A-Z)</option>
              <option value="name-desc">Product Name (Z-A)</option>
              <option value="moq-asc">MOQ (Low to High)</option>
            </select>
          </div>

          <!-- Category filter buttons -->
          <div class="space-y-3">
            <span class="block text-[10px] font-bold text-dark uppercase tracking-wider border-b border-light-darker pb-2">Filter by Category</span>
            <nav class="flex flex-wrap gap-2 lg:flex-col lg:gap-1 text-xs">
              <button
                data-filter="all"
                class="cat-filter-btn text-left w-full rounded-lg px-3 py-2 font-semibold bg-primary text-white transition-all"
              >
                All Categories ({products.length})
              </button>
              
              {categories.map((cat) => {
                const count = products.filter(p => p.category === cat.slug).length;
                return (
                  <button
                    data-filter={cat.slug}
                    class="cat-filter-btn text-left w-full rounded-lg px-3 py-2 font-semibold text-dark-muted hover:bg-light hover:text-primary transition-all"
                  >
                    {cat.name} ({count})
                  </button>
                );
              })}
            </nav>
          </div>

        </div>
      </aside>

      <!-- Catalogue Listings -->
      <div class="flex-grow space-y-6">
        
        <!-- Category description banner (updated dynamically via JS) -->
        <div id="category-description-banner" class="bg-white border border-light-darker rounded-2xl p-6 shadow-soft hidden">
          <h2 id="category-banner-title" class="text-xl font-bold text-dark font-heading"></h2>
          <p id="category-banner-desc" class="text-xs text-dark-muted mt-2 leading-relaxed font-sans"></p>
        </div>

        <!-- Products List (Editorial rows, not generic retail boxes) -->
        <div id="products-catalog-list" class="space-y-6">
          {products.map((product) => {
            // Helper to get raw numeric MOQ for sorting
            const numericMOQ = parseInt(product.moq.replace(/[^0-9]/g, '')) || 0;
            return (
              <div
                data-prod-category={product.category}
                data-prod-name={product.name}
                data-prod-moq={numericMOQ}
                class="product-row bg-white border border-light-darker rounded-2xl p-6 shadow-soft hover:shadow-soft-lg transition-all duration-300 grid grid-cols-1 md:grid-cols-12 gap-6 items-center"
              >
                <!-- Photo Container -->
                <div class="md:col-span-3">
                  <div class="overflow-hidden rounded-xl bg-light border border-light-darker aspect-[4/3] w-full">
                    <img
                      src={product.image}
                      alt={product.name}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                </div>

                <!-- Product Content -->
                <div class="md:col-span-6 space-y-3 font-sans">
                  <div class="flex items-center gap-2">
                    <span class="text-[9px] font-bold text-primary uppercase bg-primary-light px-2 py-0.5 rounded">
                      {getCategoryName(product.category)}
                    </span>
                    <span class="text-[9px] font-medium text-dark-muted uppercase">
                      SKU: AQ-{product.slug.slice(0,6).toUpperCase()}
                    </span>
                  </div>
                  <h3 class="text-lg font-bold text-dark font-heading">
                    {product.name}
                  </h3>
                  <p class="text-xs text-dark-muted leading-relaxed line-clamp-2">
                    {product.description}
                  </p>
                  <!-- Technical specifications previews -->
                  <div class="flex flex-wrap gap-x-4 gap-y-1 pt-1.5 text-[10px] text-dark-muted">
                    {Object.entries(product.specifications).slice(0, 2).map(([k, v]) => (
                      <span class="flex items-center">
                        <strong class="text-dark mr-1">{k}:</strong> {v}
                      </span>
                    ))}
                  </div>
                </div>

                <!-- B2B Actions -->
                <div class="md:col-span-3 border-t md:border-t-0 md:border-l border-light-darker pt-4 md:pt-0 md:pl-6 flex flex-col justify-center h-full space-y-4">
                  <div>
                    <span class="block text-[9px] font-bold text-dark-muted uppercase tracking-wider font-sans">Minimum Order</span>
                    <span class="text-xs font-extrabold text-dark font-sans">{product.moq}</span>
                  </div>
                  <div class="flex flex-col gap-2">
                    <a
                      href={`/products/${product.slug}`}
                      class="w-full inline-flex items-center justify-center rounded-full bg-primary px-4 py-2.5 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all duration-150"
                    >
                      Specifications & Quote
                    </a>
                    <a
                      href={`https://wa.me/18005550199?text=Hi, I am interested in procuring the ${product.name}. Please share a bulk quotation.`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-full inline-flex items-center justify-center rounded-full border border-emerald-200 bg-emerald-50 px-4 py-2.5 text-xs font-bold text-emerald-800 hover:bg-emerald-100 transition-all duration-150"
                    >
                      WhatsApp inquiry
                    </a>
                  </div>
                </div>

              </div>
            );
          })}
        </div>

        <!-- No Products Found Message -->
        <div id="no-products-message" class="hidden text-center py-16 bg-white border border-light-darker rounded-2xl p-8 shadow-soft font-sans">
          <svg class="mx-auto h-10 w-10 text-dark-muted/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <h3 class="mt-4 text-sm font-bold text-dark font-heading">No Products Found</h3>
          <p class="mt-1 text-xs text-dark-muted">Try refining your search keyword or reset category filters.</p>
        </div>

      </div>

    </div>
  </section>
</Layout>

<script define:vars={{ categories }}>
  // Dynamic Client-side Catalog Filtering & Sorting
  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.cat-filter-btn');
    const productRows = document.querySelectorAll('.product-row');
    const searchInput = document.getElementById('catalog-search');
    const sortSelect = document.getElementById('catalog-sort');
    const noProductsMsg = document.getElementById('no-products-message');
    const catalogGrid = document.getElementById('products-catalog-list');
    
    // Category Banner Elements
    const banner = document.getElementById('category-description-banner');
    const bannerTitle = document.getElementById('category-banner-title');
    const bannerDesc = document.getElementById('category-banner-desc');

    let currentFilter = 'all';
    let searchQuery = '';
    let currentSort = 'default';

    // Function to apply filters, search, and sorting
    const updateCatalogue = () => {
      let matchCount = 0;
      const visibleProducts = [];

      productRows.forEach((row) => {
        const prodRow = row;
        const category = prodRow.getAttribute('data-prod-category');
        const name = prodRow.getAttribute('data-prod-name')?.toLowerCase() || '';

        const matchesCategory = currentFilter === 'all' || category === currentFilter;
        const matchesSearch = name.includes(searchQuery);

        if (matchesCategory && matchesSearch) {
          prodRow.style.display = 'grid';
          visibleProducts.push(prodRow);
          matchCount++;
        } else {
          prodRow.style.display = 'none';
        }
      });

      // Apply sorting to visible products
      if (currentSort !== 'default') {
        const sorted = [...visibleProducts].sort((a, b) => {
          if (currentSort === 'name-asc') {
            return (a.getAttribute('data-prod-name') || '').localeCompare(b.getAttribute('data-prod-name') || '');
          } else if (currentSort === 'name-desc') {
            return (b.getAttribute('data-prod-name') || '').localeCompare(a.getAttribute('data-prod-name') || '');
          } else if (currentSort === 'moq-asc') {
            const moqA = parseInt(a.getAttribute('data-prod-moq') || '0');
            const moqB = parseInt(b.getAttribute('data-prod-moq') || '0');
            return moqA - moqB;
          }
          return 0;
        });

        // Re-append items in sorted order
        if (catalogGrid) {
          sorted.forEach(el => catalogGrid.appendChild(el));
        }
      }

      // Toggle no products warning
      if (noProductsMsg) {
        if (matchCount === 0) {
          noProductsMsg.classList.remove('hidden');
        } else {
          noProductsMsg.classList.add('hidden');
        }
      }

      // Update category banner
      if (banner && bannerTitle && bannerDesc) {
        if (currentFilter === 'all') {
          banner.classList.add('hidden');
        } else {
          const catInfo = categories.find(c => c.slug === currentFilter);
          if (catInfo) {
            bannerTitle.textContent = catInfo.name;
            bannerDesc.textContent = catInfo.description;
            banner.classList.remove('hidden');
          } else {
            banner.classList.add('hidden');
          }
        }
      }
    };

    // Attach click listeners to filter buttons
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentFilter = btn.getAttribute('data-filter') || 'all';
        
        // Update button states
        filterButtons.forEach((b) => {
          const button = b;
          if (button.getAttribute('data-filter') === currentFilter) {
            button.classList.add('bg-primary', 'text-white');
            button.classList.remove('text-dark-muted', 'hover:bg-light', 'hover:text-primary');
          } else {
            button.classList.remove('bg-primary', 'text-white');
            button.classList.add('text-dark-muted', 'hover:bg-light', 'hover:text-primary');
          }
        });

        // Update URL query parameters silently
        const url = new URL(window.location.href);
        if (currentFilter === 'all') {
          url.searchParams.delete('category');
        } else {
          url.searchParams.set('category', currentFilter);
        }
        window.history.pushState({}, '', url.toString());

        updateCatalogue();
      });
    });

    // Search input listener
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value.toLowerCase().trim();
        updateCatalogue();
      });
    }

    // Sort listener
    if (sortSelect) {
      sortSelect.addEventListener('change', (e) => {
        currentSort = e.target.value;
        updateCatalogue();
      });
    }

    // Parse URL parameter on load
    const urlParams = new URLSearchParams(window.location.search);
    const urlCat = urlParams.get('category') || 'all';
    const searchVal = urlParams.get('search') || '';

    if (searchVal && searchInput) {
      searchInput.value = searchVal;
      searchQuery = searchVal.toLowerCase().trim();
    }

    const matchedBtn = Array.from(filterButtons).find(btn => btn.getAttribute('data-filter') === urlCat);
    if (matchedBtn) {
      currentFilter = urlCat;
      filterButtons.forEach(b => {
        const button = b;
        if (button.getAttribute('data-filter') === currentFilter) {
          button.classList.add('bg-primary', 'text-white');
          button.classList.remove('text-dark-muted', 'hover:bg-light', 'hover:text-primary');
        } else {
          button.classList.remove('bg-primary', 'text-white');
          button.classList.add('text-dark-muted', 'hover:bg-light', 'hover:text-primary');
        }
      });
    }

    updateCatalogue();
  });
</script>
