---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import products from '../../data/products.json';
import categories from '../../data/categories.json';

// Static route generation
export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

// Look up category name
const category = categories.find(c => c.slug === product.category);
const categoryName = category ? category.name : "Aquatic Equipment";

const seoTitle = `${product.name} | B2B Wholesale Specifications | Aquadura`;
const seoDescription = `Procure ${product.name} in bulk. Review technical specifications, FINA/CE standards compliance, packaging configurations, and get a direct quote.`;

// SKU Generator
const productSKU = `AQ-${product.slug.slice(0, 6).toUpperCase()}`;

// Mock related products in the same category
const relatedProducts = products
  .filter(p => p.category === product.category && p.slug !== product.slug)
  .slice(0, 3);
---

<Layout title={seoTitle} description={seoDescription} image={product.image}>
  <!-- Navigation Breadcrumbs -->
  <section class="bg-white py-6 border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
        <a href="/" class="hover:text-primary font-sans">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-primary font-sans">Catalog</a>
        <span>/</span>
        <a href={`/products?category=${product.category}`} class="hover:text-primary font-sans">{categoryName}</a>
        <span>/</span>
        <span class="text-primary font-sans">{product.name}</span>
      </nav>
    </div>
  </section>

  <!-- Main Details Page -->
  <section class="py-12 lg:py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        
        <!-- Left: Product Gallery (Thumbnails list, click zoom) -->
        <div class="lg:col-span-7 space-y-6">
          <!-- Main Display -->
          <div class="relative overflow-hidden rounded-2xl bg-light border border-light-darker aspect-[4/3] w-full group">
            <img
              id="main-product-gallery-image"
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover transition-transform duration-500 origin-center select-none"
              loading="eager"
            />
            <!-- Visual Indicator for Zoom -->
            <div class="absolute bottom-4 right-4 bg-dark/75 text-white text-[10px] font-bold px-3 py-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-opacity">
              Hover to Zoom
            </div>
          </div>
          
          <!-- Thumbnails Strip (simulating multi-angle shots) -->
          <div class="flex gap-4">
            <button class="gallery-thumb-btn w-20 h-16 rounded-lg border-2 border-primary overflow-hidden bg-light" data-image-url={product.image}>
              <img src={product.image} class="w-full h-full object-cover" alt="Main view" />
            </button>
            <button class="gallery-thumb-btn w-20 h-16 rounded-lg border border-light-darker overflow-hidden bg-light opacity-60 hover:opacity-100 transition-all" data-image-url={product.image}>
              <!-- Simulating angle 2 using CSS filter hue-rotate/grayscale just to look like a separate premium listing colorway -->
              <img src={product.image} class="w-full h-full object-cover hue-rotate-15" alt="Colorway option" />
            </button>
            <button class="gallery-thumb-btn w-20 h-16 rounded-lg border border-light-darker overflow-hidden bg-light opacity-60 hover:opacity-100 transition-all" data-image-url={product.image}>
              <!-- Simulating angle 3 -->
              <img src={product.image} class="w-full h-full object-cover brightness-95" alt="Alternate detail" />
            </button>
          </div>
        </div>

        <!-- Right: Purchase/Inquiry Sidebar & Details -->
        <div class="lg:col-span-5 space-y-8">
          <!-- Meta Specs Block -->
          <div class="space-y-4">
            <div class="flex items-center justify-between text-xs text-dark-muted font-sans font-medium">
              <span>SKU: {productSKU}</span>
              <span class="inline-flex items-center text-emerald-600 font-bold">
                <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse mr-1.5"></span>
                In Stock & Customisable
              </span>
            </div>
            
            <h1 class="text-3xl font-extrabold tracking-tight text-dark font-heading leading-tight">
              {product.name}
            </h1>
            <p class="text-xs font-semibold text-primary uppercase tracking-widest font-sans">{categoryName}</p>
            <div class="h-1.5 w-16 bg-primary rounded-full mt-2"></div>
          </div>

          <!-- Product description -->
          <p class="text-sm text-dark-muted leading-relaxed font-sans">
            {product.description}
          </p>

          <!-- Sticky Sidebar Panel (Muji/Apple Style B2B Details) -->
          <div class="rounded-2xl border border-light-darker bg-light p-6 space-y-6 shadow-soft font-sans">
            <div class="flex justify-between items-center pb-3 border-b border-light-darker/60 text-xs">
              <span class="font-bold text-dark-muted uppercase tracking-wider">Minimum Order (MOQ)</span>
              <span class="font-extrabold text-dark bg-white border border-light-darker rounded px-2.5 py-0.5">{product.moq}</span>
            </div>
            
            <div class="space-y-2">
              <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Custom Packaging & Branding</span>
              <p class="text-xs text-dark leading-relaxed font-medium">
                {product.customization}
              </p>
            </div>

            <!-- B2B Actions (WhatsApp, Form Scroll, Phone Call) -->
            <div class="flex flex-col gap-3 pt-2">
              <a
                href={`https://wa.me/18005550199?text=Hi, I am looking to procure the ${product.name} (SKU: ${productSKU}) for my business. Please provide quote terms.`}
                target="_blank"
                rel="noopener noreferrer"
                class="flex w-full items-center justify-center rounded-full bg-emerald-500 py-3 text-center text-xs font-bold text-white shadow-soft hover:bg-emerald-600 transition-colors"
              >
                Inquire via WhatsApp
              </a>
              <a
                href="#quote"
                class="flex w-full items-center justify-center rounded-full bg-primary py-3 text-center text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-colors"
              >
                Request formal PDF Quote
              </a>
              <a
                href="tel:+18005550199"
                class="flex w-full items-center justify-center rounded-full border border-light-darker bg-white py-3 text-center text-xs font-bold text-dark hover:bg-light transition-all"
              >
                Speak to Sales Agent
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- Tabbed Specifications & Packaging Details (12-column grid layout, no boxes) -->
      <div class="mt-20 border-t border-light-darker pt-16 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        
        <!-- Left: Technical Parameters -->
        <div class="lg:col-span-7 space-y-6">
          <h3 class="text-base font-bold uppercase tracking-wider text-dark font-heading">Technical parameters</h3>
          <div class="overflow-hidden rounded-xl border border-light-darker shadow-soft bg-white">
            <table class="min-w-full divide-y divide-light-darker font-sans text-xs">
              <tbody class="divide-y divide-light-darker">
                {Object.entries(product.specifications).map(([key, val]) => (
                  <tr class="even:bg-light/20">
                    <td class="px-5 py-3.5 font-bold text-dark-muted w-1/3 border-r border-light-darker bg-light/5">{key}</td>
                    <td class="px-5 py-3.5 text-dark font-medium">{val}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Right: B2B Packaging & Document Downloads -->
        <div class="lg:col-span-5 space-y-8 font-sans">
          
          <!-- Packaging Details -->
          <div class="space-y-4">
            <h3 class="text-base font-bold uppercase tracking-wider text-dark font-heading">Logistics & Packaging</h3>
            <div class="rounded-xl border border-light-darker p-5 bg-white space-y-3.5 text-xs text-dark-muted">
              <div class="flex justify-between">
                <span>Standard Carton Capacity:</span>
                <strong class="text-dark">100 units / carton</strong>
              </div>
              <div class="flex justify-between">
                <span>Carton Dimensions:</span>
                <strong class="text-dark">60cm x 40cm x 35cm</strong>
              </div>
              <div class="flex justify-between">
                <span>Gross Weight per Carton:</span>
                <strong class="text-dark">12.5 kg</strong>
              </div>
              <div class="flex justify-between">
                <span>Container Load (20GP):</span>
                <strong class="text-dark">Approx. 320 Cartons</strong>
              </div>
            </div>
          </div>

          <!-- Technical downloads -->
          <div class="space-y-4">
            <h3 class="text-xs font-bold uppercase tracking-wider text-dark">Available Downloads</h3>
            <div class="space-y-2">
              <a
                href="/downloads"
                class="flex items-center justify-between p-3 rounded-lg border border-light-darker hover:bg-light hover:text-primary transition-all text-xs font-semibold text-dark-muted"
              >
                <span>Product Technical Drawing (PDF)</span>
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
              </a>
              <a
                href="/downloads"
                class="flex items-center justify-between p-3 rounded-lg border border-light-darker hover:bg-light hover:text-primary transition-all text-xs font-semibold text-dark-muted"
              >
                <span>Compliance Certifications (PDF)</span>
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
              </a>
            </div>
          </div>

        </div>
      </div>

      <!-- Feature Bullets (Alternating Section) -->
      <div class="mt-20 border-t border-light-darker pt-16 space-y-6">
        <h3 class="text-base font-bold uppercase tracking-wider text-dark font-heading text-center">Material Highlights & Design Features</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {product.features.map((feat, idx) => (
            <div class="rounded-xl border border-light-darker p-5 bg-white space-y-3 shadow-soft">
              <span class="text-primary font-bold font-heading text-lg">0{idx + 1}</span>
              <p class="text-xs text-dark-muted font-sans font-medium leading-relaxed">{feat}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Related Products Section -->
      {relatedProducts.length > 0 && (
        <div class="mt-24 border-t border-light-darker pt-16 space-y-8">
          <div class="flex justify-between items-end">
            <h3 class="text-xl font-bold text-dark font-heading">Related Collections</h3>
            <a href="/products" class="text-xs font-bold text-primary hover:underline font-sans">Browse Division &rarr;</a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedProducts.map((p) => (
              <a href={`/products/${p.slug}`} class="group space-y-4">
                <div class="overflow-hidden rounded-xl border border-light-darker bg-light aspect-[4/3]">
                  <img src={p.image} class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" alt={p.name} />
                </div>
                <div class="space-y-1 font-sans">
                  <h4 class="text-sm font-bold text-dark group-hover:text-primary transition-colors">{p.name}</h4>
                  <span class="text-[10px] font-bold text-dark-muted uppercase">MOQ: {p.moq}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Recently Viewed Section (Generated dynamically via LocalStorage script) -->
      <div id="recently-viewed-container" class="mt-24 border-t border-light-darker pt-16 space-y-8 hidden">
        <h3 class="text-xl font-bold text-dark font-heading">Recently Viewed Products</h3>
        <div id="recently-viewed-list" class="grid grid-cols-1 md:grid-cols-4 gap-6"></div>
      </div>

      <!-- Formal Quote Request Form -->
      <div class="mt-24 border-t border-light-darker pt-16 max-w-3xl mx-auto space-y-8" id="quote">
        <div class="text-center space-y-2">
          <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block">Quote Request</span>
          <h3 class="text-3xl font-extrabold text-dark font-heading">Corporate Bid Specifications</h3>
          <p class="text-xs text-dark-muted font-sans max-w-sm mx-auto">
            Provide details of your custom branding, volume parameters, and shipping timelines. B2B accounts are assigned a dedicated sales manager.
          </p>
        </div>
        <ContactForm preselectedCategory={product.category} preselectedProduct={product.name} />
      </div>

    </div>
  </section>
</Layout>

<script define:vars={{ productSKU, product }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Dynamic Gallery Image Switching
    const mainImg = document.getElementById('main-product-gallery-image');
    const thumbBtns = document.querySelectorAll('.gallery-thumb-btn');

    thumbBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetUrl = btn.getAttribute('data-image-url');
        
        // Remove active class from all, add to clicked
        thumbBtns.forEach((b) => {
          b.classList.remove('border-primary', 'border-2');
          b.classList.add('border-light-darker', 'opacity-60');
        });
        btn.classList.add('border-primary', 'border-2');
        btn.classList.remove('border-light-darker', 'opacity-60');

        if (mainImg && targetUrl) {
          mainImg.setAttribute('src', targetUrl);
        }
      });
    });

    // Main Image Hover Zoom Effect (Apple Style)
    const galleryContainer = mainImg?.parentElement;
    if (galleryContainer && mainImg) {
      galleryContainer.addEventListener('mousemove', (e) => {
        const rect = galleryContainer.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        
        mainImg.style.transformOrigin = `${x}% ${y}%`;
        mainImg.style.transform = 'scale(1.5)';
      });

      galleryContainer.addEventListener('mouseleave', () => {
        mainImg.style.transform = 'scale(1)';
        mainImg.style.transformOrigin = 'center';
      });
    }

    // Recently Viewed Logic
    const MAX_RECENT = 4;
    const key = 'aquadura_recent_products';

    const getRecent = () => {
      try {
        return JSON.parse(localStorage.getItem(key) || '[]');
      } catch (e) {
        return [];
      }
    };

    const addRecent = (prod) => {
      const items = getRecent();
      const filtered = items.filter(item => item.slug !== prod.slug);
      filtered.unshift({
        slug: prod.slug,
        name: prod.name,
        image: prod.image,
        moq: prod.moq
      });
      localStorage.setItem(key, JSON.stringify(filtered.slice(0, MAX_RECENT)));
    };

    // Add current product to recently viewed, but exclude from list output
    const currentProdInfo = {
      slug: product.slug,
      name: product.name,
      image: product.image,
      moq: product.moq
    };

    // Render recently viewed list (excluding current product)
    const renderRecentList = () => {
      const list = getRecent().filter(item => item.slug !== product.slug);
      const container = document.getElementById('recently-viewed-container');
      const listEl = document.getElementById('recently-viewed-list');

      if (list.length > 0 && container && listEl) {
        container.classList.remove('hidden');
        listEl.innerHTML = list.map(item => `
          <a href="/products/${item.slug}" class="group space-y-3 font-sans">
            <div class="overflow-hidden rounded-xl border border-light-darker bg-light aspect-[4/3]">
              <img src="${item.image}" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" alt="${item.name}" />
            </div>
            <div class="space-y-1">
              <h4 class="text-xs font-bold text-dark group-hover:text-primary transition-colors">${item.name}</h4>
              <span class="block text-[9px] font-bold text-dark-muted uppercase">MOQ: ${item.moq}</span>
            </div>
          </a>
        `).join('');
      }
    };

    addRecent(currentProdInfo);
    renderRecentList();
  });
</script>
