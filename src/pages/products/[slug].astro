---
import Layout from '../../layouts/Layout.astro';
import products from '../../data/products.json';
import categories from '../../data/categories.json';
import config from '../../data/config.json';

// Static route generation
export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

// Look up category
const category = categories.find(c => c.slug === product.category);
const categoryName = category ? category.name : "Aquatic Equipment";

const seoTitle = `${product.name} | Shop Online | ${config.brandName}`;
const seoDescription = `Buy ${product.name} online. Review specifications, materials, sizing, and order direct from ${config.brandName}.`;

const productSKU = `AQ-${product.slug.slice(0, 6).toUpperCase()}`;

// Mock related products
const relatedProducts = products
  .filter(p => p.category === product.category && p.slug !== product.slug)
  .slice(0, 3);

// Mock frequently bought together
const frequentlyBought = products
  .filter(p => p.category !== product.category)
  .slice(0, 2);
---

<Layout title={seoTitle} description={seoDescription} image={product.image}>
  
  <!-- Navigation Breadcrumbs -->
  <section class="bg-white py-6 border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
        <a href="/" class="hover:text-primary font-sans">Home</a>
        <span>/</span>
        <a href="/products" class="hover:text-primary font-sans">Catalogue</a>
        <span>/</span>
        <a href={`/products?category=${product.category}`} class="hover:text-primary font-sans">{categoryName}</a>
        <span>/</span>
        <span class="text-primary font-sans">{product.name}</span>
      </nav>
    </div>
  </section>

  <!-- Product Details -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        
        <!-- Left: Product Photo & Multi-Angle Swap -->
        <div class="lg:col-span-7 space-y-6">
          <!-- Main Photo with Zoom hover -->
          <div class="relative overflow-hidden rounded-2xl bg-light border border-light-darker aspect-[4/3] w-full group">
            <img
              id="main-product-gallery-image"
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover transition-transform duration-500 origin-center select-none"
              loading="eager"
            />
            <!-- Visual Zoom Alert -->
            <div class="absolute bottom-4 right-4 bg-dark/75 text-white text-[10px] font-bold px-3 py-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-opacity">
              Hover to Zoom
            </div>
          </div>
          
          <!-- Thumbnail Angle Swappers -->
          <div class="flex gap-4">
            <button class="gallery-thumb-btn w-20 h-16 rounded-xl border-2 border-primary overflow-hidden bg-light" data-image-url={product.image}>
              <img src={product.image} class="w-full h-full object-cover" alt="Main View" />
            </button>
            <button class="gallery-thumb-btn w-20 h-16 rounded-xl border border-light-darker overflow-hidden bg-light opacity-60 hover:opacity-100 transition-all" data-image-url={product.image}>
              <img src={product.image} class="w-full h-full object-cover hue-rotate-30" alt="Color Option" />
            </button>
            <button class="gallery-thumb-btn w-20 h-16 rounded-xl border border-light-darker overflow-hidden bg-light opacity-60 hover:opacity-100 transition-all" data-image-url={product.image}>
              <img src={product.image} class="w-full h-full object-cover brightness-90" alt="Detail Angle" />
            </button>
          </div>
        </div>

        <!-- Right: Purchase configurator -->
        <div class="lg:col-span-5 space-y-6 font-sans">
          <div class="space-y-2">
            <div class="flex items-center justify-between text-xs text-dark-muted font-medium">
              <span>SKU: {productSKU}</span>
              <span class="inline-flex items-center text-emerald-600 font-semibold">
                <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse mr-1.5"></span>
                In Stock & Ready to Ship
              </span>
            </div>
            
            <h1 class="text-2xl font-bold tracking-tight text-dark font-heading leading-tight">
              {product.name}
            </h1>
            <span class="text-xs font-bold text-primary uppercase tracking-widest block">{categoryName}</span>
          </div>

          <p class="text-xs sm:text-sm text-dark-muted leading-relaxed font-medium">
            {product.description}
          </p>

          <!-- Price & Cart config card -->
          <div class="rounded-2xl border border-light-darker bg-light p-6 space-y-6 shadow-soft">
            <div class="flex justify-between items-center pb-3 border-b border-light-darker/60 text-xs">
              <span class="font-bold text-dark-muted uppercase tracking-wider">Retail Price</span>
              <span class="text-lg font-bold text-primary">₹{product.price.toFixed(2)}</span>
            </div>

            <!-- Configuration Inputs -->
            <div class="space-y-4">
              <!-- Qty Input -->
              <div class="space-y-1.5">
                <label for="detail-qty-input" class="block text-[9px] font-bold text-dark uppercase tracking-wider">Quantity</label>
                <input
                  type="number"
                  id="detail-qty-input"
                  min="1"
                  value="1"
                  class="qty-input-field w-full rounded-xl border border-light-darker bg-white px-4 py-3 font-bold text-dark text-xs focus:outline-none"
                />
              </div>

              <!-- Options -->
              <div class="space-y-1.5 pt-1">
                <label for="detail-color-select" class="block text-[9px] font-bold text-dark uppercase tracking-wider">Select Colorway</label>
                <select
                  id="detail-color-select"
                  class="w-full rounded-xl border border-light-darker bg-white px-3 py-3 text-xs text-dark font-semibold focus:outline-none"
                >
                  <option value="standard">Standard Navy / Blue</option>
                  <option value="alternate">Special Slate / Graphite</option>
                  <option value="highlight">Bright Crimson / Yellow</option>
                </select>
              </div>
            </div>

            <!-- Main Add to Cart Action -->
            <button
              type="button"
              id="detail-add-to-cart-btn"
              data-slug={product.slug}
              data-name={product.name}
              data-image={product.image}
              data-price={product.price.toString()}
              class="w-full inline-flex items-center justify-center rounded-xl bg-primary py-3.5 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all focus:outline-none"
            >
              Add to Cart
            </button>
          </div>
        </div>

      </div>

      <!-- Tabbed Specifications & Technical Details -->
      <div class="mt-16 border-t border-light-darker pt-12 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        
        <!-- Left: Tabs & Tables -->
        <div class="lg:col-span-8 space-y-6">
          
          <!-- Tab Navigation Headers -->
          <div class="flex border-b border-light-darker text-xs font-bold uppercase tracking-wider text-dark-muted font-heading">
            <button class="spec-tab-btn pb-4 border-b-2 border-primary text-primary px-4 focus:outline-none" data-tab="specs">
              Specifications
            </button>
            <button class="spec-tab-btn pb-4 border-b-2 border-transparent px-4 hover:text-dark focus:outline-none" data-tab="logistics">
              Delivery & Returns
            </button>
            <button class="spec-tab-btn pb-4 border-b-2 border-transparent px-4 hover:text-dark focus:outline-none" data-tab="visual">
              Materials Guide
            </button>
          </div>

          <!-- Specs Tab Panel -->
          <div id="panel-specs" class="spec-tab-panel space-y-6">
            <div class="overflow-hidden rounded-xl border border-light-darker bg-white shadow-soft">
              <table class="min-w-full divide-y divide-light-darker text-xs text-dark font-sans">
                <tbody class="divide-y divide-light-darker">
                  {Object.entries(product.specifications).map(([k, v]) => (
                    <tr class="even:bg-light/10">
                      <td class="px-5 py-4 font-bold text-dark-muted w-1/3 border-r border-light-darker bg-light/5">{k}</td>
                      <td class="px-5 py-4 text-dark font-semibold">{v}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- Logistics Tab Panel -->
          <div id="panel-logistics" class="spec-tab-panel space-y-6 hidden">
            <div class="overflow-hidden rounded-xl border border-light-darker bg-white p-6 shadow-soft space-y-4 font-sans text-xs font-medium text-dark-muted">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <span class="block font-bold text-dark mb-1 uppercase tracking-wider text-[9px]">Standard Dispatch</span>
                  <span>Orders are packaged and dispatched from our logistics center within 24-48 hours.</span>
                </div>
                <div>
                  <span class="block font-bold text-dark mb-1 uppercase tracking-wider text-[9px]">Transit Timing</span>
                  <span>Standard domestic shipping takes 3-5 business days. Express shipping takes 1-2 days.</span>
                </div>
                <div>
                  <span class="block font-bold text-dark mb-1 uppercase tracking-wider text-[9px]">Return Policy</span>
                  <span>We offer a simple 14-day return policy on all unused products in their original packaging.</span>
                </div>
                <div>
                  <span class="block font-bold text-dark mb-1 uppercase tracking-wider text-[9px]">Customer Support</span>
                  <span>Contact our support desk for shipping status or product warranty evaluations.</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Materials Tab Panel -->
          <div id="panel-visual" class="spec-tab-panel space-y-6 hidden">
            <div class="rounded-xl border border-light-darker bg-light p-8 text-center shadow-soft flex flex-col items-center justify-center space-y-3 min-h-[220px]">
              <!-- Lucide-like Star SVG instead of Emoji -->
              <div class="h-10 w-10 rounded-full bg-primary/10 border border-primary/25 flex items-center justify-center text-primary">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              </div>
              <h4 class="text-xs font-bold text-dark font-heading">Premium Materials Standard</h4>
              <p class="text-xs text-dark-muted max-w-sm leading-relaxed font-sans font-medium">
                Our swim caps leverage medical-grade LSR silicone. Eyewear models feature impact-proof polycarbonate lenses with integrated anti-fog nano coatings.
              </p>
            </div>
          </div>

        </div>

        <!-- Right: Frequently Bought Together & Related Categories -->
        <div class="lg:col-span-4 space-y-6">
          
          <!-- Frequently Bought together -->
          <div class="bg-light rounded-2xl border border-light-darker p-5 shadow-soft space-y-4">
            <h3 class="text-xs font-bold text-dark uppercase tracking-wider font-heading border-b border-light-darker/60 pb-2">Frequently Bought Together</h3>
            
            <div class="space-y-3">
              {frequentlyBought.map(p => (
                <a href={`/products/${p.slug}`} class="flex items-center gap-3 p-2 bg-white border border-light-darker rounded-lg hover:border-slate-300 transition-colors group">
                  <div class="h-10 w-12 rounded-lg overflow-hidden border border-light-darker shrink-0 bg-light">
                    <img src={p.image} alt={p.name} class="h-full w-full object-cover" />
                  </div>
                  <div class="space-y-0.5">
                    <span class="block text-[10px] font-bold text-dark font-heading leading-tight group-hover:text-primary transition-colors line-clamp-1">{p.name}</span>
                    <span class="text-[9px] text-primary font-sans font-bold">₹{p.price.toFixed(2)}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Related Divisions -->
          <div class="bg-white rounded-2xl border border-light-darker p-5 shadow-soft space-y-4">
            <h3 class="text-xs font-bold text-dark uppercase tracking-wider font-heading border-b border-light-darker/60 pb-2">Related Categories</h3>
            <div class="flex flex-wrap gap-2 text-xs font-sans">
              {categories.slice(0, 4).map(c => (
                <a href={`/products?category=${c.slug}`} class="px-2.5 py-1.5 rounded-lg border border-light-darker bg-light hover:bg-white hover:border-slate-300 font-semibold text-dark-muted hover:text-primary transition-all">
                  {c.name}
                </a>
              ))}
            </div>
          </div>

        </div>

      </div>

      <!-- Recently Viewed Block -->
      <div id="recently-viewed-section" class="mt-16 border-t border-light-darker pt-12 space-y-5 hidden">
        <h3 class="text-xs font-bold text-dark uppercase tracking-wider font-heading">Recently Viewed Products</h3>
        <div id="recently-viewed-list" class="grid grid-cols-2 sm:grid-cols-4 gap-6 font-sans">
          <!-- Injected dynamically -->
        </div>
      </div>

    </div>
  </section>

  <!-- MOBILE STICKY BOTTOM QUICK CART BAR -->
  <div class="fixed bottom-0 inset-x-0 bg-white border-t border-light-darker z-30 py-3 px-6 shadow-2xl flex md:hidden items-center justify-between gap-4 font-sans">
    <div class="flex flex-col gap-0.5 leading-none">
      <span class="text-[10px] font-bold text-dark truncate max-w-[150px]">{product.name}</span>
      <span class="text-xs font-bold text-primary">₹{product.price.toFixed(2)}</span>
    </div>
    
    <div class="flex items-center gap-2">
      <input
        type="number"
        id="mobile-qty-input"
        min="1"
        value="1"
        class="w-14 rounded-lg border border-light-darker bg-light px-2 py-1.5 font-bold text-dark text-xs focus:outline-none"
      />
      <button
        type="button"
        id="mobile-sticky-add-btn"
        class="bg-primary text-white text-[10px] font-bold rounded-lg px-4 py-2.5 hover:bg-primary-dark transition-all focus:outline-none"
      >
        Add to Cart
      </button>
    </div>
  </div>

</Layout>

<script define:vars={{ products, product }}>
  document.addEventListener('DOMContentLoaded', () => {

    // ----------------------------------------------------
    // GALLERY SWAPPER CODE
    // ----------------------------------------------------
    const mainImg = document.getElementById('main-product-gallery-image');
    
    document.querySelectorAll('.gallery-thumb-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target.closest('.gallery-thumb-btn');
        if (!target || !mainImg) return;

        const url = target.getAttribute('data-image-url');
        mainImg.src = url;

        document.querySelectorAll('.gallery-thumb-btn').forEach(b => {
          b.classList.remove('border-primary', 'border-2');
          b.classList.add('border-light-darker', 'border');
        });
        target.classList.remove('border-light-darker', 'border');
        target.classList.add('border-primary', 'border-2');
      });
    });

    // Main Image Zoom Effect
    const wrapper = mainImg?.parentElement;
    if (wrapper && mainImg) {
      wrapper.addEventListener('mousemove', (e) => {
        const rect = wrapper.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        mainImg.style.transformOrigin = `${x}% ${y}%`;
        mainImg.style.transform = 'scale(1.5)';
      });

      wrapper.addEventListener('mouseleave', () => {
        mainImg.style.transform = 'scale(1)';
      });
    }

    // ----------------------------------------------------
    // TABS SYSTEM CODE
    // ----------------------------------------------------
    document.querySelectorAll('.spec-tab-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const tabId = target.getAttribute('data-tab');

        document.querySelectorAll('.spec-tab-btn').forEach(b => {
          b.classList.remove('border-primary', 'text-primary');
          b.classList.add('border-transparent', 'text-dark-muted');
        });
        target.classList.remove('border-transparent', 'text-dark-muted');
        target.classList.add('border-primary', 'text-primary');

        document.querySelectorAll('.spec-tab-panel').forEach(panel => {
          panel.classList.add('hidden');
        });
        document.getElementById(`panel-${tabId}`)?.classList.remove('hidden');
      });
    });

    // ----------------------------------------------------
    // PERSISTED RECENTLY VIEWED PRODUCTS CODE
    // ----------------------------------------------------
    const RV_KEY = 'b2b_recently_viewed';
    let rv = [];
    try {
      const data = localStorage.getItem(RV_KEY);
      rv = data ? JSON.parse(data) : [];
    } catch (e) {
      rv = [];
    }

    rv = rv.filter(slug => slug !== product.slug);
    rv.unshift(product.slug);
    rv = rv.slice(0, 5);

    try {
      localStorage.setItem(RV_KEY, JSON.stringify(rv));
    } catch (e) {}

    const listContainer = document.getElementById('recently-viewed-list');
    const sectionContainer = document.getElementById('recently-viewed-section');

    const toShow = rv.filter(slug => slug !== product.slug).slice(0, 4);
    if (toShow.length > 0 && listContainer && sectionContainer) {
      sectionContainer.classList.remove('hidden');
      listContainer.innerHTML = toShow.map(slug => {
        const item = products.find(p => p.slug === slug);
        if (!item) return '';
        return `
          <a href="/products/${item.slug}" class="group block space-y-3 bg-light border border-light-darker p-4 rounded-xl hover:border-slate-300 transition-colors">
            <div class="aspect-[4/3] rounded-lg overflow-hidden bg-white border border-light-darker">
              <img src="${item.image}" alt="${item.name}" class="h-full w-full object-cover group-hover:scale-102 transition-transform duration-500" />
            </div>
            <div class="space-y-1 font-sans">
              <span class="block text-[10px] font-bold text-dark leading-tight group-hover:text-primary transition-colors line-clamp-1">${item.name}</span>
              <span class="block text-xs text-primary font-bold">₹${item.price.toFixed(2)}</span>
            </div>
          </a>
        `;
      }).join('');
    }

    // ----------------------------------------------------
    // SYNC SIDEBAR & BOTTOM MOBILE QUANTITY & ADD TO CART
    // ----------------------------------------------------
    const desktopQtyInput = document.getElementById('detail-qty-input') as HTMLInputElement;
    const mobileQtyInput = document.getElementById('mobile-qty-input') as HTMLInputElement;
    const desktopAddBtn = document.getElementById('detail-add-to-cart-btn');
    const mobileAddBtn = document.getElementById('mobile-sticky-add-btn');

    const syncQty = (src, dest) => {
      if (src && dest) {
        dest.value = src.value;
      }
    };

    desktopQtyInput?.addEventListener('input', () => syncQty(desktopQtyInput, mobileQtyInput));
    mobileQtyInput?.addEventListener('input', () => syncQty(mobileQtyInput, desktopQtyInput));

    const triggerAdd = () => {
      const qty = parseInt(desktopQtyInput?.value || mobileQtyInput?.value || '1') || 1;

      if ((window as any).ShoppingCart) {
        (window as any).ShoppingCart.addItem({
          slug: product.slug,
          name: product.name,
          image: product.image,
          price: product.price,
          qty: qty
        });
      }
    };

    desktopAddBtn?.addEventListener('click', triggerAdd);
    mobileAddBtn?.addEventListener('click', triggerAdd);

  });
</script>
