---
import Layout from '../layouts/Layout.astro';
import faqs from '../data/faq.json';
import config from '../data/config.json';

const seoTitle = `Help Desk & Store FAQs | ${config.brandName}`;
const seoDescription = "Find answers regarding swim gear sizing, delivery dispatch, order tracking, and store return policies.";
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Page Title and Breadcrumb (Clean & Standard Width) -->
  <div class="mx-auto max-w-7xl px-6 md:px-8 pt-8 pb-4 font-sans bg-white border-b border-light-darker">
    <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2 mb-2">
      <a href="/" class="hover:text-primary">Home</a>
      <span>/</span>
      <span class="text-primary">FAQ</span>
    </nav>
    <h1 class="text-2xl font-bold tracking-tight text-dark font-heading">
      Store Help & FAQ
    </h1>
  </div>

  <!-- FAQ Accordions -->
  <section class="py-20 bg-light">
    <div class="mx-auto max-w-3xl px-6 md:px-8 space-y-8 font-sans">
      
      <!-- FAQ Search -->
      <div class="relative max-w-md mx-auto mb-12">
        <input
          type="text"
          id="faq-search-input"
          placeholder="Search FAQs (e.g. shipping, sizing)..."
          class="w-full rounded-full border border-light-darker bg-white px-5 py-3 text-sm text-dark placeholder:text-dark-muted/50 focus:border-primary focus:outline-none transition-all shadow-soft font-medium"
        />
        <svg class="absolute right-4 top-3.5 h-5 w-5 text-dark-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>

      <!-- FAQ Accordions List -->
      <div id="faq-accordions-list" class="space-y-4">
        {faqs.map((faq) => (
          <div class="faq-item bg-white border border-light-darker rounded-2xl shadow-soft transition-all duration-300">
            <details class="group/details">
              <summary class="flex justify-between items-center p-6 font-bold text-sm text-dark cursor-pointer list-none select-none font-heading focus:outline-none">
                <span class="faq-question-text">{faq.question}</span>
                <span class="ml-4 shrink-0 transition-transform duration-200 group-open/details:rotate-45 text-primary">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 pt-0 text-xs text-dark-muted leading-relaxed font-sans border-t border-light-darker/60 pt-4">
                {faq.answer}
              </div>
            </details>
          </div>
        ))}
      </div>

      <!-- Search feedback message -->
      <div id="faq-no-results" class="hidden text-center py-12 bg-white border border-light-darker rounded-2xl p-6 shadow-soft">
        <h3 class="text-sm font-bold text-dark font-heading">No matching questions found</h3>
        <p class="text-xs text-dark-muted mt-1">Try searching another keyword or reach out directly at {config.contact.email}.</p>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-16 border-t border-light-darker text-center space-y-6">
    <div class="mx-auto max-w-2xl px-6">
      <h2 class="text-xl font-bold tracking-tight text-dark font-heading">Still Have Questions?</h2>
      <p class="text-xs text-dark-muted font-sans max-w-md mx-auto leading-relaxed mt-2 font-medium">
        If you need help with a custom squad colorway order, specific sizing, or order delivery tracking, feel free to contact our store desk.
      </p>
      <div class="pt-4">
        <a href="/contact" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all">
          Contact Store Care
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('faq-search-input');
    const faqItems = document.querySelectorAll('.faq-item');
    const noResultsMsg = document.getElementById('faq-no-results');

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const query = target.value.toLowerCase().trim();
        let matchCount = 0;

        faqItems.forEach((item) => {
          const faqEl = item as HTMLElement;
          const questionText = faqEl.querySelector('.faq-question-text')?.textContent?.toLowerCase() || '';
          const answerText = faqEl.querySelector('div')?.textContent?.toLowerCase() || '';

          if (questionText.includes(query) || answerText.includes(query)) {
            faqEl.style.display = 'block';
            matchCount++;
          } else {
            faqEl.style.display = 'none';
            const details = faqEl.querySelector('details');
            if (details) {
              details.removeAttribute('open');
            }
          }
        });

        if (noResultsMsg) {
          if (matchCount === 0) {
            noResultsMsg.classList.remove('hidden');
          } else {
            noResultsMsg.classList.add('hidden');
          }
        }
      });
    }
  });
</script>
