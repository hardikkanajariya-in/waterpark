---
import Layout from '../layouts/Layout.astro';
import applications from '../data/applications.json';
import products from '../data/products.json';
import config from '../data/config.json';

const seoTitle = `Product Use Cases | ${config.brandName}`;
const seoDescription = `Learn how ${config.brandName} swimwear, caps, and water park slide tubes are used in swimming academies, water parks, hotels, and recreation zones.`;

// Resolve product details for each application focus list
const getProductDetails = (slugList: string[]) => {
  return products.filter(p => slugList.includes(p.slug));
};
---

<Layout title={seoTitle} description={seoDescription}>
  
  <!-- Page Title and Breadcrumb (Clean & Standard Width) -->
  <div class="mx-auto max-w-7xl px-6 md:px-8 pt-8 pb-4 font-sans bg-white border-b border-light-darker">
    <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2 mb-2">
      <a href="/" class="hover:text-primary">Home</a>
      <span>/</span>
      <span class="text-primary">Applications</span>
    </nav>
    <h1 class="text-2xl font-bold tracking-tight text-dark font-heading">
      Product Use Cases
    </h1>
  </div>

  <!-- Applications List -->
  <section class="py-12 bg-light space-y-24">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-24">
      {applications.map((app, index) => {
        const focusItems = getProductDetails(app.focus_products);
        const isEven = index % 2 === 0;

        return (
          <div id={app.slug} class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start border-b border-light-darker/60 pb-20 last:border-b-0 last:pb-0 scroll-mt-32">
            
            <!-- App Narrative -->
            <div class={`lg:col-span-5 space-y-6 ${isEven ? 'lg:order-1' : 'lg:order-2'} font-sans`}>
              <span class="text-[9px] font-bold text-primary uppercase tracking-widest block">Activity Focus</span>
              <h2 class="text-xl font-bold text-dark font-heading leading-tight">{app.name}</h2>
              <p class="text-xs text-dark-muted leading-relaxed font-medium">{app.description}</p>
              
              <!-- Recommendations list -->
              <div class="space-y-3.5 border-t border-light-darker/60 pt-6">
                <h4 class="text-[9px] font-bold text-dark uppercase tracking-wider">Features Utilized</h4>
                <ul class="text-xs text-dark-muted space-y-2 font-medium">
                  <li class="flex items-start">
                    <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2.5 mt-1.5 shrink-0"></span>
                    <span>{app.tagline}</span>
                  </li>
                  <li class="flex items-start">
                    <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2.5 mt-1.5 shrink-0"></span>
                    <span>Chlorine-resistant and UV-protected materials</span>
                  </li>
                  <li class="flex items-start">
                    <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2.5 mt-1.5 shrink-0"></span>
                    <span>Ergonomically tested for active use</span>
                  </li>
                </ul>
              </div>
            </div>

            <!-- App Recommendations Products Grid -->
            <div class={`lg:col-span-7 space-y-6 ${isEven ? 'lg:order-2' : 'lg:order-1'}`}>
              <h3 class="text-[9px] font-bold text-dark-muted uppercase tracking-wider mb-2 pl-1">Top Recommended Items</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 font-sans">
                {focusItems.map(p => (
                  <a href={`/products/${p.slug}`} class="group flex items-center gap-3 p-3 bg-white border border-light-darker rounded-xl hover:border-slate-300 transition-colors shadow-soft">
                    <div class="h-12 w-16 rounded-lg overflow-hidden border border-light-darker shrink-0 bg-light">
                      <img src={p.image} alt={p.name} class="h-full w-full object-cover" />
                    </div>
                    <div class="space-y-0.5 leading-none">
                      <span class="block text-xs font-bold text-dark font-heading line-clamp-1 group-hover:text-primary transition-colors pr-4">{p.name}</span>
                      <span class="text-xs font-bold text-primary">₹{p.price.toFixed(2)}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>

          </div>
        );
      })}
    </div>
  </section>
</Layout>
