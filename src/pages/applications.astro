---
import Layout from '../layouts/Layout.astro';
import applications from '../data/applications.json';
import products from '../data/products.json';
import config from '../data/config.json';

const seoTitle = `Aquatic Product Applications & Deployments | ${config.brandName}`;
const seoDescription = "Review commercial application contexts for our products. See recommendations for swim academies, theme parks, resorts, and distributor catalogs.";

// Resolve product details for each application focus list
const getProductDetails = (slugList: string[]) => {
  return products.filter(p => slugList.includes(p.slug));
};
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Header -->
  <section class="bg-white py-16 border-b border-light-darker">
    <div class="mx-auto max-w-4xl px-6 md:px-8 space-y-4">
      <span class="text-[11px] font-bold tracking-[0.25em] text-primary uppercase block">Product Utility</span>
      <h1 class="text-4xl font-extrabold tracking-tight text-dark font-heading">
        Deployment Settings
      </h1>
      <p class="text-sm text-dark-muted font-sans max-w-xl leading-relaxed">
        Our products are customized for target sectors. Select your business segment to review compliance, deployment guidelines, and relevant product selections.
      </p>
    </div>
  </section>

  <!-- Applications List -->
  <section class="py-20 bg-light space-y-24">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-24">
      {applications.map((app, index) => {
        const focusItems = getProductDetails(app.focus_products);
        const isEven = index % 2 === 0;

        return (
          <div id={app.slug} class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start border-b border-light-darker/60 pb-20 last:border-b-0 last:pb-0 scroll-mt-32">
            
            <!-- App Narrative -->
            <div class={`lg:col-span-5 space-y-6 ${isEven ? 'lg:order-1' : 'lg:order-2'}`}>
              <div class="space-y-2 font-sans">
                <span class="text-[10px] font-extrabold tracking-widest text-primary uppercase">Sector 0{index + 1}</span>
                <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">{app.name}</h2>
              </div>
              <p class="text-xs text-dark-muted leading-relaxed font-sans">{app.description}</p>
              
              <!-- Segment Specifications / Standards -->
              <div class="rounded-xl border border-light-darker p-4 bg-white space-y-2.5 text-[11px] text-dark-muted font-sans font-medium">
                <div class="flex justify-between">
                  <span>Primary Standard Compliance:</span>
                  <strong class="text-dark">
                    {app.slug === 'swimming-academies' && 'FINA Hydrodynamics'}
                    {app.slug === 'water-parks' && 'CE Flotation / EN ISO'}
                    {app.slug === 'hotels-resorts' && 'AISI 316 Corrosion Resistance'}
                    {app.slug === 'distributors-retailers' && 'REACH / RoHS Certification'}
                  </strong>
                </div>
                <div class="flex justify-between">
                  <span>Recommended Dispatch:</span>
                  <strong class="text-dark">Bulk LCL/FCL Sea Freight</strong>
                </div>
              </div>
            </div>

            <!-- Product Recommendations Grid -->
            <div class={`lg:col-span-7 space-y-4 ${isEven ? 'lg:order-2' : 'lg:order-1'}`}>
              <h3 class="text-xs font-bold uppercase tracking-wider text-dark-muted font-sans">Recommended Catalog Inclusions</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {focusItems.map(item => (
                  <div class="group flex items-center gap-3 p-3 rounded-xl border border-light-darker bg-white hover:shadow-soft transition-all duration-200">
                    <div class="h-16 w-20 shrink-0 rounded-lg overflow-hidden border border-light-darker bg-light">
                      <img src={item.image} class="w-full h-full object-cover" alt={item.name} />
                    </div>
                    <div class="font-sans text-xs">
                      <h4 class="font-bold text-dark group-hover:text-primary transition-colors line-clamp-1">{item.name}</h4>
                      <span class="block text-[10px] text-dark-muted mt-0.5">MOQ: {item.moq}</span>
                      <a href={`/products/${item.slug}`} class="text-[10px] font-semibold text-primary hover:underline mt-1 block">
                        Specs & Quote &rarr;
                      </a>
                    </div>
                  </div>
                ))}
              </div>
            </div>

          </div>
        );
      })}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-16 border-t border-light-darker text-center space-y-6">
    <div class="mx-auto max-w-2xl px-6">
      <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Require Wholesale Contract Consultation?</h2>
      <p class="text-xs text-dark-muted font-sans max-w-md mx-auto leading-relaxed mt-2">
        Our logistics team helps configure customs clearance documentation and maritime transport manifests to optimize delivery costs.
      </p>
      <div class="pt-4">
        <a href="/contact" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all">
          Contact Logistics Manager
        </a>
      </div>
    </div>
  </section>
</Layout>
