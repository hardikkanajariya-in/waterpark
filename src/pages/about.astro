---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';

const seoTitle = `Corporate Supply & Logistics | ${config.brandName}`;
const seoDescription = `Learn about ${config.brandName}'s bulk procurement network, material quality testing, and worldwide logistics capabilities.`;
---

<Layout title={seoTitle} description={seoDescription}>
  
  <!-- Page Header -->
  <section class="bg-white py-20 border-b border-light-darker">
    <div class="mx-auto max-w-4xl px-6 md:px-8 space-y-6">
      <span class="text-[10px] font-black tracking-widest text-primary uppercase block">Quality Policy</span>
      <h1 class="text-4xl font-extrabold text-dark tracking-tight leading-[1.1] font-heading">
        Reliable B2B Aquatic Supply
      </h1>
      <p class="text-sm sm:text-base text-dark-muted font-sans leading-relaxed pt-2">
        {config.brandName} supplies commercial-grade aquatic equipment to swim schools, water parks, hotels, and retailers. We focus on structured logistics, standard materials compliance, and direct bulk supply efficiency.
      </p>
    </div>
  </section>

  <!-- Narrative Section -->
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Text -->
        <div class="lg:col-span-6 space-y-6 font-sans">
          <span class="text-[10px] font-black text-primary tracking-widest uppercase block">Supply Network</span>
          <h2 class="text-2xl font-extrabold text-dark font-heading leading-tight">Scale Meets Specification</h2>
          <p class="text-xs text-dark-muted leading-relaxed">
            By partnering with certified manufacturing facilities, we coordinate high-volume procurement schedules. We supply standard silicone swim caps, optical goggles, and commercial river tubes using durable, pool-tested materials.
          </p>
          <p class="text-xs text-dark-muted leading-relaxed">
            Every product batch is evaluated for seal retention, material fatigue, and chlorine exposure. This ensures that the equipment supplied meets standard industrial expectations in saline and chlorinated environments.
          </p>
        </div>
        <!-- Photo -->
        <div class="lg:col-span-6">
          <div class="overflow-hidden rounded-2xl border border-light-darker aspect-[4/3] bg-light">
            <img
              src="/images/gallery_factory.png"
              alt="Inside precision molding laboratory"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics Panel -->
  <section class="bg-dark text-white py-12">
    <div class="mx-auto max-w-7xl px-6 md:px-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-secondary font-heading">8 Divisions</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">Aquatic Catalogue</span>
      </div>
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-secondary font-heading">100% Bulk</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">MOQ Optimised</span>
      </div>
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-secondary font-heading">Nationwide</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">Logistic Network</span>
      </div>
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-secondary font-heading">24 Hours</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">Response Guarantee</span>
      </div>
    </div>
  </section>

  <!-- B2B Operations Capabilities -->
  <section class="py-16 bg-light border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl">
        <span class="text-[10px] font-black text-primary tracking-widest uppercase block mb-2">Our Capabilities</span>
        <h2 class="text-2xl font-extrabold tracking-tight text-dark font-heading">Service Commitments</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-xs font-sans">
        <div class="space-y-2">
          <h3 class="text-sm font-bold text-dark font-heading">Consolidated Logistics</h3>
          <p class="text-dark-muted leading-relaxed">
            We handle packing lists, bulk crating, and marine/air dispatch, delivering directly to resorts, academies, and warehouses.
          </p>
        </div>
        <div class="space-y-2">
          <h3 class="text-sm font-bold text-dark font-heading">Material Quality Standards</h3>
          <p class="text-dark-muted leading-relaxed">
            All polymers and silicone items leverage liquid injection molding and high-grade compound formulas to prevent tearing.
          </p>
        </div>
        <div class="space-y-2">
          <h3 class="text-sm font-bold text-dark font-heading">Custom Packaging</h3>
          <p class="text-dark-muted leading-relaxed">
            We assist with customized brand packaging, retail boxes, and printed instructions for institutional orders.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
