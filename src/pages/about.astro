---
import Layout from '../layouts/Layout.astro';
import applications from '../data/applications.json';

const seoTitle = "Corporate Ethos & Quality Infrastructure | Aquadura";
const seoDescription = "Learn about Aquadura's operational footprint, raw material safety regulations, ethical social audits, and international compliance frameworks including CE, BSCI, and ISO.";
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Section 1: Editorial Header -->
  <section class="bg-white py-24 border-b border-light-darker">
    <div class="mx-auto max-w-4xl px-6 md:px-8 space-y-6">
      <span class="text-[11px] font-bold tracking-[0.25em] text-primary uppercase block">Quality Policy</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-dark tracking-tight leading-[1.1] font-heading">
        Aquatic supply <br/>
        <span class="text-primary font-medium italic">without compromise.</span>
      </h1>
      <p class="text-lg text-dark-muted font-sans leading-relaxed pt-2">
        Aquadura supplies commercial-grade aquatic equipment to swim schools, theme parks, hotels, and sports clubs. By integrating design, material sourcing, and testing directly in our network, we guarantee structural-grade product durability.
      </p>
    </div>
  </section>

  <!-- Section 2: Narrative & Large Image (Apple/Muji Style) -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <!-- Text -->
        <div class="lg:col-span-6 space-y-6">
          <span class="text-xs font-bold text-primary tracking-widest uppercase">Factory Operations</span>
          <h2 class="text-3xl font-extrabold text-dark font-heading leading-tight">Scale Meets Specification</h2>
          <p class="text-sm text-dark-muted font-sans leading-relaxed">
            Operating a 15,000 square meter partner facility, we coordinate high-volume production schedules. Our processes utilize high-frequency welding for PVC slide tubes and precision liquid injection molding for hypoallergenic silicone seals.
          </p>
          <p class="text-sm text-dark-muted font-sans leading-relaxed">
            We avoid generic shortcuts. Every batch undergoes seal retention checks, chlorine aging exposure, and ultraviolet stress testing to confirm raw materials maintain elasticity and structural integrity in saline and chlorinated installations.
          </p>
        </div>
        <!-- Photo -->
        <div class="lg:col-span-6">
          <div class="overflow-hidden rounded-2xl bg-light border border-light-darker aspect-[4/3]">
            <img
              src="/images/gallery_factory.png"
              alt="Inside precision molding laboratory"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Stat Strip (Minimal typography) -->
  <section class="bg-dark text-white py-16">
    <div class="mx-auto max-w-7xl px-6 md:px-8 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div class="space-y-1">
        <span class="block text-4xl font-extrabold text-secondary tracking-tight font-heading">1.2M+</span>
        <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">Units Annual Output</span>
      </div>
      <div class="space-y-1">
        <span class="block text-4xl font-extrabold text-secondary tracking-tight font-heading">99.8%</span>
        <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">QA Pass Rate</span>
      </div>
      <div class="space-y-1">
        <span class="block text-4xl font-extrabold text-secondary tracking-tight font-heading">15,000m²</span>
        <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">Facility Footprint</span>
      </div>
      <div class="space-y-1">
        <span class="block text-4xl font-extrabold text-secondary tracking-tight font-heading">24 Hours</span>
        <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">Response Guarantee</span>
      </div>
    </div>
  </section>

  <!-- Section 4: Compliance Matrix -->
  <section class="py-20 lg:py-28 bg-light border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl">
        <span class="text-xs font-bold text-primary tracking-widest uppercase block mb-2">Quality Standards</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Certified Operations</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="space-y-3 font-sans">
          <span class="text-xs font-bold text-primary uppercase">Management Standard</span>
          <h3 class="text-base font-bold text-dark font-heading">ISO 9001:2015</h3>
          <p class="text-xs text-dark-muted leading-relaxed">
            Our Quality Management System oversees each logistics milestone—from inspection of raw polymers to the shipping manifests of finished goods.
          </p>
        </div>
        <div class="space-y-3 font-sans">
          <span class="text-xs font-bold text-primary uppercase">Compliance Audit</span>
          <h3 class="text-base font-bold text-dark font-heading">BSCI Social Audits</h3>
          <p class="text-xs text-dark-muted leading-relaxed">
            We require all primary factories to undergo annual Business Social Compliance Initiative (BSCI) audits to ensure safe workspace ethics and fair labor rates.
          </p>
        </div>
        <div class="space-y-3 font-sans">
          <span class="text-xs font-bold text-primary uppercase">Safety Standard</span>
          <h3 class="text-base font-bold text-dark font-heading">CE Declaration</h3>
          <p class="text-xs text-dark-muted leading-relaxed">
            All waterproof covers and commercial safety flotation vests conform with European Economic Area (CE) safety directives.
          </p>
        </div>
        <div class="space-y-3 font-sans">
          <span class="text-xs font-bold text-primary uppercase">Athletic Standard</span>
          <h3 class="text-base font-bold text-dark font-heading">FINA Design Rules</h3>
          <p class="text-xs text-dark-muted leading-relaxed">
            Our competition lane lines, starting blocks, and racing caps align with World Aquatics FINA regulations for water displacement.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Applications Overview -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl">
        <span class="text-xs font-bold text-primary tracking-widest uppercase block mb-2">B2B Sectors</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Tailored Solutions for Commercial Operations</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {applications.map((app) => (
          <div class="space-y-4 font-sans">
            <h3 class="text-lg font-bold text-dark font-heading">{app.name}</h3>
            <p class="text-xs text-dark-muted leading-relaxed">{app.description}</p>
            <a href={`/applications#${app.slug}`} class="inline-block text-xs font-bold text-primary hover:underline">
              Browse deployment cases &rarr;
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
