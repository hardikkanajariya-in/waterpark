---
import Layout from '../layouts/Layout.astro';
import Statistics from '../components/Statistics.astro';
import IndustriesServed from '../components/IndustriesServed.astro';

const seoTitle = "Corporate Profile & Manufacturing Facilities | Aquadura";
const seoDescription = "Learn about Aquadura's 15,000m² manufacturing capacity, raw material specifications, and quality certifications including ISO 9001, CE, BSCI, and FINA compliance.";
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Page Header -->
  <section class="bg-white py-16 border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="space-y-4 max-w-3xl">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
          <a href="/" class="hover:text-primary font-sans">Home</a>
          <span>/</span>
          <span class="text-primary font-sans">About Us</span>
        </nav>
        <h1 class="text-4xl font-extrabold tracking-tight text-dark sm:text-5xl font-heading">
          Corporate Profile
        </h1>
        <div class="h-1 w-20 bg-primary rounded-full mt-2"></div>
        <p class="text-lg text-dark-muted font-sans mt-4 leading-relaxed">
          Aquadura is a global industrial leader in commercial aquatic product manufacturing. We partner with water parks, hotels, distributors, and academies to supply high-durability gear at scale.
        </p>
      </div>
    </div>
  </section>

  <!-- Manufacturing Capabilities & Material Focus -->
  <section class="py-20 lg:py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-16">
      
      <!-- Philosophy / Overview -->
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16 lg:items-center">
        <div class="lg:col-span-6 space-y-6">
          <h2 class="text-xs font-bold uppercase tracking-widest text-primary font-heading">
            Our Blueprint
          </h2>
          <h3 class="text-3xl font-extrabold tracking-tight text-dark font-heading leading-tight">
            Engineered for Extreme Environments
          </h3>
          <p class="text-sm text-dark-muted leading-relaxed font-sans">
            Aquatic gear faces harsh conditions daily: intense UV rays, persistent chlorine concentrations, thermal changes, and high physical stress from guest rental usage. 
          </p>
          <p class="text-sm text-dark-muted leading-relaxed font-sans">
            To address these conditions, we invest in structural-grade materials and automated injection molding technology. Every batch is manufactured from non-toxic, hypoallergenic compounds designed to perform over seasons—not months.
          </p>
          
          <!-- Key details list -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
            <div class="flex items-start">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-primary/10 text-primary mr-3 text-xs font-bold font-heading">1</span>
              <div>
                <span class="block text-xs font-bold text-dark font-sans">Premium Raw Materials</span>
                <span class="block text-[11px] text-dark-muted font-sans mt-0.5">Food-grade silicone & optical-grade PC.</span>
              </div>
            </div>
            <div class="flex items-start">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded bg-primary/10 text-primary mr-3 text-xs font-bold font-heading">2</span>
              <div>
                <span class="block text-xs font-bold text-dark font-sans">High-Frequency Seam Welding</span>
                <span class="block text-[11px] text-dark-muted font-sans mt-0.5">Dual-layer reinforcement for slide rafts.</span>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-6">
          <div class="overflow-hidden rounded-2xl bg-light border border-light-darker shadow-soft">
            <img
              src="/images/gallery_factory.png"
              alt="Inside Aquadura precision molding facility"
              class="w-full h-[320px] object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Production Metrics -->
  <Statistics />

  <!-- Quality Assurance & Compliance Standards -->
  <section class="py-20 lg:py-24 bg-white border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-16">
      
      <div class="mx-auto max-w-3xl text-center space-y-4">
        <h2 class="text-xs font-bold uppercase tracking-widest text-primary">
          Compliance Matrix
        </h2>
        <h3 class="text-3xl font-extrabold tracking-tight text-dark font-heading">
          Certified Manufacturing Compliance
        </h3>
        <div class="h-1 w-16 bg-primary mx-auto rounded-full mt-4"></div>
      </div>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        
        <!-- ISO Card -->
        <div class="rounded-2xl border border-light-darker p-8 shadow-soft space-y-4">
          <div class="inline-flex rounded-lg bg-primary-light px-3 py-1 text-xs font-bold text-primary font-sans">
            QMS Standard
          </div>
          <h4 class="text-lg font-bold text-dark font-heading">ISO 9001:2015</h4>
          <p class="text-xs text-dark-muted leading-relaxed font-sans">
            Our Quality Management System governs each production phase—from raw compound sourcing to final tensile testing—ensuring batch consistency.
          </p>
        </div>

        <!-- CE Compliance -->
        <div class="rounded-2xl border border-light-darker p-8 shadow-soft space-y-4">
          <div class="inline-flex rounded-lg bg-primary-light px-3 py-1 text-xs font-bold text-primary font-sans">
            Safety Standard
          </div>
          <h4 class="text-lg font-bold text-dark font-heading">CE Compliant</h4>
          <p class="text-xs text-dark-muted leading-relaxed font-sans">
            Product lines carry complete CE marking, confirming strict compliance with European safety, health, and environmental protection requirements.
          </p>
        </div>

        <!-- BSCI Audited -->
        <div class="rounded-2xl border border-light-darker p-8 shadow-soft space-y-4">
          <div class="inline-flex rounded-lg bg-primary-light px-3 py-1 text-xs font-bold text-primary font-sans">
            Ethical Auditing
          </div>
          <h4 class="text-lg font-bold text-dark font-heading">BSCI Audited</h4>
          <p class="text-xs text-dark-muted leading-relaxed font-sans">
            We undergo annual Business Social Compliance Initiative (BSCI) audits to verify fair labor rates, workplace safety, and ethical factory conditions.
          </p>
        </div>

        <!-- FINA Approved -->
        <div class="rounded-2xl border border-light-darker p-8 shadow-soft space-y-4">
          <div class="inline-flex rounded-lg bg-primary-light px-3 py-1 text-xs font-bold text-primary font-sans">
            Sport Standard
          </div>
          <h4 class="text-lg font-bold text-dark font-heading">FINA Compliant</h4>
          <p class="text-xs text-dark-muted leading-relaxed font-sans">
            Our competition lane ropes, starting blocks, racing caps, and racing goggles satisfy FINA dimensional and hydrodynamic design guidelines.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- Industries Served Section -->
  <IndustriesServed />
</Layout>
