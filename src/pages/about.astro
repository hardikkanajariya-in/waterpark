---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';

const seoTitle = `About Our Store | ${config.brandName}`;
const seoDescription = `Learn about ${config.brandName}, India's premier online store for leakproof swimming goggles, silicone caps, and water park floats.`;
---

<Layout title={seoTitle} description={seoDescription}>
  
  <!-- Page Title and Breadcrumb (Clean & Standard Width) -->
  <div class="mx-auto max-w-7xl px-6 md:px-8 pt-8 pb-4 font-sans bg-white border-b border-light-darker">
    <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2 mb-2">
      <a href="/" class="hover:text-primary">Home</a>
      <span>/</span>
      <span class="text-primary">About Our Store</span>
    </nav>
    <h1 class="text-2xl font-bold tracking-tight text-dark font-heading">
      About Us
    </h1>
  </div>

  <!-- Narrative Section -->
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Text -->
        <div class="lg:col-span-6 space-y-6 font-sans">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Our Values</span>
          <h2 class="text-2xl font-extrabold text-dark font-heading leading-tight">Comfort Meets Performance</h2>
          <p class="text-xs text-dark-muted leading-relaxed font-medium">
            We believe that every swim should be comfortable and clear. That's why we curate only the best-performing equipment, from skin-safe silicone dome caps to optically corrective swim goggles and high-buoyancy training fins.
          </p>
          <p class="text-xs text-dark-muted leading-relaxed font-medium">
            Our water park float tubes are crafted with heavy-gauge, UV-stabilized PVC tarpaulin, built to provide hours of fun on slides and lazy rivers. We check every batch for seam strength and safety before sending them to your door.
          </p>
        </div>
        <!-- Photo -->
        <div class="lg:col-span-6">
          <div class="overflow-hidden rounded-2xl border border-light-darker aspect-[4/3] bg-light">
            <img
              src="/images/gallery_pool.png"
              alt="Poolside swim gear display"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Statistics Panel -->
  <section class="bg-dark text-white py-12">
    <div class="mx-auto max-w-7xl px-6 md:px-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-primary font-heading">8 Divisions</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">Aquatic Gear</span>
      </div>
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-primary font-heading">100% Premium</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">Quality Checked</span>
      </div>
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-primary font-heading">Pan-India</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">Home Delivery</span>
      </div>
      <div class="space-y-1">
        <span class="block text-3xl font-extrabold text-primary font-heading">24/7 Care</span>
        <span class="block text-[9px] font-bold text-slate-400 uppercase tracking-widest">Customer Support</span>
      </div>
    </div>
  </section>

  <!-- Service Commitments -->
  <section class="py-16 bg-light border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block mb-2">Our Guarantees</span>
        <h2 class="text-2xl font-extrabold tracking-tight text-dark font-heading">Our Promises to Swimmers</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-xs font-sans">
        <div class="space-y-2">
          <h3 class="text-sm font-bold text-dark font-heading">Direct Home Delivery</h3>
          <p class="text-dark-muted leading-relaxed font-medium">
            We dispatch your orders within 24 hours of purchase, using premium courier networks to deliver right to your doorstep across India.
          </p>
        </div>
        <div class="space-y-2">
          <h3 class="text-sm font-bold text-dark font-heading">Tested Pool Endurance</h3>
          <p class="text-dark-muted leading-relaxed font-medium">
            All our liquid silicone swim caps and gaskets feature highly stretchable formulas to prevent tearing, fading, or chlorine degradation.
          </p>
        </div>
        <div class="space-y-2">
          <h3 class="text-sm font-bold text-dark font-heading">Hassle-Free Exchanges</h3>
          <p class="text-dark-muted leading-relaxed font-medium">
            Bought the wrong goggle size or want to change your cap color? We provide easy exchanges within 14 days on all unused store purchases.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
