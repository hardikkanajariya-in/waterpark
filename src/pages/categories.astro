---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';

const seoTitle = "Product Divisions | Aquadura Commercial Aquatics";
const seoDescription = "Browse through Aquadura's 8 manufacturing categories, spanning commercial swimming goggles, custom silicone caps, waterproof phone cases, pool hardware, and water park structures.";

// Count products in each category for the category listing metadata
const getProductCount = (catSlug: string) => {
  return products.filter(p => p.category === catSlug).length;
};
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Page Header -->
  <section class="bg-white py-16 border-b border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="space-y-4 max-w-3xl">
        <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2">
          <a href="/" class="hover:text-primary">Home</a>
          <span>/</span>
          <span class="text-primary">Categories</span>
        </nav>
        <h1 class="text-4xl font-extrabold tracking-tight text-dark sm:text-5xl font-heading">
          Product Divisions
        </h1>
        <div class="h-1 w-20 bg-primary rounded-full mt-2"></div>
        <p class="text-lg text-dark-muted font-sans mt-4 leading-relaxed">
          We operate 8 advanced production divisions. Each is dedicated to specific aquatic components, ensuring specialized manufacturing expertise, raw material safety, and quality certifications.
        </p>
      </div>
    </div>
  </section>

  <!-- Detailed Categories List -->
  <section class="py-20 lg:py-24 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-16">
      {categories.map((cat, index) => {
        const prodCount = getProductCount(cat.slug);
        const isEven = index % 2 === 0;
        
        return (
          <div class={`grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center lg:gap-16 border-b border-light-darker/60 pb-16 last:border-0 last:pb-0`}>
            
            <!-- Category Image -->
            <div class={`lg:col-span-5 relative ${isEven ? 'lg:order-1' : 'lg:order-2'}`}>
              <div class="overflow-hidden rounded-2xl bg-white shadow-soft border border-light-darker">
                <img
                  src={cat.image}
                  alt={cat.name}
                  class="h-[300px] w-full object-cover sm:h-[350px] hover:scale-102 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="absolute -bottom-4 right-4 rounded-xl bg-white px-4 py-2 border border-light-darker shadow-soft font-sans text-xs font-bold text-dark">
                {prodCount} Commercial Products
              </div>
            </div>

            <!-- Category Description -->
            <div class={`lg:col-span-7 space-y-6 ${isEven ? 'lg:order-2' : 'lg:order-1'}`}>
              <div class="space-y-2">
                <span class="text-xs font-extrabold uppercase tracking-widest text-primary">Division 0{index + 1}</span>
                <h2 class="text-2xl font-bold tracking-tight text-dark sm:text-3xl font-heading">
                  {cat.name}
                </h2>
              </div>
              
              <p class="text-base text-dark-muted leading-relaxed font-sans">
                {cat.description}
              </p>
              
              <!-- Quick list of featured products in this category -->
              <div class="space-y-3 pt-2">
                <h4 class="text-xs font-bold uppercase tracking-wider text-dark">Featured Products in this Division</h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {products
                    .filter(p => p.category === cat.slug)
                    .slice(0, 4)
                    .map(p => (
                      <a 
                        href={`/products/${p.slug}`}
                        class="flex items-center text-sm font-semibold text-dark-muted hover:text-primary font-sans group"
                      >
                        <svg class="h-4 w-4 text-primary/70 shrink-0 mr-2 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                        {p.name}
                      </a>
                    ))}
                </div>
              </div>

              <!-- Button CTA -->
              <div class="pt-6">
                <a
                  href={`/products?category=${cat.slug}`}
                  class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-soft hover:bg-primary-dark hover:shadow-soft-lg transition-all duration-200"
                >
                  View Catalog
                  <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              </div>
            </div>

          </div>
        );
      })}
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-white py-16 border-t border-light-darker">
    <div class="mx-auto max-w-5xl px-6 text-center space-y-6 md:px-8">
      <h2 class="text-2xl font-extrabold tracking-tight text-dark sm:text-3xl font-heading">
        Need a Specialized Custom Molding Solution?
      </h2>
      <p class="text-sm text-dark-muted font-sans max-w-xl mx-auto leading-relaxed">
        If our standard 8 categories do not match your exact blueprint, our in-house engineering team can develop custom tooling and molds.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3.5 text-sm font-semibold text-white shadow-soft hover:bg-primary-dark transition-all duration-150"
      >
        Inquire About Custom Tooling
      </a>
    </div>
  </section>
</Layout>
