---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';
import config from '../data/config.json';
import gallery from '../data/gallery.json';

const seoTitle = `${config.brandName} | Premium B2B Aquatic Supply & Wholesale Catalogue`;
const seoDescription = `${config.brandTagline}. Procure professional goggles, custom silicone caps, water park slide tubes, and pool hardware direct from distribution.`;

// Featured Products
const primaryFeatured = products.find(p => p.slug === "apex-racing-goggles") || products[0];
const secondaryFeatured = [
  products.find(p => p.slug === "floating-dry-bag-phone-pouch"),
  products.find(p => p.slug === "pro-silicone-racing-cap")
].filter(p => p !== undefined) as typeof products;

// B2B Packages / Bundle Deals
const bulkBundles = [
  {
    id: "waterpark-bundle",
    name: "Water Park Operations Bundle",
    badge: "Most Requested",
    description: "Complete aquatic facility package designed for immediate commercial water slide and lazy river deployment.",
    items: [
      "100x Commercial Slide Tubes (Single & Double)",
      "200x USCG-Compliant Safety Life Vests",
      "500x RFID locker wristbands"
    ],
    slugs: ["single-rider-commercial-water-tube", "commercial-life-vest-adult", "rfid-locker-key-wristband"],
    estMoq: "1 Pack"
  },
  {
    id: "academy-bundle",
    name: "Elite Swim Squad Set",
    badge: "Academy Standard",
    description: "Equip competitive training academies and school teams with customized gear and branding.",
    items: [
      "250x Custom Team Silicone Caps",
      "100x Apex Pro Racing Goggles",
      "50x High-density EVA Kickboards"
    ],
    slugs: ["custom-branded-team-cap", "apex-racing-goggles", "contour-pull-buoy"],
    estMoq: "1 Pack"
  },
  {
    id: "resort-bundle",
    name: "Resort Pool Hardware Package",
    badge: "Facility Supply",
    description: "Heavy-duty pool fittings and competitive hardware for premium hotels, municipal pools, and resorts.",
    items: [
      "6x Competition Starting Blocks",
      "6x Stainless Steel Pool Ladders",
      "4x Anti-Wave Racing Lane Ropes"
    ],
    slugs: ["competition-starting-block", "stainless-steel-pool-ladder", "anti-wave-racing-lane-rope"],
    estMoq: "1 Pack"
  }
];

// Applications
const applicationsList = [
  {
    title: "Water Parks & Slides",
    desc: "Heavy-gauge K80 PVC slide rafts, commercial life vests, and waterproof device cases built to withstand constant sun exposure, high friction, and heavy chlorine.",
    image: "/images/gallery_park.png"
  },
  {
    title: "Swimming Academies",
    desc: "FINA-compliant racing goggles, variable-thickness 3D silicone dome caps, pull buoys, and resistance training kits built for institutional durability.",
    image: "/images/gallery_pool.png"
  },
  {
    title: "Hotels & Resorts",
    desc: "Stainless steel deck equipment, anti-wave swimming lane ropes, and soft liquid silicone leisure goggles that don't leave pressure marks on guests.",
    image: "/images/gallery_quality.png"
  },
  {
    title: "Retail & Dealers",
    desc: "Individually packaged prescription swim goggles, heavy-duty 500D PVC dry bags, and quick-dry microfiber accessories tailored for commercial retail shelves.",
    image: "/images/gallery_factory.png"
  }
];

// Latest Products Carousel
const latestProducts = products.filter(p => 
  ["lazy-river-luxury-lounger", "roll-top-waterproof-dry-bag", "swim-resistance-training-belt", "optical-corrective-goggles"].includes(p.slug)
);
---

<Layout title={seoTitle} description={seoDescription}>

  <!-- 1. IMMERSIVE HERO SECTION (90vh) -->
  <section class="relative min-h-[85vh] flex items-center bg-slate-950 text-white overflow-hidden">
    <!-- Full-bleed background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="/images/hero_catalog.png"
        alt="Premium aquatics equipment supply catalog"
        class="w-full h-full object-cover select-none object-center opacity-30"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/70 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 mx-auto max-w-7xl px-6 md:px-8 py-20 w-full">
      <div class="max-w-3xl space-y-6">
        <span class="inline-flex items-center rounded-full bg-primary/20 border border-primary/40 px-3.5 py-1 text-xs font-bold text-accent uppercase tracking-widest">
          Dealers & Distributors Division
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black tracking-tight leading-[1.05] font-heading text-white">
          {config.heroTitle}
        </h1>
        <p class="text-sm sm:text-lg text-slate-300 font-medium max-w-xl leading-relaxed">
          {config.heroSubtitle}
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a
            href="#categories"
            class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-xs font-bold text-white shadow-lg hover:bg-primary-dark transition-all duration-200"
          >
            Explore Divisions &rarr;
          </a>
          <button
            type="button"
            class="open-inquiry-direct-btn inline-flex items-center justify-center rounded-full bg-slate-800 border border-slate-700 px-8 py-4 text-xs font-bold text-slate-200 hover:bg-slate-700 hover:text-white transition-all duration-200"
          >
            Request B2B Quote
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. PROMINENT CENTRAL SEARCH BAR -->
  <section class="relative z-20 -mt-10 max-w-4xl mx-auto px-6">
    <div class="bg-white rounded-3xl border border-light-darker p-5 sm:p-7 shadow-2xl space-y-4">
      <h2 class="text-xs font-black text-dark uppercase tracking-wider text-center font-heading">
        Search our B2B Product Database
      </h2>
      <form action="/products" method="GET" class="relative flex flex-col sm:flex-row gap-3">
        <div class="relative flex-grow">
          <input
            type="text"
            name="search"
            placeholder={config.searchPlaceholder}
            class="w-full rounded-2xl border border-light-darker bg-light px-5 py-4 pl-12 text-sm text-dark placeholder:text-dark-muted/50 focus:bg-white focus:border-primary focus:outline-none transition-all"
            required
          />
          <svg class="absolute left-4 top-4.5 h-5 w-5 text-dark-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <button
          type="submit"
          class="rounded-2xl bg-dark text-white px-8 py-4 text-xs font-bold hover:bg-primary transition-all flex items-center justify-center gap-1.5"
        >
          🔍 Search Database
        </button>
      </form>
      <!-- Quick Categories -->
      <div class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1.5 text-[11px] text-dark-muted font-medium">
        <span>Suggested:</span>
        <a href="/products?category=swimming-goggles" class="hover:text-primary underline">Swimming Goggles</a>
        <span>&bull;</span>
        <a href="/products?category=swimming-caps" class="hover:text-primary underline">Custom Caps</a>
        <span>&bull;</span>
        <a href="/products?category=pool-equipment" class="hover:text-primary underline">Pool Hardwares</a>
        <span>&bull;</span>
        <a href="/products?category=water-park-tubes" class="hover:text-primary underline">River Tubes</a>
      </div>
    </div>
  </section>

  <!-- 3. PREMIUM CATEGORY GRID (8 TILES WITH RHYTHM) -->
  <section id="categories" class="py-24 bg-light transition-all">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-black text-primary tracking-widest uppercase block">Catalog Divisions</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Shop by Division</h2>
        <p class="text-xs text-dark-muted font-medium">Quick-route into specialized wholesale categories of aquatic accessories.</p>
      </div>

      <!-- 8-Tile Editorial Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-6">
        {categories.map((cat, idx) => {
          // Visual Rhythm: assign different width spans to make the grid asymmetrical
          let gridClass = "lg:col-span-3"; // Default square/portrait
          if (idx === 0) gridClass = "lg:col-span-6"; // First item (Goggles) is wide
          if (idx === 4) gridClass = "lg:col-span-6"; // Fifth item (Pool Equipment) is wide
          if (idx === 7) gridClass = "lg:col-span-6"; // Last item (Tubes) is wide

          return (
            <a
              href={`/products?category=${cat.slug}`}
              class={`group block relative overflow-hidden rounded-2xl bg-white border border-light-darker aspect-[4/3] sm:aspect-auto sm:h-72 lg:h-80 shadow-soft hover:shadow-soft-lg transition-all duration-300 ${gridClass}`}
            >
              <!-- Background Image -->
              <div class="absolute inset-0 bg-light-darker">
                <img
                  src={cat.image}
                  alt={cat.name}
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <!-- Dark gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-dark/70 via-dark/20 to-transparent z-10"></div>
              
              <!-- Content -->
              <div class="absolute bottom-6 left-6 right-6 z-20 space-y-1 text-white font-sans">
                <h3 class="text-lg font-bold font-heading leading-tight">{cat.name}</h3>
                <p class="text-[11px] text-slate-300 leading-normal line-clamp-2 max-w-md group-hover:text-white transition-colors">
                  {cat.description}
                </p>
                <div class="pt-2">
                  <span class="inline-flex items-center text-[10px] font-bold tracking-wider uppercase text-accent group-hover:underline">
                    View Catalogue &rarr;
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 4. EDITORIAL FEATURED PRODUCT (Asymmetrical Composition) -->
  <section class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 border-b border-light-darker pb-6">
        <div class="space-y-2">
          <span class="text-[10px] font-black text-primary tracking-widest uppercase block font-heading">Featured Showcase</span>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Top Performing Equipment</h2>
        </div>
        <a href="/products" class="text-xs font-bold text-primary hover:underline">
          View Complete Catalog index &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- Left 60%: Large Primary Product Highlight -->
        <div class="lg:col-span-7 bg-light rounded-3xl border border-light-darker p-6 sm:p-8 space-y-6">
          <div class="relative overflow-hidden aspect-[4/3] rounded-2xl bg-white border border-light-darker">
            <img
              src={primaryFeatured.image}
              alt={primaryFeatured.name}
              class="w-full h-full object-cover hover:scale-102 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          
          <div class="space-y-4">
            <div class="flex items-center justify-between text-xs">
              <span class="text-xs font-extrabold text-primary uppercase font-sans">Apex Racing series</span>
              <span class="font-bold text-dark bg-white border border-light-darker px-2 py-0.5 rounded text-[11px]">MOQ: {primaryFeatured.moq}</span>
            </div>
            
            <h3 class="text-2xl font-extrabold text-dark font-heading leading-tight">
              {primaryFeatured.name}
            </h3>
            
            <p class="text-xs text-dark-muted font-sans leading-relaxed">
              {primaryFeatured.description}
            </p>

            <!-- Specs Grid -->
            <div class="grid grid-cols-2 gap-4 text-[11px] text-dark-muted font-sans border-t border-light-darker pt-4">
              {Object.entries(primaryFeatured.specifications).slice(0, 4).map(([k, v]) => (
                <div>
                  <span class="block font-bold text-dark">{k}</span>
                  <span>{v}</span>
                </div>
              ))}
            </div>

            <!-- B2B Direct Quote Add -->
            <div class="flex items-center gap-3 pt-4">
              <div class="flex flex-col gap-1 text-[10px]">
                <label class="font-bold uppercase tracking-wider text-dark-muted">Quantity</label>
                <input
                  type="number"
                  min="200"
                  value="200"
                  data-slug={primaryFeatured.slug}
                  class="qty-input-field w-20 rounded-lg border border-light-darker bg-white px-2.5 py-2 font-bold text-dark text-xs focus:outline-none"
                />
              </div>
              <button
                type="button"
                data-add-to-quote
                data-slug={primaryFeatured.slug}
                data-name={primaryFeatured.name}
                data-image={primaryFeatured.image}
                data-moq={primaryFeatured.moq}
                data-numeric-moq="200"
                class="flex-grow inline-flex items-center justify-center rounded-lg bg-primary py-3 text-xs font-bold text-white shadow hover:bg-primary-dark transition-all"
              >
                Add to Quote Sheet
              </button>
            </div>
          </div>
        </div>

        <!-- Right 40%: Secondary Stacked Items -->
        <div class="lg:col-span-5 space-y-6">
          {secondaryFeatured.map((prod) => {
            const numericMoq = parseInt(prod.moq.replace(/[^0-9]/g, '')) || 100;
            return (
              <div class="bg-white rounded-3xl border border-light-darker p-6 flex flex-col justify-between hover:border-slate-300 transition-colors h-[270px] sm:h-[310px] lg:h-[285px]">
                <div class="flex gap-4">
                  <!-- Photo -->
                  <div class="h-24 w-28 shrink-0 rounded-2xl overflow-hidden border border-light-darker bg-light">
                    <img src={prod.image} alt={prod.name} class="h-full w-full object-cover" />
                  </div>
                  <!-- Content -->
                  <div class="space-y-1">
                    <span class="text-[9px] font-bold text-primary uppercase font-sans">Institutional Selection</span>
                    <h4 class="text-base font-bold text-dark font-heading leading-snug line-clamp-1">{prod.name}</h4>
                    <p class="text-[11px] text-dark-muted font-sans leading-normal line-clamp-3">{prod.description}</p>
                  </div>
                </div>

                <!-- Footer row -->
                <div class="border-t border-light-darker pt-4 flex items-center justify-between">
                  <div class="text-[11px]">
                    <span class="block text-[8px] font-bold text-dark-muted uppercase">Wholesale MOQ</span>
                    <span class="font-extrabold text-dark">{prod.moq}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <a href={`/products/${prod.slug}`} class="text-xs font-bold text-primary hover:underline pr-2">Specs &rarr;</a>
                    <button
                      type="button"
                      data-add-to-quote
                      data-slug={prod.slug}
                      data-name={prod.name}
                      data-image={prod.image}
                      data-moq={prod.moq}
                      data-numeric-moq={numericMoq.toString()}
                      class="inline-flex items-center justify-center rounded-lg bg-dark px-4 py-2.5 text-[10px] font-bold text-white hover:bg-primary transition-all"
                    >
                      + Add Quote
                    </button>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>

  <!-- 5. PRE-CONFIGURED INSTITUTIONAL BUNDLES -->
  <section class="py-24 bg-light border-y border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-black text-primary tracking-widest uppercase block">Bulk Solutions</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Pre-configured B2B Packages</h2>
        <p class="text-xs text-dark-muted font-medium">Consolidated catalog packages designed for rapid facility planning and deployment.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {bulkBundles.map(bundle => (
          <div class="group flex flex-col justify-between p-6 sm:p-8 rounded-2xl border border-light-darker bg-white shadow-soft hover:shadow-soft-lg transition-all duration-300">
            <div class="space-y-5">
              <div class="flex items-center justify-between">
                <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-[9px] font-bold text-primary uppercase tracking-wider font-sans">
                  {bundle.badge}
                </span>
                <span class="text-[10px] font-bold text-dark-muted uppercase font-sans">Min Qty: {bundle.estMoq}</span>
              </div>
              
              <h3 class="text-lg font-bold text-dark font-heading group-hover:text-primary transition-colors">
                {bundle.name}
              </h3>
              
              <p class="text-xs text-dark-muted leading-relaxed font-sans">
                {bundle.description}
              </p>

              <!-- Included items list -->
              <div class="bg-light rounded-xl p-4 border border-light-darker/60 space-y-2">
                <span class="block text-[9px] font-bold text-dark uppercase tracking-wider">Package Contents:</span>
                <ul class="text-[11px] text-dark font-medium space-y-1.5 font-sans">
                  {bundle.items.map(item => (
                    <li class="flex items-start gap-1.5">
                      <span class="text-primary mt-0.5">&bull;</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="pt-6 mt-6 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
              <a href="/products" class="font-bold text-dark-muted hover:text-dark">Explore specs</a>
              
              <!-- Direct action button that adds each slug to quote -->
              <button
                type="button"
                class="add-bundle-btn font-bold text-primary hover:underline flex items-center gap-1"
                data-bundle-slugs={bundle.slugs.join(',')}
                data-bundle-name={bundle.name}
              >
                Inquire Pack &rarr;
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. SHOP BY APPLICATION (BUYER SECTORS) -->
  <section class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-black text-primary tracking-widest uppercase block">Sector Solutions</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Shop by Application</h2>
        <p class="text-xs text-dark-muted font-medium">Engineered configurations matching specific industrial requirements.</p>
      </div>

      <!-- Sectors Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {applicationsList.map(app => (
          <div class="group flex flex-col rounded-3xl border border-light-darker overflow-hidden hover:border-slate-300 transition-all bg-light">
            <div class="h-44 overflow-hidden relative">
              <img src={app.image} alt={app.title} class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" />
              <div class="absolute inset-0 bg-dark/20"></div>
            </div>
            <div class="p-6 flex-grow flex flex-col justify-between space-y-4">
              <div class="space-y-2">
                <h3 class="text-base font-extrabold text-dark font-heading leading-tight">{app.title}</h3>
                <p class="text-xs text-dark-muted leading-relaxed font-sans">{app.desc}</p>
              </div>
              <a href="/products" class="text-xs font-bold text-primary hover:underline mt-auto block font-sans">
                Browse Sector Inventory &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. WHY BULK BUYERS CHOOSE US (B2B VALUE PROPS) -->
  <section class="py-20 bg-slate-950 text-white relative overflow-hidden">
    <!-- Fine-grid background overlay -->
    <div class="absolute inset-0 opacity-5 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:24px_24px]"></div>

    <div class="mx-auto max-w-7xl px-6 md:px-8 relative z-10 space-y-12">
      <div class="max-w-2xl space-y-2">
        <span class="text-[10px] font-black text-accent tracking-widest uppercase block">Procurement Security</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-white font-heading">Why Bulk Buyers Partner With Us</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6">
        {config.b2bReassurances.map(val => (
          <div class="p-5 rounded-2xl border border-slate-800 bg-slate-900/60 backdrop-blur-sm space-y-2.5">
            <div class="h-8 w-8 rounded-lg bg-primary/20 border border-primary/40 flex items-center justify-center text-accent text-sm font-black">
              &bull;
            </div>
            <h3 class="text-sm font-bold text-white font-heading leading-tight">{val.title}</h3>
            <p class="text-[11px] text-slate-400 leading-normal font-sans">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. LATEST PRODUCTS (HORIZONTAL CAROUSEL) -->
  <section class="py-24 bg-light border-y border-light-darker overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-8">
      <div class="flex items-end justify-between">
        <div class="space-y-2">
          <span class="text-[10px] font-black text-primary tracking-widest uppercase block">Recently Catalogued</span>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">New Arrivals</h2>
        </div>
        <!-- Scroll navigation buttons -->
        <div class="flex gap-2">
          <button id="carousel-prev-btn" class="h-9 w-9 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-sm transition-all focus:outline-none">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="carousel-next-btn" class="h-9 w-9 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-sm transition-all focus:outline-none">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Carousel Container -->
      <div
        id="new-arrivals-carousel"
        class="flex gap-6 overflow-x-auto pb-4 scroll-smooth scrollbar-none snap-x snap-mandatory"
      >
        {latestProducts.map((product) => {
          const numericMoq = parseInt(product.moq.replace(/[^0-9]/g, '')) || 100;
          return (
            <div class="snap-start shrink-0 w-[280px] sm:w-[320px] bg-white border border-light-darker rounded-2xl p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300 flex flex-col justify-between">
              <div class="space-y-4">
                <div class="relative overflow-hidden aspect-[4/3] bg-light rounded-xl border border-light-darker">
                  <img
                    src={product.image}
                    alt={product.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
