---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';
import config from '../data/config.json';

const seoTitle = `${config.brandName} | Premium Swimming Equipment & Aquatic Gear`;
const seoDescription = `${config.brandTagline}. Shop professional goggles, custom silicone caps, water park rafts, and pool accessories.`;

// Get retail prices for featured items
const primaryFeatured = products.find(p => p.slug === "apex-racing-goggles") || products[0];
const secondaryFeatured = [
  products.find(p => p.slug === "floating-dry-bag-phone-pouch"),
  products.find(p => p.slug === "pro-silicone-racing-cap")
].filter(p => p !== undefined) as typeof products;

// B2C Swim Packs / Bundle Deals
const retailBundles = [
  {
    id: "recreation-pack",
    name: "Ultimate Snorkel & Swim Pack",
    badge: "Best Seller",
    price: 3499,
    description: "Equip yourself with elite training essentials. Features a complete set optimized for pool training.",
    items: [
      "1x Apex Pro Racing Goggles",
      "1x Classic Silicone Dome Cap",
      "1x Heavy-Duty nose clip & earplug set"
    ],
    slugs: ["apex-racing-goggles", "pro-silicone-racing-cap", "swim-resistance-training-belt"]
  },
  {
    id: "water-slide-set",
    name: "Water Park Float Set",
    badge: "Leisure Standard",
    price: 7999,
    description: "Get ready for the summer season with commercial-grade tubing and float safety equipment.",
    items: [
      "1x Single Rider Commercial Slide Tube",
      "1x USCG-Compliant Safety Life Vest"
    ],
    slugs: ["single-rider-commercial-water-tube", "commercial-life-vest-adult"]
  },
  {
    id: "squad-training-set",
    name: "Complete Pool Training Set",
    badge: "Training Essential",
    price: 5499,
    description: "Perfect package for competitive training, lap swimmers, and club squad members.",
    items: [
      "1x Hydrodynamic Training Swim Fins",
      "1x Ergonomic Contour Pull Buoy",
      "1x High-density EVA Kickboard"
    ],
    slugs: ["hydrodynamic-swim-fins", "contour-pull-buoy"]
  }
];

// Applications
const applicationsList = [
  {
    title: "Water Parks & Slides",
    desc: "Heavy-gauge slide rafts, commercial life vests, and waterproof device cases built to withstand constant sun exposure and heavy chlorine.",
    image: "/images/gallery_park.png"
  },
  {
    title: "Swimming Academies",
    desc: "Racing goggles, variable-thickness 3D silicone caps, pull buoys, and resistance training kits built for institutional durability.",
    image: "/images/gallery_pool.png"
  },
  {
    title: "Hotels & Resorts",
    desc: "Stainless steel deck ladders, anti-wave swimming lane ropes, and soft liquid silicone leisure goggles that don't leave pressure marks.",
    image: "/images/gallery_quality.png"
  },
  {
    title: "Retail & Leisure",
    desc: "Individually packaged prescription swim goggles, heavy-duty PVC dry bags, and quick-dry microfiber accessories tailored for active swimmers.",
    image: "/images/gallery_factory.png"
  }
];

// Latest Products
const latestProducts = products.filter(p => 
  ["lazy-river-luxury-lounger", "roll-top-waterproof-dry-bag", "swim-resistance-training-belt", "optical-corrective-goggles"].includes(p.slug)
);
---

<Layout title={seoTitle} description={seoDescription}>

  <!-- 1. HERO SECTION (ONLY CLICKABLE IMAGES WITH DOTTED INDICATORS BELOW) -->
  <section class="mx-auto max-w-7xl px-6 md:px-8 pt-6">
    <div id="hero-slider" class="relative overflow-hidden rounded-3xl h-[280px] sm:h-[380px] lg:h-[480px] bg-slate-100 shadow-soft">
      
      <!-- Slides Wrapper -->
      <div id="hero-slides-wrapper" class="flex h-full transition-transform duration-500 ease-out" style="transform: translateX(0%);">
        
        <!-- Slide 1 -->
        <a href="/products" class="w-full h-full shrink-0 relative block">
          <img
            src="/images/hero_catalog.png"
            alt="Elite Swimming Equipment"
            class="w-full h-full object-cover select-none object-center opacity-100"
            loading="eager"
          />
        </a>

        <!-- Slide 2 -->
        <a href="/products?category=swimming-goggles" class="w-full h-full shrink-0 relative block">
          <img
            src="/images/gallery_pool.png"
            alt="Premium Racing Goggles"
            class="w-full h-full object-cover select-none object-center opacity-100"
            loading="lazy"
          />
        </a>

        <!-- Slide 3 -->
        <a href="/products?category=water-park-tubes" class="w-full h-full shrink-0 relative block">
          <img
            src="/images/gallery_park.png"
            alt="Water Park Slide Tubes"
            class="w-full h-full object-cover select-none object-center opacity-100"
            loading="lazy"
          />
        </a>

      </div>
    </div>

    <!-- Dotted Indicators Below Banner -->
    <div class="flex justify-center gap-2.5 mt-4">
      <button class="hero-dot-btn h-2.5 w-2.5 rounded-full bg-slate-300 hover:bg-primary transition-all focus:outline-none" data-slide="0" aria-label="Go to slide 1"></button>
      <button class="hero-dot-btn h-2.5 w-2.5 rounded-full bg-slate-200 hover:bg-primary transition-all focus:outline-none" data-slide="1" aria-label="Go to slide 2"></button>
      <button class="hero-dot-btn h-2.5 w-2.5 rounded-full bg-slate-200 hover:bg-primary transition-all focus:outline-none" data-slide="2" aria-label="Go to slide 3"></button>
    </div>
  </section>

  <!-- 2. PROMINENT CENTRAL SEARCH BAR -->
  <section class="relative z-20 -mt-8 max-w-4xl mx-auto px-6">
    <div class="bg-white rounded-2xl border border-light-darker p-5 shadow-xl space-y-3">
      <h2 class="text-xs font-bold text-dark uppercase tracking-wider text-center font-heading">
        Search Goggles, Caps, Accessories & More
      </h2>
      <form action="/products" method="GET" class="relative flex flex-col sm:flex-row gap-3">
        <div class="relative flex-grow">
          <input
            type="text"
            name="search"
            placeholder={config.searchPlaceholder}
            class="w-full rounded-xl border border-light-darker bg-light px-4 py-3 pl-10 text-xs text-dark placeholder:text-dark-muted/50 focus:bg-white focus:border-primary focus:outline-none transition-all font-medium"
            required
          />
          <svg class="absolute left-3.5 top-3.5 h-4.5 w-4.5 text-dark-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <button
          type="submit"
          class="rounded-xl bg-dark text-white px-8 py-3.5 text-xs font-bold hover:bg-primary transition-all flex items-center justify-center font-sans focus:outline-none"
        >
          Search Store
        </button>
      </form>
    </div>
  </section>

  <!-- 3. PREMIUM CATEGORY GRID -->
  <section id="categories" class="py-20 bg-light mt-12 border-t border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-10">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Catalog Divisions</span>
        <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Shop by Category</h2>
        <p class="text-xs text-dark-muted font-medium">Quick-route into specialized categories of premium aquatic accessories.</p>
      </div>

      <!-- 8-Tile Editorial Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-5">
        {categories.map((cat, idx) => {
          let gridClass = "lg:col-span-3";
          if (idx === 0) gridClass = "lg:col-span-6";
          if (idx === 4) gridClass = "lg:col-span-6";
          if (idx === 7) gridClass = "lg:col-span-6";

          return (
            <a
              href={`/products?category=${cat.slug}`}
              class={`group block relative overflow-hidden rounded-2xl bg-white border border-light-darker aspect-[4/3] sm:aspect-auto sm:h-64 lg:h-72 shadow-soft hover:shadow-soft-lg transition-all duration-300 ${gridClass}`}
            >
              <!-- Background Image -->
              <div class="absolute inset-0 bg-light-darker">
                <img
                  src={cat.image}
                  alt={cat.name}
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-dark/10 to-transparent z-10"></div>
              
              <!-- Content -->
              <div class="absolute bottom-5 left-5 right-5 z-20 space-y-1 text-white font-sans">
                <h3 class="text-base font-bold font-heading leading-tight">{cat.name}</h3>
                <p class="text-[11px] text-slate-200 leading-normal line-clamp-2 max-w-md">
                  {cat.description}
                </p>
                <div class="pt-1.5">
                  <span class="inline-flex items-center text-[9px] font-bold tracking-wider uppercase text-accent group-hover:underline">
                    Shop Collection &rarr;
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 4. EDITORIAL FEATURED PRODUCT (Asymmetrical Composition) -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-10">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 border-b border-light-darker pb-5">
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block font-heading">Featured Product</span>
          <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Direct Customer Highlights</h2>
        </div>
        <a href="/products" class="text-xs font-bold text-primary hover:underline">
          View All Products &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        
        <!-- Left 60%: Large Primary Product Highlight -->
        <div class="lg:col-span-7 bg-light rounded-2xl border border-light-darker p-6 space-y-6">
          <div class="relative overflow-hidden aspect-[4/3] rounded-xl bg-white border border-light-darker">
            <img
              src={primaryFeatured.image}
              alt={primaryFeatured.name}
              class="w-full h-full object-cover hover:scale-102 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          
          <div class="space-y-4">
            <div class="flex items-center justify-between text-xs">
              <span class="text-xs font-bold text-primary uppercase font-sans">Premium Goggles</span>
              <span class="font-bold text-primary text-sm font-sans">₹{primaryFeatured.price.toFixed(2)}</span>
            </div>
            
            <h3 class="text-xl font-bold text-dark font-heading leading-tight">
              {primaryFeatured.name}
            </h3>
            
            <p class="text-xs text-dark-muted font-sans leading-relaxed">
              {primaryFeatured.description}
            </p>

            <!-- Specs Grid -->
            <div class="grid grid-cols-2 gap-4 text-[11px] text-dark-muted font-sans border-t border-light-darker pt-4">
              {Object.entries(primaryFeatured.specifications).slice(0, 4).map(([k, v]) => (
                <div>
                  <span class="block font-semibold text-dark">{k}</span>
                  <span>{v}</span>
                </div>
              ))}
            </div>

            <!-- Add to Cart Widget -->
            <div class="flex items-center gap-3 pt-3">
              <div class="flex flex-col gap-1 text-[9px]">
                <label class="font-bold uppercase tracking-wider text-dark-muted">Qty</label>
                <input
                  type="number"
                  min="1"
                  value="1"
                  data-slug={primaryFeatured.slug}
                  class="qty-input-field w-14 rounded-lg border border-light-darker bg-white px-2.5 py-2 font-bold text-dark text-xs focus:outline-none"
                />
              </div>
              <button
                type="button"
                data-add-to-cart
                data-slug={primaryFeatured.slug}
                data-name={primaryFeatured.name}
                data-image={primaryFeatured.image}
                data-price={primaryFeatured.price.toString()}
                class="flex-grow inline-flex items-center justify-center rounded-lg bg-primary py-3 text-xs font-bold text-white shadow hover:bg-primary-dark transition-all focus:outline-none"
              >
                Add to Cart
              </button>
            </div>
          </div>
        </div>

        <!-- Right 40%: Secondary Stacked Items -->
        <div class="lg:col-span-5 space-y-6">
          {secondaryFeatured.map((prod) => {
            return (
              <div class="bg-white rounded-2xl border border-light-darker p-5 flex flex-col justify-between hover:border-slate-300 transition-colors h-[250px] sm:h-[280px] lg:h-[255px]">
                <div class="flex gap-4">
                  <!-- Photo -->
                  <div class="h-20 w-24 shrink-0 rounded-xl overflow-hidden border border-light-darker bg-light">
                    <img src={prod.image} alt={prod.name} class="h-full w-full object-cover" />
                  </div>
                  <!-- Content -->
                  <div class="space-y-1">
                    <span class="text-[9px] font-bold text-primary uppercase font-sans">Leisure Gear</span>
                    <h4 class="text-sm font-bold text-dark font-heading leading-snug line-clamp-1">{prod.name}</h4>
                    <p class="text-[11px] text-dark-muted font-sans leading-normal line-clamp-3">{prod.description}</p>
                  </div>
                </div>

                <!-- Footer row -->
                <div class="border-t border-light-darker pt-3 flex items-center justify-between">
                  <div class="text-[11px]">
                    <span class="block text-[8px] font-bold text-dark-muted uppercase">Retail Price</span>
                    <span class="font-bold text-primary">₹{prod.price.toFixed(2)}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <a href={`/products/${prod.slug}`} class="text-xs font-semibold text-primary hover:underline pr-1">Details</a>
                    <button
                      type="button"
                      data-add-to-cart
                      data-slug={prod.slug}
                      data-name={prod.name}
                      data-image={prod.image}
                      data-price={prod.price.toString()}
                      class="inline-flex items-center justify-center rounded-lg bg-dark px-4 py-2.5 text-[10px] font-bold text-white hover:bg-primary transition-all focus:outline-none"
                    >
                      + Add to Cart
                    </button>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>

  <!-- 5. CURATED SWIM PACKS -->
  <section class="py-20 bg-light border-y border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-10">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Swim Packs</span>
        <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Popular Swim Bundles</h2>
        <p class="text-xs text-dark-muted font-medium">Consolidated product kits curated for immediate swimming routine deployment.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {retailBundles.map(bundle => (
          <div class="group flex flex-col justify-between p-6 rounded-2xl border border-light-darker bg-white shadow-soft hover:shadow-soft-lg transition-all duration-300">
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-[9px] font-bold text-primary uppercase tracking-wider font-sans">
                  {bundle.badge}
                </span>
                <span class="text-sm font-bold text-primary font-sans">₹{bundle.price.toFixed(2)}</span>
              </div>
              
              <h3 class="text-base font-bold text-dark font-heading group-hover:text-primary transition-colors">
                {bundle.name}
              </h3>
              
              <p class="text-xs text-dark-muted leading-relaxed font-sans">
                {bundle.description}
              </p>

              <!-- Included items list -->
              <div class="bg-light rounded-xl p-4 border border-light-darker/60 space-y-2">
                <span class="block text-[9px] font-bold text-dark uppercase tracking-wider">Pack Inclusions:</span>
                <ul class="text-[11px] text-dark font-medium space-y-1 font-sans">
                  {bundle.items.map(item => (
                    <li class="flex items-start gap-1.5">
                      <span class="text-primary mt-0.5">&bull;</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="pt-5 mt-5 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
              <a href="/products" class="font-semibold text-dark-muted hover:text-dark">Explore specifications</a>
              <button
                type="button"
                class="add-retail-bundle-btn font-bold text-primary hover:underline flex items-center gap-1 focus:outline-none"
                data-bundle-slugs={bundle.slugs.join(',')}
                data-bundle-name={bundle.name}
              >
                Add Pack to Cart &rarr;
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. SHOP BY USE CASE -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-10">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Use Scenarios</span>
        <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Shop by Use Case</h2>
        <p class="text-xs text-dark-muted font-medium">Configurations matching specific water activities and environments.</p>
      </div>

      <!-- Sectors Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {applicationsList.map(app => (
          <div class="group flex flex-col rounded-2xl border border-light-darker overflow-hidden hover:border-slate-300 transition-all bg-light">
            <div class="h-40 overflow-hidden relative">
              <img src={app.image} alt={app.title} class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500" />
              <div class="absolute inset-0 bg-dark/15"></div>
            </div>
            <div class="p-5 flex-grow flex flex-col justify-between space-y-3">
              <div class="space-y-1.5">
                <h3 class="text-sm font-bold text-dark font-heading leading-tight">{app.title}</h3>
                <p class="text-xs text-dark-muted leading-relaxed font-sans">{app.desc}</p>
              </div>
              <a href="/products" class="text-xs font-semibold text-primary hover:underline mt-auto block font-sans">
                Browse Items &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. WHY SHOP WITH US (RETAIL VALUE PROPS) -->
  <section class="py-16 bg-slate-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 bg-[linear-gradient(to_right,#808080_1px,transparent_1px),linear-gradient(to_bottom,#808080_1px,transparent_1px)] bg-[size:24px_24px]"></div>

    <div class="mx-auto max-w-7xl px-6 md:px-8 relative z-10 space-y-10">
      <div class="max-w-2xl space-y-2">
        <span class="text-[10px] font-bold text-accent tracking-widest uppercase block">Store Commitments</span>
        <h2 class="text-2xl font-bold tracking-tight text-white font-heading">Why Customers Choose Us</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-5">
        {config.b2bReassurances.map(val => (
          <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/60 backdrop-blur-sm space-y-2">
            <!-- Proper Star SVG instead of Emoji -->
            <div class="h-6 w-6 rounded-lg bg-primary/20 border border-primary/45 flex items-center justify-center text-accent">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            </div>
            <h3 class="text-xs font-bold text-white font-heading leading-tight">{val.title}</h3>
            <p class="text-[11px] text-slate-400 leading-normal font-sans">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. LATEST PRODUCTS (HORIZONTAL CAROUSEL) -->
  <section class="py-20 bg-light border-y border-light-darker overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-8">
      <div class="flex items-end justify-between">
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Recently Added</span>
          <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">New Arrivals</h2>
        </div>
        <!-- Scroll navigation -->
        <div class="flex gap-2">
          <button id="carousel-prev-btn" class="h-8 w-8 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-sm transition-all focus:outline-none">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="carousel-next-btn" class="h-8 w-8 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-sm transition-all focus:outline-none">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Carousel Container -->
      <div
        id="new-arrivals-carousel"
        class="flex gap-6 overflow-x-auto pb-4 scroll-smooth scrollbar-none snap-x snap-mandatory"
      >
        {latestProducts.map((product) => {
          return (
            <div class="snap-start shrink-0 w-[260px] sm:w-[300px] bg-white border border-light-darker rounded-2xl p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300 flex flex-col justify-between">
              <div class="space-y-4">
                <div class="relative overflow-hidden aspect-[4/3] bg-light rounded-xl border border-light-darker">
                  <img
                    src={product.image}
                    alt={product.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <div class="space-y-1 font-sans">
                  <span class="text-[9px] font-bold text-primary uppercase block">{product.category.replace('-', ' ')}</span>
                  <h3 class="text-xs font-bold text-dark font-heading line-clamp-1">
                    {product.name}
                  </h3>
                </div>
              </div>
              <div class="mt-6 pt-4 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
                <span class="font-bold text-primary">₹{product.price.toFixed(2)}</span>
                <button
                  type="button"
                  data-add-to-cart
                  data-slug={product.slug}
                  data-name={product.name}
                  data-image={product.image}
                  data-price={product.price.toString()}
                  class="font-bold text-primary hover:underline focus:outline-none"
                >
                  + Add to Cart
                </button>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 9. LIFESTYLE GALLERY -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-10">
      <div class="text-center max-w-2xl mx-auto space-y-2">
