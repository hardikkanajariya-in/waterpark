                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.387 9.805-9.767.002-2.607-1.012-5.059-2.859-6.908C16.375 2.08 13.933 1.066 11.33 1.066c-5.41 0-9.81 4.39-9.814 9.77-.002 2.073.547 4.097 1.59 5.851l-.97 3.537 3.62-.949zM18.54 14.86c-.33-.165-1.95-.963-2.25-1.073-.3-.11-.52-.165-.74.165-.22.33-.85 1.073-1.04 1.293-.19.22-.38.248-.71.083-1.258-.63-2.15-1.093-2.983-1.806-.233-.2-.456-.407-.672-.61-.346-.324-.085-.5.086-.67.153-.153.33-.385.495-.578.1-.118.162-.2.242-.364.08-.165.04-.303-.02-.44-.06-.138-.52-1.266-.71-1.733-.19-.459-.395-.396-.54-.404-.143-.008-.307-.01-.472-.01-.165 0-.44.062-.67.315-.23.254-.88.86-.88 2.097 0 1.237.9 2.434 1.02 2.6 1.057 1.411 2.378 2.35 3.86 2.923.633.245 1.22.36 1.706.326.545-.04 1.63-.667 1.86-1.28.23-.61.23-1.127.16-1.237-.07-.11-.29-.165-.62-.33z"/>
