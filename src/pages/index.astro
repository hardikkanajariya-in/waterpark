---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';
import applications from '../data/applications.json';
import testimonials from '../data/testimonials.json';
import ContactForm from '../components/ContactForm.astro';

const seoTitle = "AQUADURA | Premium Aquatic Catalogue & Wholesaler";
const seoDescription = "Supplier and wholesale distributor of commercial-grade swimming caps, goggles, waterproof phone covers, pool lanes, and slides for academies, water parks, and resorts.";

// Fetch 4 featured collections to showcase
const featuredCollections = categories.slice(0, 4);

// Fetch 3 Editor's Picks
const editorsPicks = products.filter(p => 
  ["apex-racing-goggles", "floating-dry-bag-phone-pouch", "stainless-steel-pool-ladder"].includes(p.slug)
);

// Fetch 3 Latest Arrivals
const latestArrivals = products.filter(p => 
  ["double-rider-commercial-water-tube", "pro-silicone-racing-cap", "swim-resistance-training-belt"].includes(p.slug)
);
---

<Layout title={seoTitle} description={seoDescription}>
  
  <!-- 1. EDITORIAL HERO SECTION -->
  <section class="relative bg-white pt-24 pb-20 lg:pt-32 lg:pb-28 overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
        <!-- Hero Text -->
        <div class="lg:col-span-6 space-y-6">
          <span class="text-[11px] font-bold tracking-[0.25em] text-primary uppercase block">Aquadura Catalog 2026</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-dark tracking-tight leading-[1.05] font-heading">
            Equipping water recreation <br/>
            <span class="text-primary font-medium italic">at scale.</span>
          </h1>
          <p class="text-base text-dark-muted font-sans max-w-lg leading-relaxed pt-2">
            A minimalist catalogue of high-durability goggles, caps, waterproof covers, and commercial pool infrastructure. Curated for water parks, academies, and resorts globally.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <a
              href="/products"
              class="inline-flex items-center justify-center rounded-full bg-primary px-7 py-3.5 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all duration-200"
            >
              Explore Products
            </a>
            <a
              href="/contact"
              class="inline-flex items-center justify-center rounded-full border border-light-darker bg-white px-7 py-3.5 text-xs font-bold text-dark hover:bg-light transition-all duration-200"
            >
              Request B2B Quote
            </a>
          </div>
        </div>

        <!-- Hero Image Container (Apple-style, no floating cards, high-end photography) -->
        <div class="lg:col-span-6">
          <div class="relative overflow-hidden rounded-2xl bg-light-darker/35 border border-light-darker aspect-[4/3] w-full">
            <img
              src="/images/hero_catalog.png"
              alt="Premium swim and water sports gear arrangement"
              class="w-full h-full object-cover select-none"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. FEATURED COLLECTIONS (Asymmetrical Card Grid) -->
  <section class="py-20 lg:py-28 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl">
        <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block mb-2">Curated Divisions</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Featured B2B Collections</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
        {featuredCollections.map((col, idx) => {
          // Asymmetrical layout classes
          const colSpan = idx === 0 || idx === 3 ? "md:col-span-7" : "md:col-span-5";
          return (
            <a
              href={`/products?category=${col.slug}`}
              class={`group flex flex-col justify-between overflow-hidden rounded-2xl bg-white border border-light-darker p-8 shadow-soft hover:shadow-soft-lg transition-all duration-300 ${colSpan}`}
            >
              <div class="space-y-4">
                <span class="text-[10px] font-bold text-primary tracking-widest uppercase">Division 0{idx + 1}</span>
                <h3 class="text-xl font-bold text-dark font-heading group-hover:text-primary transition-colors">{col.name}</h3>
                <p class="text-xs text-dark-muted font-sans leading-relaxed max-w-sm">{col.description}</p>
              </div>
              <div class="mt-8 flex items-center text-xs font-bold text-primary group-hover:text-primary-dark font-sans">
                Browse Catalogue
                <svg class="ml-1.5 h-3.5 w-3.5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 3. BUSINESS SEGMENTS & APPLICATIONS (Muji/Aesop Editorial) -->
  <section class="py-20 lg:py-28 bg-white" id="applications">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-16">
      <div class="max-w-2xl space-y-2">
        <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block">Target Deployments</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Sectors We Supply</h2>
      </div>

      <div class="space-y-16">
        {applications.map((app, idx) => {
          const isEven = idx % 2 === 0;
          return (
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-center">
              <div class={`lg:col-span-5 space-y-6 ${isEven ? 'lg:order-1' : 'lg:order-2'}`}>
                <span class="text-xs font-bold text-primary tracking-widest uppercase">{app.tagline}</span>
                <h3 class="text-2xl font-bold text-dark font-heading">{app.name}</h3>
                <p class="text-sm text-dark-muted font-sans leading-relaxed">{app.description}</p>
                <div class="pt-2">
                  <a
                    href={`/applications#${app.slug}`}
                    class="inline-flex items-center text-xs font-bold text-primary hover:text-primary-dark font-sans group"
                  >
                    View deployment cases
                    <svg class="ml-1.5 h-4 w-4 transform group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </div>
              <div class={`lg:col-span-7 ${isEven ? 'lg:order-2' : 'lg:order-1'}`}>
                <div class="overflow-hidden rounded-2xl bg-light border border-light-darker aspect-[16/9]">
                  <img
                    src={app.image}
                    alt={app.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 4. EDITOR'S PICKS (Premium Products, Decathlon/Nike Vibe) -->
  <section class="py-20 lg:py-28 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div class="space-y-2">
          <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block">Highly Requested</span>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Editor's Picks</h2>
        </div>
        <a href="/products" class="text-xs font-bold text-primary hover:underline font-sans">
          Browse full catalog &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {editorsPicks.map((product) => (
          <div class="group flex flex-col justify-between overflow-hidden rounded-2xl bg-white border border-light-darker p-6 shadow-soft hover:shadow-soft-lg transition-all duration-300">
            <div class="space-y-4">
              <div class="relative overflow-hidden aspect-[4/3] bg-light rounded-xl border border-light-darker">
                <img
                  src={product.image}
                  alt={product.name}
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <h3 class="text-lg font-bold text-dark font-heading group-hover:text-primary transition-colors">
                {product.name}
              </h3>
              <p class="text-xs text-dark-muted font-sans leading-relaxed line-clamp-3">
                {product.description}
              </p>
            </div>
            <div class="mt-6 pt-4 border-t border-light-darker/60 flex items-center justify-between text-xs">
              <span class="text-[10px] font-bold text-dark-muted uppercase tracking-wider">MOQ: {product.moq}</span>
              <a href={`/products/${product.slug}`} class="font-bold text-primary hover:underline font-sans">
                Specifications
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. PRODUCT CATEGORIES (Clean Grid List) -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block">Catalogue Index</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Explore All Divisions</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {categories.map((cat) => (
          <a
            href={`/products?category=${cat.slug}`}
            class="group block p-6 rounded-2xl bg-light border border-light-darker hover:bg-white hover:shadow-soft transition-all duration-200"
          >
            <div class="h-10 w-10 bg-white border border-light-darker rounded-xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-200 mb-6">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="text-sm font-bold text-dark font-heading group-hover:text-primary transition-colors">
              {cat.name}
            </h3>
            <span class="text-[10px] text-dark-muted font-sans font-medium uppercase mt-1 block">
              View Division &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. LATEST ARRIVALS (Asymmetrical List/Grid) -->
  <section class="py-20 lg:py-28 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl space-y-2">
        <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block">New Releases</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Latest Additions</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestArrivals.map((product) => (
          <a
            href={`/products/${product.slug}`}
            class="group block space-y-4"
          >
            <div class="relative overflow-hidden rounded-2xl bg-white border border-light-darker aspect-[4/3] w-full">
              <img
                src={product.image}
                alt={product.name}
                class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="space-y-1">
              <h3 class="text-base font-bold text-dark font-heading group-hover:text-primary transition-colors">
                {product.name}
              </h3>
              <span class="text-xs text-dark-muted font-sans font-medium">MOQ: {product.moq}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. ABOUT COMPANY & ETHOS (Muji/Aesop Style) -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-6 space-y-6">
          <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block">Brand Ethos</span>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Premium Materials, Minimalist Design</h2>
          <p class="text-sm text-dark-muted font-sans leading-relaxed">
            At Aquadura, we source aquatic merchandise crafted to withstand the friction of daily wear and chemical exposure. We prioritize raw material safety—using food-grade liquid silicones and optical-grade polycarbonates that do not leak, crack, or yellow.
          </p>
          <p class="text-sm text-dark-muted font-sans leading-relaxed">
            By partnering directly with elite global distribution networks, we bypass secondary logistics markups, offering competitive wholesale contracts and certified compliance (ISO 9001, CE, FINA) direct to schools, academies, and resorts.
          </p>
          <div class="pt-2">
            <a href="/about" class="text-xs font-bold text-primary hover:underline font-sans">
              Learn about our standards &rarr;
            </a>
          </div>
        </div>

        <div class="lg:col-span-6">
          <div class="overflow-hidden rounded-2xl bg-light border border-light-darker aspect-video">
            <img
              src="/images/gallery_factory.png"
              alt="Quality assurance lab testing"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. BULK ORDERS CTA (Calm, Editorial B2B Lead Gen) -->
  <section class="py-20 lg:py-24 bg-light border-y border-light-darker">
    <div class="mx-auto max-w-4xl px-6 text-center space-y-8 md:px-8">
      <span class="text-[11px] font-bold tracking-[0.25em] text-primary uppercase block">Enterprise Supply</span>
      <h2 class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl font-heading">
        Request Custom Packing & Wholesale Pricing
      </h2>
      <p class="text-sm text-dark-muted font-sans max-w-xl mx-auto leading-relaxed">
        Download our complete 2026 Catalog PDF for deep specification sheets, or request pre-production samples. B2B accounts receive volume scaling terms and custom logo branding.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4 pt-2">
        <a
          href="/contact"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-full bg-primary px-7 py-3.5 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all duration-200"
        >
          Submit Quote Inquiry
        </a>
        <a
          href="/downloads"
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-full bg-white border border-light-darker px-7 py-3.5 text-xs font-bold text-dark hover:bg-light transition-all duration-200"
        >
          Download Catalog (PDF)
        </a>
      </div>
    </div>
  </section>

  <!-- 9. CONTACT & INQUIRY (Form Section) -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-3xl px-6 md:px-8">
      <div class="text-center space-y-4 mb-12">
        <span class="text-[11px] font-bold tracking-[0.2em] text-primary uppercase block">Direct Line</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Speak with a Procurement Lead</h2>
        <p class="text-xs text-dark-muted font-sans max-w-md mx-auto">
          Need custom screen printing or specific certification approvals? Fill out your requirements below and receive a detailed bid sheet.
        </p>
      </div>

      <ContactForm />
    </div>
  </section>
</Layout>
