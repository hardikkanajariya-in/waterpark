            </div>

            <button
              type="submit"
              class="w-full inline-flex items-center justify-center rounded-xl bg-primary py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all focus:outline-none font-sans"
            >
              Submit Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Carousel logic
  document.addEventListener('DOMContentLoaded', () => {
    
    // ----------------------------------------------------
    // LATEST PRODUCTS CAROUSEL LOGIC
    // ----------------------------------------------------
    const carousel = document.getElementById('new-arrivals-carousel');
    const cPrevBtn = document.getElementById('carousel-prev-btn');
    const cNextBtn = document.getElementById('carousel-next-btn');

    if (carousel && cPrevBtn && cNextBtn) {
      cPrevBtn.addEventListener('click', () => {
        carousel.scrollLeft -= 260;
      });
      cNextBtn.addEventListener('click', () => {
        carousel.scrollLeft += 260;
      });
    }

    // Direct inquiry form
    const quoteForm = document.getElementById('b2b-direct-quote-form') as HTMLFormElement;
    const successBanner = document.getElementById('form-success-banner');

    if (quoteForm && successBanner) {
      quoteForm.addEventListener('submit', (e) => {
        e.preventDefault();
        quoteForm.classList.add('hidden');
        successBanner.classList.remove('hidden');
        quoteForm.reset();
      });
    }

    // Add bundle items to shopping cart
    document.querySelectorAll('.add-retail-bundle-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.target as HTMLElement;
        const slugsStr = target.getAttribute('data-bundle-slugs') || '';
        const slugs = slugsStr.split(',');

        fetch('/src/data/products.json')
          .then(res => res.json())
          .then(allProducts => {
            slugs.forEach(slug => {
              const product = allProducts.find((p: any) => p.slug === slug);
              if (product && (window as any).ShoppingCart) {
                (window as any).ShoppingCart.addItem({
                  slug: product.slug,
                  name: product.name,
                  image: product.image,
                  price: product.price,
                  qty: 1
                });
              }
            });
          })
          .catch(err => {
            console.error("Failed to load products list", err);
          });
      });
    });

  });
</script>
