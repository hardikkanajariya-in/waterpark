---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';
import applications from '../data/applications.json';
import brands from '../data/brands.json';
import gallery from '../data/gallery.json';

const seoTitle = "AQUADURA | Wholesale Aquatic Catalog & B2B eCommerce";
const seoDescription = "Equip your academies, resorts, water parks, and stores. Browse professional goggles, custom silicone caps, waterproof phone covers, pool hardware, and slides.";

// 1. Today's B2B Offers
const todayOffers = [
  {
    product: products.find(p => p.slug === "pro-silicone-racing-cap"),
    badge: "15% off 1000+ Units",
    deal: "Waived logo print setup fee. High-definition multi-color screen printing included directly from the factory floor."
  },
  {
    product: products.find(p => p.slug === "floating-dry-bag-phone-pouch"),
    badge: "B2B Bundle Pack",
    deal: "Buy 500 Floating Phone Pouches, receive 500 custom-color RFID locker wristbands at a 50% discount."
  },
  {
    product: products.find(p => p.slug === "competition-starting-block"),
    badge: "6-Unit Facility Set",
    deal: "Procure a complete set of 6 elite competitive starting blocks with pre-installed Colorado Timing wiring slots."
  }
].filter(item => item.product !== undefined);

// 2. Best Sellers
const bestSellers = products.filter(p => 
  ["apex-racing-goggles", "rfid-locker-key-wristband", "stainless-steel-pool-ladder", "single-rider-commercial-water-tube"].includes(p.slug)
);

// 3. New Arrivals (horizontal carousel list)
const newArrivals = products.filter(p => 
  ["lazy-river-luxury-lounger", "roll-top-waterproof-dry-bag", "swim-resistance-training-belt", "optical-corrective-goggles", "contour-pull-buoy"].includes(p.slug)
);

// 4. Editor's Picks (asymmetric layouts)
const editorsPicks = products.filter(p => 
  ["anti-wave-racing-lane-rope", "double-rider-commercial-water-tube", "heavy-duty-armband-phone-case"].includes(p.slug)
);

// 5. Trending Products
const trendingProducts = products.filter(p => 
  ["commercial-life-vest-adult", "hydrodynamic-swim-fins", "junior-safe-swim-goggles", "commercial-pool-vacuum-cleaner"].includes(p.slug)
);

const getCategoryName = (catSlug: string) => {
  return categories.find(c => c.slug === catSlug)?.name || "Aquatic Gear";
};
---

<Layout title={seoTitle} description={seoDescription}>

  <!-- 1. ANNOUNCEMENT BAR (Handled by the thin top-bar inside Navbar.astro) -->

  <!-- 2. SHOPPING HERO BANNER -->
  <section class="relative bg-white pt-8 pb-16 lg:pt-12 lg:pb-20 overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-dark text-white min-h-[480px] sm:min-h-[560px] flex items-center p-8 sm:p-16 lg:p-20 shadow-soft-lg">
        
        <!-- Background Image overlay -->
        <div class="absolute inset-0 z-0 opacity-40">
          <img
            src="/images/hero_catalog.png"
            alt="Summer competitive aquatics gear collection"
            class="w-full h-full object-cover select-none"
            loading="eager"
          />
        </div>
        <div class="absolute inset-0 bg-gradient-to-r from-dark via-dark/80 to-transparent z-10"></div>

        <!-- Hero Content -->
        <div class="relative z-20 max-w-2xl space-y-6">
          <span class="inline-flex items-center rounded-full bg-primary/25 border border-primary/45 px-3 py-1 text-xs font-bold text-accent uppercase tracking-wider font-sans">
            Limited Season Release
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.05] font-heading">
            Elite Competition & Recreation Catalog
          </h1>
          <p class="text-sm sm:text-base text-slate-300 font-sans leading-relaxed max-w-lg">
            Procure world-class silicone caps, optical goggles, watertight device cases, and commercial-grade pool ropes direct from distribution.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 pt-2">
            <a
              href="/products"
              class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all duration-200"
            >
              Browse Catalogue
            </a>
            <a
              href="#offers"
              class="inline-flex items-center justify-center rounded-full bg-slate-800 border border-slate-700 px-8 py-4 text-xs font-bold text-slate-200 hover:bg-slate-700 transition-all duration-200"
            >
              View Volume Deals
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. PROMOTIONAL STRIP (eCommerce Reassurances) -->
  <section class="bg-white border-y border-light-darker py-6">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-2 gap-y-6 gap-x-4 md:grid-cols-4 text-center font-sans text-xs">
        <div class="space-y-1">
          <span class="block font-bold text-dark uppercase tracking-wider">Bulk Order Pricing</span>
          <span class="block text-[11px] text-dark-muted">Volume scale discounts applied</span>
        </div>
        <div class="space-y-1 border-l border-light-darker">
          <span class="block font-bold text-dark uppercase tracking-wider">Custom OEM Branding</span>
          <span class="block text-[11px] text-dark-muted">Factory screen printing templates</span>
        </div>
        <div class="space-y-1 border-l border-light-darker">
          <span class="block font-bold text-dark uppercase tracking-wider">Fast Sea & Air Freight</span>
          <span class="block text-[11px] text-dark-muted">Rotterdam & Dallas logistics dispatch</span>
        </div>
        <div class="space-y-1 border-l border-light-darker">
          <span class="block font-bold text-dark uppercase tracking-wider">Compliance Assured</span>
          <span class="block text-[11px] text-dark-muted">ISO 9001, CE & FINA certified</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. SHOP BY CATEGORY (Visual Photography Tiles) -->
  <section class="py-20 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Catalog Divisions</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Shop by Category</h2>
      </div>

      <!-- Categories Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {categories.map((cat) => (
          <a
            href={`/products?category=${cat.slug}`}
            class="group block relative overflow-hidden rounded-2xl bg-white border border-light-darker aspect-[4/5] shadow-soft hover:shadow-soft-lg transition-all duration-300"
          >
            <!-- Background Image -->
            <div class="absolute inset-0 bg-light-darker">
              <img
                src={cat.image}
                alt={cat.name}
                class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <!-- Fine-line dark gradient overlay at bottom -->
            <div class="absolute inset-0 bg-gradient-to-t from-dark/60 via-dark/10 to-transparent z-10"></div>
            
            <!-- Category Title at bottom -->
            <div class="absolute bottom-6 left-6 right-6 z-20 space-y-1 text-white">
              <h3 class="text-lg font-bold font-heading leading-tight">{cat.name}</h3>
              <span class="inline-flex items-center text-[10px] font-bold tracking-wider uppercase text-accent group-hover:underline">
                Explore Division &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. FEATURED COLLECTIONS (Asymmetrical Editorial Banners) -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-16">
      
      <!-- Banner 1: Left Aligned -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center bg-light rounded-3xl overflow-hidden border border-light-darker">
        <div class="lg:col-span-5 p-8 sm:p-12 space-y-6">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Competition Essentials</span>
          <h3 class="text-3xl font-extrabold text-dark font-heading leading-tight">Professional Swim Squad Supplies</h3>
          <p class="text-xs text-dark-muted font-sans leading-relaxed">
            Equip your athletic club with FINA-compliant wrinkle-free silicone dome caps, hydrodynamic short-blade training fins, and optical corrective goggles.
          </p>
          <a
            href="/products?category=swimming-training-equipment"
            class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-xs font-bold text-white hover:bg-primary-dark transition-colors font-sans"
          >
            Shop Squad Gear
          </a>
        </div>
        <div class="lg:col-span-7 h-[300px] sm:h-[400px]">
          <img
            src="/images/gallery_pool.png"
            alt="Competitive starting blocks and lane ropes"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Banner 2: Right Aligned -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center bg-light rounded-3xl overflow-hidden border border-light-darker">
        <div class="lg:col-span-7 h-[300px] sm:h-[400px] lg:order-1">
          <img
            src="/images/gallery_park.png"
            alt="Water park installation and tubes"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="lg:col-span-5 p-8 sm:p-12 space-y-6 lg:order-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Summer Operations</span>
          <h3 class="text-3xl font-extrabold text-dark font-heading leading-tight">Water Park Rental Tubing</h3>
          <p class="text-xs text-dark-muted font-sans leading-relaxed">
            Procure high-wear single, double, and 4-person slide rafts. Handcrafted from heavy-gauge K80 PVC with overlap-welded seams.
          </p>
          <a
            href="/products?category=water-park-tubes"
            class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-xs font-bold text-white hover:bg-primary-dark transition-colors font-sans"
          >
            Shop Slide Tubes
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- 6. TODAY'S OFFERS (B2B Volume Deals) -->
  <section class="py-20 bg-light border-y border-light-darker" id="offers">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Volume Incentive Contracts</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Special Contract Offers</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {todayOffers.map((deal) => (
          <div class="group flex flex-col justify-between p-8 rounded-2xl border border-light-darker bg-white shadow-soft hover:shadow-soft-lg transition-all duration-300">
            <div class="space-y-4">
              <span class="inline-flex items-center rounded-full bg-primary-light px-3 py-1 text-[10px] font-bold text-primary uppercase tracking-wider font-sans">
                {deal.badge}
              </span>
              <h3 class="text-lg font-bold text-dark font-heading group-hover:text-primary transition-colors">
                {deal.product?.name}
              </h3>
              <p class="text-xs text-dark-muted font-sans leading-relaxed">
                {deal.deal}
              </p>
            </div>
            <div class="pt-6 mt-6 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
              <div>
                <span class="block text-[9px] font-bold text-dark-muted uppercase">MOQ Requirements</span>
                <span class="font-extrabold text-dark">{deal.product?.moq}</span>
              </div>
              <a
                href={`/products/${deal.product?.slug || ''}#quote`}
                class="font-bold text-primary hover:underline"
              >
                Inquire Offer &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. BEST SELLERS (Minimalist Catalogue Grid) -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Highly Requested</span>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Best Selling Wholesale Lines</h2>
        </div>
        <a href="/products" class="text-xs font-bold text-primary hover:underline font-sans">
          Browse Catalog index &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {bestSellers.map((product) => (
          <div class="group flex flex-col justify-between overflow-hidden rounded-2xl bg-white border border-light-darker p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300">
            <div class="space-y-4">
              <div class="relative overflow-hidden aspect-[4/3] bg-light rounded-xl border border-light-darker">
                <img
                  src={product.image}
                  alt={product.name}
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="space-y-1">
                <span class="text-[9px] font-bold text-primary uppercase">{getCategoryName(product.category)}</span>
                <h3 class="text-base font-bold text-dark font-heading leading-snug line-clamp-1">
                  {product.name}
                </h3>
              </div>
              <p class="text-xs text-dark-muted font-sans leading-relaxed line-clamp-2">
                {product.description}
              </p>
            </div>
            
            <div class="mt-6 pt-4 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
              <div>
                <span class="block text-[8px] font-bold text-dark-muted uppercase">Wholesale MOQ</span>
                <span class="font-extrabold text-dark">{product.moq}</span>
              </div>
              <a href={`/products/${product.slug}`} class="font-bold text-primary hover:underline">
                View Specs &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. NEW ARRIVALS (Horizontal snap scrolling carousel) -->
  <section class="py-20 bg-light border-y border-light-darker overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-8">
      <div class="flex items-end justify-between">
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Recently Catalogued</span>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">New Arrivals</h2>
        </div>
        <!-- Scroll navigation buttons -->
        <div class="flex gap-2">
          <button id="carousel-prev-btn" class="h-9 w-9 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-soft transition-all focus:outline-none">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="carousel-next-btn" class="h-9 w-9 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-soft transition-all focus:outline-none">
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Carousel Container -->
      <div
        id="new-arrivals-carousel"
        class="flex gap-6 overflow-x-auto pb-4 scroll-smooth scrollbar-none snap-x snap-mandatory"
      >
        {newArrivals.map((product) => (
          <div class="snap-start shrink-0 w-[280px] sm:w-[320px] bg-white border border-light-darker rounded-2xl p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300 flex flex-col justify-between">
            <div class="space-y-4">
              <div class="relative overflow-hidden aspect-[4/3] bg-light rounded-xl border border-light-darker">
                <img
                  src={product.image}
                  alt={product.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="space-y-1">
                <span class="text-[9px] font-bold text-primary uppercase">{getCategoryName(product.category)}</span>
                <h3 class="text-sm font-bold text-dark font-heading line-clamp-1">
                  {product.name}
                </h3>
              </div>
            </div>
            <div class="mt-6 pt-4 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
              <span class="font-bold text-dark-muted">MOQ: {product.moq}</span>
              <a href={`/products/${product.slug}`} class="font-bold text-primary hover:underline">
                Request Quote &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 9. EDITOR'S PICKS (Asymmetrical Custom layouts) -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Selected Recommendations</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Editor's Picks</h2>
      </div>

      <!-- Asymmetrical Products Listing Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Large full-width highlight banner -->
        {editorsPicks[0] && (
          <div class="lg:col-span-8 bg-light rounded-3xl border border-light-darker overflow-hidden grid grid-cols-1 sm:grid-cols-12 gap-6 items-center">
            <div class="sm:col-span-6 p-8 space-y-4 font-sans">
              <span class="text-[9px] font-bold text-primary uppercase bg-primary-light px-2 py-0.5 rounded inline-block">
                {getCategoryName(editorsPicks[0].category)}
              </span>
              <h3 class="text-xl font-bold text-dark font-heading leading-tight">{editorsPicks[0].name}</h3>
              <p class="text-xs text-dark-muted leading-relaxed line-clamp-3">{editorsPicks[0].description}</p>
              <div class="pt-2 flex items-center justify-between text-xs">
                <span>MOQ: {editorsPicks[0].moq}</span>
                <a href={`/products/${editorsPicks[0].slug}`} class="font-bold text-primary hover:underline">Specifications &rarr;</a>
              </div>
            </div>
            <div class="sm:col-span-6 h-64 sm:h-full min-h-[250px]">
              <img
                src={editorsPicks[0].image}
                alt={editorsPicks[0].name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        )}

        <!-- Small grid picks -->
        <div class="lg:col-span-4 flex flex-col gap-6">
          {editorsPicks.slice(1, 3).map(pick => (
            <a
              href={`/products/${pick.slug}`}
              class="group flex gap-4 p-4 bg-white border border-light-darker rounded-2xl hover:shadow-soft transition-all duration-200"
            >
              <div class="h-20 w-24 shrink-0 rounded-xl overflow-hidden border border-light-darker bg-light">
                <img src={pick.image} class="w-full h-full object-cover" alt={pick.name} />
              </div>
              <div class="font-sans text-xs space-y-1 justify-center flex flex-col">
                <span class="text-[9px] font-bold text-primary uppercase">{getCategoryName(pick.category)}</span>
                <h4 class="font-bold text-dark group-hover:text-primary transition-colors line-clamp-1">{pick.name}</h4>
                <span class="text-[10px] text-dark-muted block">MOQ: {pick.moq}</span>
              </div>
            </a>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- 10. EXPLORE BY APPLICATION (Deployment Settings Navigation) -->
  <section class="py-20 bg-light border-y border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Target Segment Selection</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Explore by Application</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 font-sans">
        {applications.map((app) => (
          <a
            href={`/applications#${app.slug}`}
            class="group block p-6 rounded-2xl bg-white border border-light-darker hover:shadow-soft transition-all duration-200 space-y-4"
          >
            <div class="h-10 w-10 bg-primary-light rounded-xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-200">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div class="space-y-1">
              <h3 class="text-sm font-bold text-dark font-heading leading-tight group-hover:text-primary transition-colors">
                {app.name}
              </h3>
              <p class="text-[10px] text-dark-muted line-clamp-2 leading-relaxed">
                {app.description}
              </p>
            </div>
            <span class="text-[10px] font-bold text-primary group-hover:underline block">
              View Deployment Catalogue &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 11. TRENDING PRODUCTS / CUSTOMER FAVORITES -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="max-w-2xl space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Account Favorites</span>
        <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Trending Catalog Items</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {trendingProducts.map((product) => (
          <div class="group flex flex-col justify-between overflow-hidden rounded-2xl bg-white border border-light-darker p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300">
            <div class="space-y-4">
              <div class="relative overflow-hidden aspect-[4/3] bg-light rounded-xl border border-light-darker">
                <img
                  src={product.image}
                  alt={product.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <div class="space-y-1 font-sans">
                <span class="text-[9px] font-bold text-primary uppercase">{getCategoryName(product.category)}</span>
                <h3 class="text-base font-bold text-dark font-heading line-clamp-1">
                  {product.name}
                </h3>
              </div>
            </div>
            <div class="mt-6 pt-4 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
              <span class="font-bold text-dark-muted">MOQ: {product.moq}</span>
              <a href={`/products/${product.slug}`} class="font-bold text-primary hover:underline">
                Get Quote &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 12. BRANDS (Represented Collections) -->
  <section class="py-12 bg-light border-y border-light-darker font-sans text-xs">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <span class="font-bold text-dark-muted uppercase tracking-widest">Our Collections:</span>
        <div class="flex flex-wrap justify-center gap-12 font-heading font-extrabold text-lg text-dark/40 select-none">
          {brands.map(brand => (
            <a href="/brands" class="hover:text-primary transition-colors">
              {brand.name.toUpperCase()}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 13. GALLERY PREVIEW -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="flex justify-between items-end">
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Operational Photos</span>
          <h2 class="text-3xl font-extrabold tracking-tight text-dark font-heading">Real-World Case Settings</h2>
        </div>
        <a href="/gallery" class="text-xs font-bold text-primary hover:underline font-sans">View Full Gallery &rarr;</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {gallery.slice(0, 4).map((item) => (
          <a
            href="/gallery"
            class="group block space-y-3"
          >
            <div class="relative overflow-hidden rounded-2xl bg-light border border-light-darker aspect-[4/3] w-full">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="font-sans">
              <h4 class="text-xs font-bold text-dark group-hover:text-primary transition-colors line-clamp-1">{item.title}</h4>
              <span class="text-[9px] text-dark-muted uppercase">{item.category}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 14. BULK ORDER CTA & NEWSLETTER (Lead Generation) -->
  <section class="py-20 bg-light border-t border-light-darker font-sans">
    <div class="mx-auto max-w-5xl px-6 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Catalog Download CTA -->
      <div class="lg:col-span-6 space-y-6">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Accounts Registration</span>
        <h2 class="text-3xl font-extrabold text-dark font-heading leading-tight">Request Volume Quote & Spec Catalogues</h2>
        <p class="text-xs text-dark-muted leading-relaxed">
          Open a commercial B2B account to coordinate shipping logistics, waived print template setups, and customized container allocations.
        </p>
        <div class="flex flex-wrap gap-4 pt-2">
          <a href="/contact" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all duration-200">
            Submit B2B Inquiry
          </a>
          <a href="/downloads" class="inline-flex items-center justify-center rounded-full bg-white border border-light-darker px-6 py-3 text-xs font-bold text-dark hover:bg-light transition-all duration-200">
            Download Catalogue (PDF)
          </a>
        </div>
      </div>

      <!-- Newsletter subscription form -->
      <div class="lg:col-span-6 bg-white border border-light-darker p-8 rounded-3xl shadow-soft">
        <div class="space-y-4">
          <h3 class="text-lg font-bold text-dark font-heading">Catalogue Updates</h3>
          <p class="text-xs text-dark-muted leading-relaxed">
            Subscribe to receive automated notifications when new divisions, sub-brands, or B2B bundle offers are published.
          </p>
          <form id="home-newsletter-form" class="space-y-4 pt-2">
            <div class="flex flex-col sm:flex-row gap-2">
              <input
                type="email"
                required
                placeholder="Email address"
                class="w-full rounded-full border border-light-darker bg-light px-4 py-2.5 text-xs text-dark placeholder:text-dark-muted/50 focus:bg-white focus:outline-none focus:border-primary transition-all"
              />
              <button
                type="submit"
                class="shrink-0 rounded-full bg-primary px-6 py-2.5 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-colors"
              >
                Subscribe
              </button>
            </div>
            <div id="newsletter-success" class="hidden text-[11px] font-bold text-emerald-600 flex items-center gap-1.5 animate-fade-in">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Subscription confirmed.
            </div>
          </form>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Horizontal snap scroll carousel triggers
    const carousel = document.getElementById('new-arrivals-carousel');
    const prevBtn = document.getElementById('carousel-prev-btn');
    const nextBtn = document.getElementById('carousel-next-btn');

    if (carousel && prevBtn && nextBtn) {
      const scrollOffset = 300;
      
      prevBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: -scrollOffset, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: scrollOffset, behavior: 'smooth' });
      });
    }

    // 2. Newsletter Submit
    const newsForm = document.querySelector('form#home-newsletter-form');
    const successMsg = document.getElementById('newsletter-success');

    if (newsForm && successMsg) {
      newsForm.addEventListener('submit', (e) => {
        e.preventDefault();
        newsForm.reset();
        successMsg.classList.remove('hidden');
        setTimeout(() => {
          successMsg.classList.add('hidden');
        }, 4000);
      });
    }
  });
</script>
