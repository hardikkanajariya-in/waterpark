                <span class="font-bold text-dark-muted">MOQ: {product.moq}</span>
                <button
                  type="button"
                  data-add-to-quote
                  data-slug={product.slug}
                  data-name={product.name}
                  data-image={product.image}
                  data-moq={product.moq}
                  data-numeric-moq={numericMoq.toString()}
                  class="font-bold text-primary hover:underline focus:outline-none"
                >
                  + Add Quote
                </button>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

