<script>
  // Carousel logic
  document.addEventListener('DOMContentLoaded', () => {
    
    // ----------------------------------------------------
    // HERO BANNER SLIDER LOGIC
    // ----------------------------------------------------
    const slidesWrapper = document.getElementById('hero-slides-wrapper');
    const dotBtns = document.querySelectorAll('.hero-dot-btn');
    
    let currentSlide = 0;
    const totalSlides = 3;
    let autoPlayInterval;

    const updateSlider = (index) => {
      currentSlide = (index + totalSlides) % totalSlides;
      
      if (slidesWrapper) {
        slidesWrapper.style.transform = `translateX(-${currentSlide * 100}%)`;
      }
      
      dotBtns.forEach((dot, idx) => {
        dot.classList.remove('bg-primary', 'bg-slate-300');
        if (idx === currentSlide) {
          dot.classList.add('bg-primary');
        } else {
          dot.classList.add('bg-slate-300');
        }
      });
    };

    const startAutoPlay = () => {
      stopAutoPlay();
      autoPlayInterval = setInterval(() => {
        updateSlider(currentSlide + 1);
      }, 5000);
    };

    const stopAutoPlay = () => {
      if (autoPlayInterval) clearInterval(autoPlayInterval);
    };

    dotBtns.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopAutoPlay();
        updateSlider(index);
        startAutoPlay();
      });
    });

    // Start auto-play
    startAutoPlay();

    // ----------------------------------------------------
    // LATEST PRODUCTS CAROUSEL LOGIC
    // ----------------------------------------------------
    const carousel = document.getElementById('new-arrivals-carousel');
    const cPrevBtn = document.getElementById('carousel-prev-btn');
    const cNextBtn = document.getElementById('carousel-next-btn');

    if (carousel && cPrevBtn && cNextBtn) {
      cPrevBtn.addEventListener('click', () => {
        carousel.scrollLeft -= 260;
      });
      cNextBtn.addEventListener('click', () => {
        carousel.scrollLeft += 260;
      });
    }

    // Direct inquiry form
    const quoteForm = document.getElementById('b2b-direct-quote-form') as HTMLFormElement;
    const successBanner = document.getElementById('form-success-banner');

    if (quoteForm && successBanner) {
      quoteForm.addEventListener('submit', (e) => {
        e.preventDefault();
        quoteForm.classList.add('hidden');
        successBanner.classList.remove('hidden');
        quoteForm.reset();
      });
    }

    // Add bundle items to shopping cart
    document.querySelectorAll('.add-retail-bundle-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.target as HTMLElement;
        const slugsStr = target.getAttribute('data-bundle-slugs') || '';
        const slugs = slugsStr.split(',');

        fetch('/src/data/products.json')
          .then(res => res.json())
          .then(allProducts => {
            slugs.forEach(slug => {
              const product = allProducts.find((p: any) => p.slug === slug);
              if (product && (window as any).ShoppingCart) {
                (window as any).ShoppingCart.addItem({
                  slug: product.slug,
                  name: product.name,
                  image: product.image,
                  price: product.price,
                  qty: 1
                });
              }
            });
          })
          .catch(err => {
            console.error("Failed to load products list", err);
          });
      });
    });

  });
</script>
