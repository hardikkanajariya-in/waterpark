<script>
  // Carousel logic
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('new-arrivals-carousel');
    const prevBtn = document.getElementById('carousel-prev-btn');
    const nextBtn = document.getElementById('carousel-next-btn');

    if (carousel && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        carousel.scrollLeft -= 300;
      });
      nextBtn.addEventListener('click', () => {
        carousel.scrollLeft += 300;
      });
    }

    // Direct quote form submit
    const quoteForm = document.getElementById('b2b-direct-quote-form') as HTMLFormElement;
    const successBanner = document.getElementById('form-success-banner');

    if (quoteForm && successBanner) {
      quoteForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        // Hide form inputs
        quoteForm.classList.add('hidden');
        successBanner.classList.remove('hidden');
        
        // Reset form
        quoteForm.reset();
      });
    }

    // Add bundle items to quote cart
    document.querySelectorAll('.add-bundle-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const target = e.target as HTMLElement;
        const slugsStr = target.getAttribute('data-bundle-slugs') || '';
        const slugs = slugsStr.split(',');

        // We fetch the full products from window products or local JSON (represented in client-side quotes)
        // Wait, we can fetch matching products using client-side data.
        // Let's add them one by one.
        fetch('/src/data/products.json')
          .then(res => res.json())
          .then(allProducts => {
            slugs.forEach(slug => {
              const product = allProducts.find((p: any) => p.slug === slug);
              if (product && (window as any).QuoteCart) {
                const numericMoq = parseInt(product.moq.replace(/[^0-9]/g, '')) || 100;
                (window as any).QuoteCart.addItem({
                  slug: product.slug,
                  name: product.name,
                  image: product.image,
                  moq: product.moq,
                  numericMoq: numericMoq,
                  qty: numericMoq,
                  printing: false,
                  packaging: 'standard'
                });
              }
            });
          })
          .catch(err => {
            // Fallback: search row buttons or use catalog direct data if fetch fails
            console.error("Failed to load products list from json", err);
          });
      });
    });

  });
</script>
