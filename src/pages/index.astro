---
import Layout from '../layouts/Layout.astro';
import categories from '../data/categories.json';
import products from '../data/products.json';
import config from '../data/config.json';

const seoTitle = `${config.brandName} | Premium Swimming Equipment & Aquatic Gear`;
const seoDescription = `${config.brandTagline}. Shop professional goggles, custom silicone caps, water park rafts, and pool accessories.`;

// Get retail prices for featured items
const primaryFeatured = products.find(p => p.slug === "apex-racing-goggles") || products[0];
const secondaryFeatured = [
  products.find(p => p.slug === "floating-dry-bag-phone-pouch"),
  products.find(p => p.slug === "pro-silicone-racing-cap")
].filter(p => p !== undefined) as typeof products;

// B2C Swim Packs / Bundle Deals
const retailBundles = [
  {
    id: "recreation-pack",
    name: "Ultimate Snorkel & Swim Pack",
    badge: "Best Seller",
    price: 3499,
    description: "Equip yourself with elite training essentials. Features a complete set optimized for pool training.",
    items: [
      "1x Apex Pro Racing Goggles",
      "1x Classic Silicone Dome Cap",
      "1x Heavy-Duty nose clip & earplug set"
    ],
    slugs: ["apex-racing-goggles", "pro-silicone-racing-cap", "swim-resistance-training-belt"]
  },
  {
    id: "water-slide-set",
    name: "Water Park Float Set",
    badge: "Leisure Standard",
    price: 7999,
    description: "Get ready for the summer season with commercial-grade tubing and float safety equipment.",
    items: [
      "1x Single Rider Commercial Slide Tube",
      "1x USCG-Compliant Safety Life Vest"
    ],
    slugs: ["single-rider-commercial-water-tube", "commercial-life-vest-adult"]
  },
  {
    id: "squad-training-set",
    name: "Complete Pool Training Set",
    badge: "Training Essential",
    price: 5499,
    description: "Perfect package for competitive training, lap swimmers, and club squad members.",
    items: [
      "1x Hydrodynamic Training Swim Fins",
      "1x Ergonomic Contour Pull Buoy",
      "1x High-density EVA Kickboard"
    ],
    slugs: ["hydrodynamic-swim-fins", "contour-pull-buoy"]
  }
];

// Applications
const applicationsList = [
  {
    title: "Water Parks & Slides",
    desc: "Heavy-gauge slide rafts, commercial life vests, and waterproof device cases built to withstand constant sun exposure and heavy chlorine.",
    image: "/images/gallery_park.png"
  },
  {
    title: "Swimming Academies",
    desc: "Racing goggles, variable-thickness 3D silicone caps, pull buoys, and resistance training kits built for institutional durability.",
    image: "/images/gallery_pool.png"
  },
  {
    title: "Hotels & Resorts",
    desc: "Stainless steel deck ladders, anti-wave swimming lane ropes, and soft liquid silicone leisure goggles that don't leave pressure marks.",
    image: "/images/gallery_quality.png"
  },
  {
    title: "Retail & Leisure",
    desc: "Individually packaged prescription swim goggles, heavy-duty PVC dry bags, and quick-dry microfiber accessories tailored for active swimmers.",
    image: "/images/gallery_factory.png"
  }
];

// Latest Products
const latestProducts = products.filter(p => 
  ["lazy-river-luxury-lounger", "roll-top-waterproof-dry-bag", "swim-resistance-training-belt", "optical-corrective-goggles"].includes(p.slug)
);
---

<Layout title={seoTitle} description={seoDescription}>

  <!-- 1. HEADER & PREMIUM SEARCH SECTION -->
  <section class="max-w-7xl mx-auto px-6 md:px-8 pt-12 pb-6">
    <div class="relative overflow-hidden rounded-3xl border border-light-darker p-8 sm:p-16 shadow-soft text-center space-y-6 bg-cover bg-center" style="background-image: url('/images/gallery_pool.png');">
      <!-- Premium Dark Overlay -->
      <div class="absolute inset-0 bg-slate-950/60 z-0"></div>

      <div class="relative z-10 space-y-2 max-w-2xl mx-auto">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Aquadura Retail</span>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-white font-heading leading-tight">
          India's Ultimate Swim & Water Park Gear Store
        </h1>
        <p class="text-xs sm:text-sm text-slate-200 font-sans font-medium">
          Get ready for the pool with leakproof goggles, stretchable silicone caps, training kickboards, and slide-ready float tubes. Pan-India shipping in 3-7 days.
        </p>
      </div>

      <div class="relative z-10 max-w-2xl mx-auto">
        <form action="/products" method="GET" class="relative flex flex-col sm:flex-row gap-3">
          <div class="relative flex-grow">
            <input
              type="text"
              name="search"
              placeholder={config.searchPlaceholder}
              class="w-full rounded-xl border border-light-darker bg-white px-4 py-3 pl-10 text-xs text-dark placeholder:text-dark-muted/50 focus:border-primary focus:outline-none transition-all font-semibold shadow-sm"
              required
            />
            <svg class="absolute left-3.5 top-3.5 h-5 w-5 text-dark-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <button
            type="submit"
            class="rounded-xl bg-primary text-white px-8 py-3.5 text-xs font-bold hover:bg-primary-dark transition-all flex items-center justify-center font-sans focus:outline-none shadow-md"
          >
            Search Store
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- 3. PREMIUM CATEGORY SLIDER (NO DESCRIPTIONS, ROUNDED ICONS) -->
  <section id="categories" class="py-16 bg-light mt-12 border-t border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-8">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Catalog Divisions</span>
        <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Shop by Category</h2>
        <p class="text-xs text-dark-muted font-medium">Browse our specialized collections of premium swim and water park gear.</p>
      </div>

      <!-- Horizontal scrollable category circles -->
      <div class="flex gap-8 overflow-x-auto pb-6 scrollbar-none snap-x snap-mandatory justify-start md:justify-center">
        {categories.map((cat) => (
          <a
            href={`/products?category=${cat.slug}`}
            class="snap-start shrink-0 w-28 sm:w-32 flex flex-col items-center text-center group"
          >
            <!-- Highly rounded category image container -->
            <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full overflow-hidden border border-light-darker bg-white shadow-soft group-hover:scale-105 transition-transform duration-300">
              <img
                src={cat.image}
                alt={cat.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <span class="mt-3 text-xs font-bold text-dark group-hover:text-primary transition-colors line-clamp-1">
              {cat.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. SIGNATURE SWIM HIGHLIGHTS (Editorial Split Layout) -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 border-b border-light-darker pb-5">
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block font-heading">Signature Pick</span>
          <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Featured Swimwear & Gear</h2>
        </div>
        <a href="/products" class="text-xs font-bold text-primary hover:underline">
          View All Products &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        <!-- Left: Large Product Highlight Card -->
        <div class="lg:col-span-8 bg-gradient-to-br from-light via-white to-light rounded-3xl border border-light-darker p-8 flex flex-col md:flex-row gap-8 items-center shadow-soft hover:shadow-soft-lg transition-all duration-300">
          <div class="w-full md:w-1/2 aspect-[4/3] rounded-2xl overflow-hidden border border-light-darker bg-white">
            <img
              src={primaryFeatured.image}
              alt={primaryFeatured.name}
              class="w-full h-full object-cover hover:scale-102 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="w-full md:w-1/2 space-y-5 font-sans">
            <div class="flex items-center justify-between">
              <span class="text-[10px] font-bold text-primary uppercase bg-primary-light px-2.5 py-0.5 rounded font-semibold">Goggles</span>
              <span class="text-lg font-bold text-primary">₹{primaryFeatured.price.toFixed(2)}</span>
            </div>
            
            <h3 class="text-xl font-bold text-dark font-heading leading-tight">
              {primaryFeatured.name}
            </h3>
            
            <p class="text-xs text-dark-muted leading-relaxed font-medium">
              {primaryFeatured.description}
            </p>

            <div class="space-y-1.5 border-t border-light-darker pt-4 text-[11px] text-dark-muted font-semibold">
              {Object.entries(primaryFeatured.specifications).slice(0, 3).map(([k, v]) => (
                <div class="flex justify-between">
                  <span class="font-bold text-dark">{k}</span>
                  <span>{v}</span>
                </div>
              ))}
            </div>

            <div class="flex items-center gap-3 pt-2">
              <div class="flex flex-col gap-1 text-[9px]">
                <label class="font-bold uppercase tracking-wider text-dark-muted">Qty</label>
                <input
                  type="number"
                  min="1"
                  value="1"
                  data-slug={primaryFeatured.slug}
                  class="qty-input-field w-12 rounded-lg border border-light-darker bg-white px-2 py-1.5 font-bold text-dark text-xs focus:outline-none"
                />
              </div>
              <button
                type="button"
                data-add-to-cart
                data-slug={primaryFeatured.slug}
                data-name={primaryFeatured.name}
                data-image={primaryFeatured.image}
                data-price={primaryFeatured.price.toString()}
                class="flex-grow inline-flex items-center justify-center rounded-xl bg-primary py-3 text-xs font-bold text-white shadow hover:bg-primary-dark transition-all focus:outline-none"
              >
                Add to Cart
              </button>
            </div>
          </div>
        </div>

        <!-- Right: Vertical list of side highlights -->
        <div class="lg:col-span-4 flex flex-col gap-6 justify-between">
          {secondaryFeatured.map((prod) => (
            <div class="bg-white rounded-3xl border border-light-darker p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300 flex flex-col justify-between flex-grow">
              <div class="flex gap-4">
                <div class="h-16 w-16 shrink-0 rounded-xl overflow-hidden border border-light-darker bg-light">
                  <img src={prod.image} alt={prod.name} class="h-full w-full object-cover" />
                </div>
                <div class="space-y-1 flex-grow font-sans">
                  <div class="flex items-center justify-between">
                    <span class="text-[9px] font-bold text-primary uppercase">Leisure</span>
                    <span class="text-xs font-bold text-primary">₹{prod.price.toFixed(2)}</span>
                  </div>
                  <h4 class="text-xs font-bold text-dark font-heading leading-snug line-clamp-1">{prod.name}</h4>
                  <p class="text-[10px] text-dark-muted leading-normal line-clamp-2 font-medium">{prod.description}</p>
                </div>
              </div>

              <div class="mt-4 pt-3 border-t border-light-darker flex items-center justify-between font-sans">
                <a href={`/products/${prod.slug}`} class="text-[10px] font-bold text-dark-muted hover:text-primary transition-colors">View Details &rarr;</a>
                <button
                  type="button"
                  data-add-to-cart
                  data-slug={prod.slug}
                  data-name={prod.name}
                  data-image={prod.image}
                  data-price={prod.price.toString()}
                  class="inline-flex items-center justify-center rounded-lg bg-dark px-3 py-1.5 text-[9px] font-bold text-white hover:bg-primary transition-all focus:outline-none"
                >
                  + Add to Cart
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 5. CURATED SWIM BUNDLES (Magazine Split Row Layout) -->
  <section class="py-20 bg-light border-y border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left Side: Large Info Panel -->
        <div class="lg:col-span-4 space-y-5 font-sans">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Swim Packs</span>
          <h2 class="text-3xl font-bold tracking-tight text-dark font-heading leading-tight">Ready Swim Bundles</h2>
          <p class="text-xs text-dark-muted leading-relaxed font-medium">
            Get everything you need in one quick package. Our swim packs are curated by store experts to combine caps, goggles, and training fins in a discounted starter kit.
          </p>
          <div class="pt-2">
            <a href="/products" class="inline-flex items-center text-xs font-bold text-primary hover:underline">
              Browse individual gear list &rarr;
            </a>
          </div>
        </div>

        <!-- Right Side: Vertical List of Bundles -->
        <div class="lg:col-span-8 space-y-5">
          {retailBundles.map(bundle => (
            <div class="group bg-white rounded-2xl border border-light-darker p-5 sm:p-6 shadow-soft hover:shadow-soft-lg transition-all duration-300 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6">
              <div class="space-y-3 font-sans flex-grow">
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-[9px] font-bold text-primary uppercase tracking-wider">
                    {bundle.badge}
                  </span>
                  <span class="text-xs text-dark-muted font-bold">Includes {bundle.items.length} items</span>
                </div>
                <h3 class="text-base font-bold text-dark font-heading group-hover:text-primary transition-colors">
                  {bundle.name}
                </h3>
                <div class="flex flex-wrap gap-2 text-[10px] text-dark font-semibold">
                  {bundle.items.map(item => (
                    <span class="px-2 py-0.5 rounded bg-light border border-light-darker">{item}</span>
                  ))}
                </div>
              </div>

              <div class="shrink-0 flex sm:flex-col items-end sm:items-center justify-between w-full sm:w-auto border-t sm:border-t-0 border-light-darker pt-4 sm:pt-0 gap-4">
                <div class="text-right sm:text-center">
                  <span class="block text-[8px] font-bold text-dark-muted uppercase tracking-wider">Bundle Price</span>
                  <span class="text-base font-bold text-primary">₹{bundle.price.toFixed(2)}</span>
                </div>
                <button
                  type="button"
                  class="add-retail-bundle-btn inline-flex justify-center rounded-xl bg-primary px-5 py-3 text-xs font-bold text-white shadow hover:bg-primary-dark transition-all focus:outline-none font-sans"
                  data-bundle-slugs={bundle.slugs.join(',')}
                  data-bundle-name={bundle.name}
                >
                  Add Bundle
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 6. SHOP BY USE CASE (Dynamic Masonry Overlays) -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Use Scenarios</span>
        <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Shop by Use Case</h2>
        <p class="text-xs text-dark-muted font-medium">Configurations matching specific water activities and environments.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-6">
        {applicationsList.map((app, idx) => {
          const colSpan = (idx === 0 || idx === 3) ? "lg:col-span-7" : "lg:col-span-5";
          return (
            <a
              href={`/products?search=${app.title.split(' ')[0].toLowerCase()}`}
              class={`group relative block overflow-hidden rounded-3xl border border-light-darker aspect-video lg:h-64 bg-light shadow-soft hover:shadow-soft-lg transition-all duration-300 ${colSpan}`}
            >
              <div class="absolute inset-0">
                <img
                  src={app.image}
                  alt={app.title}
                  class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-dark/20 to-transparent z-10"></div>
              
              <div class="absolute bottom-6 left-6 right-6 z-20 space-y-2 text-white font-sans">
                <h3 class="text-lg font-bold font-heading leading-tight">{app.title}</h3>
                <p class="text-xs text-slate-200 font-medium line-clamp-2 max-w-md">{app.desc}</p>
                <div class="pt-1.5 flex items-center gap-1 text-[10px] font-bold text-accent group-hover:underline">
                  Browse items &rarr;
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 7. STORE GUARANTEES (Minimal Borderless Bar) -->
  <section class="py-12 bg-white border-y border-light-darker">
    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-8 items-start">
        {config.b2bReassurances.map(val => (
          <div class="space-y-3 font-sans">
            <div class="h-10 w-10 rounded-2xl bg-primary-light flex items-center justify-center text-primary">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="space-y-1">
              <h3 class="text-xs font-bold text-dark font-heading leading-tight">{val.title}</h3>
              <p class="text-[10px] text-dark-muted font-medium leading-normal">{val.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8. LATEST PRODUCTS (HORIZONTAL CAROUSEL) -->
  <section class="py-20 bg-light border-b border-light-darker overflow-hidden">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-8">
      <div class="flex items-end justify-between">
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Recently Added</span>
          <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">New Arrivals</h2>
        </div>
        <!-- Scroll navigation -->
        <div class="flex gap-2">
          <button id="carousel-prev-btn" class="h-8 w-8 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-sm transition-all focus:outline-none">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button id="carousel-next-btn" class="h-8 w-8 rounded-full border border-light-darker bg-white text-dark hover:text-primary hover:border-primary flex items-center justify-center shadow-sm transition-all focus:outline-none">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Carousel Container -->
      <div
        id="new-arrivals-carousel"
        class="flex gap-6 overflow-x-auto pb-4 scroll-smooth scrollbar-none snap-x snap-mandatory"
      >
        {latestProducts.map((product) => {
          return (
            <div class="snap-start shrink-0 w-[260px] sm:w-[300px] bg-white border border-light-darker rounded-2xl p-5 shadow-soft hover:shadow-soft-lg transition-all duration-300 flex flex-col justify-between">
              <div class="space-y-4">
                <div class="relative overflow-hidden aspect-[4/3] bg-light rounded-xl border border-light-darker">
                  <img
                    src={product.image}
                    alt={product.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <div class="space-y-1 font-sans">
                  <span class="text-[9px] font-bold text-primary uppercase block">{product.category.replace('-', ' ')}</span>
                  <h3 class="text-xs font-bold text-dark font-heading line-clamp-1">
                    {product.name}
                  </h3>
                </div>
              </div>
              <div class="mt-6 pt-4 border-t border-light-darker/60 flex items-center justify-between text-xs font-sans">
                <span class="font-bold text-primary">₹{product.price.toFixed(2)}</span>
                <button
                  type="button"
                  data-add-to-cart
                  data-slug={product.slug}
                  data-name={product.name}
                  data-image={product.image}
                  data-price={product.price.toString()}
                  class="font-bold text-primary hover:underline focus:outline-none"
                >
                  + Add to Cart
                </button>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 9. LIFESTYLE GALLERY (Curated Overlapping Photo Collage) -->
  <section class="py-20 bg-white">
    <div class="mx-auto max-w-7xl px-6 md:px-8 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-2">
        <span class="text-[10px] font-bold text-primary tracking-widest uppercase block">Visual Showcase</span>
        <h2 class="text-2xl font-bold tracking-tight text-dark font-heading">Swim & Slide Showcase</h2>
        <p class="text-xs text-dark-muted font-medium">Real-world swimming pool and leisure deployment case photos.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        <div class="overflow-hidden rounded-3xl border border-light-darker aspect-[4/3] bg-light relative group shadow-soft hover:shadow-soft-lg transition-all duration-300">
          <img src="/images/gallery_factory.png" alt="Splash-proof Gear Sets" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/65 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
            <span class="text-white text-xs font-bold font-heading">Splash-proof Gear Sets</span>
          </div>
        </div>
        <div class="overflow-hidden rounded-3xl border border-light-darker aspect-[4/3] bg-light relative group shadow-soft hover:shadow-soft-lg transition-all duration-300">
          <img src="/images/gallery_pool.png" alt="Competitive Swim Training" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/65 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
            <span class="text-white text-xs font-bold font-heading">Competitive Swim Training</span>
          </div>
        </div>
        <div class="overflow-hidden rounded-3xl border border-light-darker aspect-[4/3] bg-light relative group shadow-soft hover:shadow-soft-lg transition-all duration-300">
          <img src="/images/gallery_quality.png" alt="Premium Finish Verification" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-dark/65 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
