---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import config from '../data/config.json';

const seoTitle = `Contact Support Desk | ${config.brandName}`;
const seoDescription = `Have a question about swim gear, cap sizes, or retail orders? Get in touch with the ${config.brandName} store support care team.`;
---

<Layout title={seoTitle} description={seoDescription}>
  
  <!-- Page Title and Breadcrumb (Clean & Standard Width) -->
  <div class="mx-auto max-w-7xl px-6 md:px-8 pt-8 pb-4 font-sans">
    <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2 mb-2">
      <a href="/" class="hover:text-primary">Home</a>
      <span>/</span>
      <span class="text-primary">Contact Store</span>
    </nav>
    <h1 class="text-2xl font-bold tracking-tight text-dark font-heading">
      Contact Us
    </h1>
  </div>

  <!-- Split Layout -->
  <section class="py-12 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 lg:flex lg:gap-16">
      
      <!-- Left: Contact info -->
      <div class="w-full lg:w-1/3 shrink-0 space-y-12 mb-12 lg:mb-0 font-sans">
        
        <!-- Channels -->
        <div class="space-y-4">
          <span class="block text-[10px] font-bold text-primary uppercase tracking-widest">Department Help</span>
          <ul class="space-y-4 text-xs font-semibold">
            <li>
              <span class="block font-bold text-dark mb-0.5">General Care & Orders</span>
              <a href={`mailto:${config.contact.email}`} class="text-primary hover:underline">{config.contact.email}</a>
            </li>
            <li>
              <span class="block font-bold text-dark mb-0.5">Squad Personalization & Customs</span>
              <a href={`mailto:custom@${config.contact.email.split('@')[1]}`} class="text-primary hover:underline">custom@{config.contact.email.split('@')[1]}</a>
            </li>
            <li>
              <span class="block font-bold text-dark mb-0.5">Delivery Support</span>
              <a href={`mailto:delivery@${config.contact.email.split('@')[1]}`} class="text-primary hover:underline">delivery@{config.contact.email.split('@')[1]}</a>
            </li>
          </ul>
        </div>

        <!-- Coordinates -->
        <div class="space-y-4">
          <span class="block text-[10px] font-bold text-primary uppercase tracking-widest font-sans">Mumbai Store Outlet</span>
          <ul class="space-y-4 text-xs text-dark-muted font-semibold">
            <li class="flex items-start">
              <svg class="h-4 w-4 text-primary shrink-0 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <span>{config.contact.address}</span>
            </li>
            <li class="flex items-center">
              <svg class="h-4 w-4 text-primary shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${config.contact.phoneRaw}`} class="hover:text-primary transition-colors">{config.contact.phone}</a>
            </li>
            <li class="flex items-center">
              <svg class="h-4 w-4 text-primary shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Mon - Sat / 10:00 AM - 8:00 PM IST</span>
            </li>
          </ul>
        </div>

        <!-- Store Outlets -->
        <div class="space-y-4">
          <span class="block text-[10px] font-bold text-primary uppercase tracking-widest">Our Outlets</span>
          <ul class="space-y-2 text-[11px] text-dark-muted font-bold font-sans">
            <li class="flex items-center">
              <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2"></span>
              Bandra West (Hill Road, Mumbai)
            </li>
            <li class="flex items-center">
              <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2"></span>
              Connaught Place (Inner Circle, New Delhi)
            </li>
            <li class="flex items-center">
              <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2"></span>
              Indiranagar (100 Feet Road, Bengaluru)
            </li>
          </ul>
        </div>

      </div>

      <!-- Right: Form -->
      <div class="flex-grow">
        <ContactForm />
      </div>

    </div>
  </section>
</Layout>
