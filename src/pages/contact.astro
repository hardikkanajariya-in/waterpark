---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import config from '../data/config.json';

const seoTitle = `Contact & Wholesale Inquiries | ${config.brandName}`;
const seoDescription = `Partner with ${config.brandName}. Submit bulk order inquiries, request product samples, or discuss custom logo printing options with our sales division.`;
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Header -->
  <section class="bg-white py-16 border-b border-light-darker">
    <div class="mx-auto max-w-4xl px-6 md:px-8 space-y-4">
      <span class="text-[10px] font-black tracking-widest text-primary uppercase block font-heading">Direct Channels</span>
      <h1 class="text-4xl font-extrabold tracking-tight text-dark font-heading">
        Procurement & Accounts
      </h1>
      <p class="text-sm text-dark-muted font-sans max-w-xl leading-relaxed">
        Submit technical parameters, discuss custom logo die-lines, or coordinate freight logistics. A wholesale representative will follow up within 24 business hours.
      </p>
    </div>
  </section>

  <!-- Split Layout -->
  <section class="py-16 bg-light">
    <div class="mx-auto max-w-7xl px-6 md:px-8 lg:flex lg:gap-16">
      
      <!-- Left: Contact info -->
      <div class="w-full lg:w-1/3 shrink-0 space-y-12 mb-12 lg:mb-0 font-sans">
        
        <!-- Channels -->
        <div class="space-y-4">
          <span class="block text-[10px] font-bold text-primary uppercase tracking-widest">Department Routing</span>
          <ul class="space-y-4 text-xs">
            <li>
              <span class="block font-bold text-dark mb-0.5">Wholesale & Bulk Contracts</span>
              <a href={`mailto:${config.contact.email}`} class="text-primary font-semibold hover:underline">{config.contact.email}</a>
            </li>
            <li>
              <span class="block font-bold text-dark mb-0.5">Custom Printing & OEM Branding</span>
              <a href={`mailto:branding@${config.contact.email.split('@')[1]}`} class="text-primary font-semibold hover:underline">branding@{config.contact.email.split('@')[1]}</a>
            </li>
            <li>
              <span class="block font-bold text-dark mb-0.5">Freight & Shipping Manifests</span>
              <a href={`mailto:logistics@${config.contact.email.split('@')[1]}`} class="text-primary font-semibold hover:underline">logistics@{config.contact.email.split('@')[1]}</a>
            </li>
          </ul>
        </div>

        <!-- Coordinates -->
        <div class="space-y-4">
          <span class="block text-[10px] font-bold text-primary uppercase tracking-widest">Headquarters Office</span>
          <ul class="space-y-4 text-xs text-dark-muted">
            <li class="flex items-start">
              <svg class="h-4 w-4 text-primary shrink-0 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <span>{config.contact.address}</span>
            </li>
            <li class="flex items-center">
              <svg class="h-4 w-4 text-primary shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${config.contact.phoneRaw}`} class="hover:text-primary transition-colors">{config.contact.phone}</a>
            </li>
            <li class="flex items-center">
              <svg class="h-4 w-4 text-primary shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>Mon - Fri / 8:00 AM - 6:00 PM EST</span>
            </li>
          </ul>
        </div>

        <!-- Logistics Hubs -->
        <div class="space-y-4">
          <span class="block text-[10px] font-bold text-primary uppercase tracking-widest">Global Freight Hubs</span>
          <ul class="space-y-2 text-[11px] text-dark-muted font-medium">
            <li class="flex items-center">
              <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2"></span>
              Main Sea Port Dispatch (Rotterdam)
            </li>
            <li class="flex items-center">
              <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2"></span>
              Air Cargo Hub (Singapore)
            </li>
            <li class="flex items-center">
              <span class="h-1.5 w-1.5 bg-primary rounded-full mr-2"></span>
              Distribution Warehouses (Dallas / Mumbai)
            </li>
          </ul>
        </div>

      </div>

      <!-- Right: Form -->
      <div class="flex-grow">
        <ContactForm />
      </div>

    </div>
  </section>
</Layout>
