---
import Layout from '../layouts/Layout.astro';
import downloads from '../data/downloads.json';
import config from '../data/config.json';

const seoTitle = `Product Guides & Store Downloads | ${config.brandName}`;
const seoDescription = `Download product catalogs, sizing charts, gear care guides, and squad print templates in PDF formats.`;
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Page Title and Breadcrumb (Clean & Standard Width) -->
  <div class="mx-auto max-w-7xl px-6 md:px-8 pt-8 pb-4 font-sans bg-white border-b border-light-darker">
    <nav class="flex text-xs font-semibold uppercase tracking-wider text-dark-muted space-x-2 mb-2">
      <a href="/" class="hover:text-primary">Home</a>
      <span>/</span>
      <span class="text-primary">Downloads</span>
    </nav>
    <h1 class="text-2xl font-bold tracking-tight text-dark font-heading">
      Resource Centre
    </h1>
  </div>

  <!-- Downloads List -->
  <section class="py-20 bg-light">
    <div class="mx-auto max-w-4xl px-6 md:px-8 space-y-6">
      
      <div class="grid grid-cols-1 gap-6">
        {downloads.map((doc) => (
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-6 rounded-2xl border border-light-darker bg-white shadow-soft hover:shadow-soft-lg transition-all duration-200 gap-6 animate-fade-in">
            <div class="space-y-2 font-sans flex-grow">
              <div class="flex items-center gap-2">
                <span class="px-2.5 py-0.5 rounded bg-primary-light text-primary text-[9px] font-bold uppercase tracking-wider">
                  {doc.category}
                </span>
                <span class="text-[10px] text-dark-muted font-semibold">
                  Version {doc.version} &bull; {doc.file_size}
                </span>
              </div>
              <h2 class="text-base font-bold text-dark font-heading">
                {doc.title}
              </h2>
              <p class="text-xs text-dark-muted leading-relaxed font-medium">
                {doc.description}
              </p>
            </div>
            
            <button
              type="button"
              class="shrink-0 w-full sm:w-auto inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 text-xs font-bold text-white hover:bg-primary-dark transition-all focus:outline-none"
              onclick="alert('Download started')"
            >
              <svg class="h-4.5 w-4.5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download PDF
            </button>
          </div>
        ))}
      </div>

    </div>
  </section>
</Layout>
