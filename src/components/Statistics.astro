---
const stats = [
  { value: "1.2M+", label: "Units Annual Capacity" },
  { value: "15,000m²", label: "Production Facility" },
  { value: "99.8%", label: "QA Pass Rate" },
  { value: "24/7", label: "Client Support Coverage" }
];
---

<section class="bg-dark text-white py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid grid-cols-2 gap-y-10 gap-x-8 md:grid-cols-4 text-center">
      {stats.map((stat) => (
        <div class="space-y-2">
          <div class="text-4xl font-extrabold text-secondary sm:text-5xl font-heading tracking-tight">
            {stat.value}
          </div>
          <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 font-sans">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
