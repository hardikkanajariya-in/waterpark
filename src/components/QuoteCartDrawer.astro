---
import config from '../data/config.json';
---

<!-- Slide-out Cart Backdrop -->
<div id="cart-drawer-backdrop" class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300"></div>

<!-- Slide-out Drawer Panel -->
<div 
  id="cart-drawer" 
  class="fixed top-0 right-0 h-full w-full sm:w-[460px] bg-white border-l border-light-darker shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col font-sans"
  style="z-index: 10000;"
>
  
  <!-- Drawer Header -->
  <div class="p-5 border-b border-light-darker flex items-center justify-between bg-slate-50">
    <div class="flex items-center space-x-2">
      <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
      </svg>
      <h2 class="text-sm font-bold text-dark font-heading">Your Shopping Cart</h2>
      <span id="cart-badge-count" class="bg-primary/10 text-primary text-[10px] font-extrabold px-2.5 py-0.5 rounded-full">0 items</span>
    </div>
    
    <button id="close-cart-drawer-btn" class="text-dark-muted hover:text-dark p-1 rounded-full hover:bg-light transition-all focus:outline-none">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Drawer Body (Scrollable items) -->
  <div id="cart-drawer-body" class="flex-grow overflow-y-auto p-5 space-y-6">
    <!-- Empty State -->
    <div id="cart-empty-state" class="text-center py-16 space-y-4">
      <div class="h-16 w-16 bg-light rounded-full flex items-center justify-center mx-auto text-dark-muted/40">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
      </div>
      <h3 class="text-xs font-bold text-dark font-heading">Your cart is empty</h3>
      <p class="text-xs text-dark-muted max-w-[260px] mx-auto leading-relaxed">
        Add some premium products from our catalog to get started.
      </p>
      <a href="/products" class="inline-flex justify-center rounded-full bg-primary px-5 py-2.5 text-xs font-bold text-white hover:bg-primary-dark transition-all">
        Continue Shopping
      </a>
    </div>

    <!-- Items List Container -->
    <div id="cart-items-list" class="space-y-4 hidden">
      <!-- Injected by Javascript -->
    </div>

    <!-- Cart Summary & Checkout Form -->
    <div id="cart-summary-container" class="border-t border-light-darker pt-5 mt-6 hidden space-y-5">
      <!-- Subtotal row -->
      <div class="flex justify-between items-center text-xs font-bold text-dark pb-2 border-b border-light-darker/60">
        <span class="text-dark-muted font-medium">Estimated Subtotal</span>
        <span id="cart-subtotal" class="text-sm font-bold text-primary">₹0.00</span>
      </div>

      <h3 class="text-[10px] font-bold text-dark uppercase tracking-wider">Shipping Details</h3>
      
      <form id="drawer-checkout-form" class="space-y-3.5">
        <div>
          <label for="checkout-name" class="block text-[9px] font-bold text-dark uppercase tracking-wider mb-1">Full Name *</label>
          <input
            type="text"
            id="checkout-name"
            required
            placeholder="John Doe"
            class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all font-medium"
          />
        </div>
        
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="checkout-email" class="block text-[9px] font-bold text-dark uppercase tracking-wider mb-1">Email *</label>
            <input
              type="email"
              id="checkout-email"
              required
              placeholder="john@example.com"
              class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all font-medium"
            />
          </div>
          <div>
            <label for="checkout-phone" class="block text-[9px] font-bold text-dark uppercase tracking-wider mb-1">Phone *</label>
            <input
              type="tel"
              id="checkout-phone"
              required
              placeholder="+91 99999 88888"
              class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all font-medium"
            />
          </div>
        </div>

        <div>
          <label for="checkout-address" class="block text-[9px] font-bold text-dark uppercase tracking-wider mb-1">Delivery Address *</label>
          <textarea
            id="checkout-address"
            rows="2"
            required
            placeholder="Enter full shipping address..."
            class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all resize-none font-medium"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full inline-flex items-center justify-center rounded-full bg-primary py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all"
        >
          Place Order (COD/Payment on delivery)
        </button>
      </form>
    </div>
  </div>

  <!-- Success Screen Overlay -->
  <div id="cart-success-overlay" class="absolute inset-0 bg-white z-20 flex flex-col items-center justify-center p-8 space-y-4 text-center transform translate-y-full transition-transform duration-300">
    <div class="h-16 w-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center shadow-inner">
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h3 class="text-base font-bold text-dark font-heading">Order Placed Successfully!</h3>
    <p class="text-xs text-dark-muted max-w-[280px] leading-relaxed">
      Thank you for shopping with us. We have received your order details and will dispatch your items shortly. A tracking number will be sent to your email.
    </p>
    <button id="close-cart-success-btn" class="inline-flex justify-center rounded-full border border-light-darker bg-light px-6 py-2.5 text-xs font-bold text-dark hover:bg-white transition-all">
      Continue Browsing
    </button>
  </div>
</div>

<script>
  interface CartItem {
    slug: string;
    name: string;
    image: string;
    price: number;
    qty: number;
  }

  class ShoppingCartManager {
    static getCart(): CartItem[] {
      try {
        const data = localStorage.getItem('retail_shopping_cart');
        return data ? JSON.parse(data) : [];
      } catch (e) {
        return [];
      }
    }

    static saveCart(cart: CartItem[]) {
      try {
        localStorage.setItem('retail_shopping_cart', JSON.stringify(cart));
        window.dispatchEvent(new CustomEvent('cart-updated'));
      } catch (e) {
        console.error("Failed to save cart state", e);
      }
    }

    static addItem(item: Omit<CartItem, 'qty'> & { qty?: number }) {
      const cart = this.getCart();
      const existing = cart.find(i => i.slug === item.slug);
      const targetQty = item.qty || 1;
      
      if (existing) {
        existing.qty = existing.qty + targetQty;
      } else {
        cart.push({
          slug: item.slug,
          name: item.name,
          image: item.image,
          price: item.price,
          qty: targetQty
        });
      }
      
      this.saveCart(cart);
      
      setTimeout(() => {
        window.dispatchEvent(new CustomEvent('open-cart-drawer'));
      }, 50);
    }

    static removeItem(slug: string) {
      let cart = this.getCart();
      cart = cart.filter(i => i.slug !== slug);
      this.saveCart(cart);
    }

    static updateItemQty(slug: string, qty: number) {
      const cart = this.getCart();
      const item = cart.find(i => i.slug === slug);
      if (item) {
        item.qty = Math.max(qty, 1);
        this.saveCart(cart);
      }
    }

    static clearCart() {
      this.saveCart([]);
    }
  }

  (window as any).ShoppingCart = ShoppingCartManager;

  document.addEventListener('DOMContentLoaded', () => {
    const drawer = document.getElementById('cart-drawer');
    const backdrop = document.getElementById('cart-drawer-backdrop');
    const closeBtn = document.getElementById('close-cart-drawer-btn');
    
    const badgeCount = document.getElementById('cart-badge-count');
    const emptyState = document.getElementById('cart-empty-state');
    const itemsList = document.getElementById('cart-items-list');
    const summaryContainer = document.getElementById('cart-summary-container');
    const subtotalText = document.getElementById('cart-subtotal');
    const successOverlay = document.getElementById('cart-success-overlay');
    const successCloseBtn = document.getElementById('close-cart-success-btn');
    const form = document.getElementById('drawer-checkout-form') as HTMLFormElement;

    const openDrawer = () => {
      drawer?.classList.remove('translate-x-full');
      backdrop?.classList.remove('opacity-0', 'pointer-events-none');
      document.body.classList.add('overflow-hidden');
    };

    const closeDrawer = () => {
      drawer?.classList.add('translate-x-full');
      backdrop?.classList.add('opacity-0', 'pointer-events-none');
      document.body.classList.remove('overflow-hidden');
      successOverlay?.classList.add('translate-y-full'); 
    };

    window.addEventListener('open-cart-drawer', openDrawer);
    window.addEventListener('close-cart-drawer', closeDrawer);
    
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);
    successCloseBtn?.addEventListener('click', () => {
      closeDrawer();
      ShoppingCartManager.clearCart();
    });

    const renderCart = () => {
      const cart = ShoppingCartManager.getCart();
      const navBadges = document.querySelectorAll('.nav-cart-badge');
      const totalCount = cart.reduce((acc, i) => acc + i.qty, 0);

      navBadges.forEach(b => {
        b.textContent = totalCount.toString();
        if (totalCount > 0) {
          b.classList.remove('hidden');
        } else {
          b.classList.add('hidden');
        }
      });

      if (badgeCount) {
        badgeCount.textContent = `${cart.length} item${cart.length === 1 ? '' : 's'}`;
      }

      if (cart.length === 0) {
        emptyState?.classList.remove('hidden');
        itemsList?.classList.add('hidden');
        summaryContainer?.classList.add('hidden');
        return;
      }

      emptyState?.classList.add('hidden');
      itemsList?.classList.remove('hidden');
      summaryContainer?.classList.remove('hidden');

      const totalCost = cart.reduce((acc, i) => acc + (i.price * i.qty), 0);
      if (subtotalText) {
        subtotalText.textContent = `₹${totalCost.toFixed(2)}`;
      }

      if (itemsList) {
        itemsList.innerHTML = cart.map(item => `
          <div class="flex gap-4 p-4 border border-light-darker rounded-xl bg-white hover:border-slate-300 transition-colors relative group">
            
            <div class="h-16 w-20 shrink-0 rounded-lg overflow-hidden border border-light-darker bg-light">
              <img src="${item.image}" alt="${item.name}" class="h-full w-full object-cover" />
            </div>

            <div class="flex-grow space-y-1 font-sans">
              <h4 class="text-xs font-bold text-dark leading-snug pr-6 line-clamp-1">${item.name}</h4>
              <span class="block text-xs font-bold text-primary">₹${item.price.toFixed(2)}</span>

              <div class="flex items-center gap-2 pt-1.5 text-xs text-dark-muted font-medium">
                <span class="text-[9px] uppercase font-bold text-dark-muted">Quantity:</span>
                <input
                  type="number"
                  min="1"
                  value="${item.qty}"
                  data-slug="${item.slug}"
                  class="cart-qty-input w-14 rounded border border-light-darker bg-light/50 px-2 py-0.5 focus:bg-white focus:outline-none font-bold text-dark text-xs"
                />
              </div>
            </div>

            <button
              data-slug="${item.slug}"
              class="remove-cart-item-btn absolute top-3 right-3 text-dark-muted/40 hover:text-red-600 transition-colors p-1 rounded hover:bg-red-50 focus:outline-none"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>

          </div>
        `).join('');

        document.querySelectorAll('.cart-qty-input').forEach(input => {
          input.addEventListener('change', (e) => {
            const target = e.target as HTMLInputElement;
            const slug = target.getAttribute('data-slug') || '';
            let val = parseInt(target.value) || 1;
            if (val < 1) {
              val = 1;
              target.value = '1';
            }
            ShoppingCartManager.updateItemQty(slug, val);
          });
        });

        document.querySelectorAll('.remove-cart-item-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const target = (e.target as HTMLElement).closest('.remove-cart-item-btn');
            if (target) {
              const slug = target.getAttribute('data-slug') || '';
              ShoppingCartManager.removeItem(slug);
            }
          });
        });
      }
    };

    window.addEventListener('cart-updated', renderCart);
    renderCart();

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const cart = ShoppingCartManager.getCart();
      if (cart.length === 0) return;

      const name = (document.getElementById('checkout-name') as HTMLInputElement).value;
      const email = (document.getElementById('checkout-email') as HTMLInputElement).value;
      const phone = (document.getElementById('checkout-phone') as HTMLInputElement).value;
      const address = (document.getElementById('checkout-address') as HTMLTextAreaElement).value;

      const orderData = {
        customer: { name, email, phone, address },
        items: cart.map(i => ({
          slug: i.slug,
          name: i.name,
          qty: i.qty,
          price: i.price
        })),
        total: cart.reduce((acc, i) => acc + (i.price * i.qty), 0)
      };

      console.log('Placing Order:', orderData);
      
      setTimeout(() => {
        successOverlay?.classList.remove('translate-y-full');
        form.reset();
      }, 350);
    });

    document.body.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const addBtn = target.closest('[data-add-to-cart]');
      
      if (addBtn) {
        e.preventDefault();
        
        const slug = addBtn.getAttribute('data-slug') || '';
        const name = addBtn.getAttribute('data-name') || '';
        const image = addBtn.getAttribute('data-image') || '';
        const price = parseFloat(addBtn.getAttribute('data-price') || '0') || 0;
        
        let qty = 1;
        const qtyInput = document.querySelector(`.qty-input-field[data-slug="${slug}"]`) as HTMLInputElement;
        if (qtyInput) {
          qty = parseInt(qtyInput.value) || 1;
        }

        ShoppingCartManager.addItem({
          slug,
          name,
          image,
          price,
          qty
        });
      }
    });

  });
</script>
