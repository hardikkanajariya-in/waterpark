---
import config from '../data/config.json';
---

<!-- Slide-out Quote Drawer Backdrop -->
<div id="quote-drawer-backdrop" class="fixed inset-0 bg-slate-950/40 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300"></div>

<!-- Slide-out Drawer Panel -->
<div id="quote-drawer" class="fixed top-0 right-0 z-50 h-full w-full sm:w-[480px] bg-white border-l border-light-darker shadow-2xl transform translate-x-full transition-transform duration-300 flex flex-col font-sans">
  
  <!-- Drawer Header -->
  <div class="p-6 border-b border-light-darker flex items-center justify-between bg-slate-50">
    <div class="flex items-center space-x-2">
      <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <h2 class="text-base font-bold text-dark font-heading">Quote Inquiry Sheet</h2>
      <span id="quote-badge-count" class="bg-primary/10 text-primary text-[10px] font-extrabold px-2.5 py-0.5 rounded-full">0 items</span>
    </div>
    
    <button id="close-quote-drawer-btn" class="text-dark-muted hover:text-dark p-1 rounded-full hover:bg-light transition-all focus:outline-none">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Drawer Body (Scrollable items) -->
  <div id="quote-drawer-body" class="flex-grow overflow-y-auto p-6 space-y-6">
    <!-- Empty State -->
    <div id="quote-empty-state" class="text-center py-12 space-y-4">
      <div class="h-16 w-16 bg-light rounded-full flex items-center justify-center mx-auto text-dark-muted/40">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m-9 1V4a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
      </div>
      <h3 class="text-sm font-bold text-dark font-heading">No items in inquiry list</h3>
      <p class="text-xs text-dark-muted max-w-[280px] mx-auto leading-relaxed">
        Browse our catalog and add products to compile a bulk quotation inquiry.
      </p>
      <a href="/products" class="inline-flex justify-center rounded-full bg-primary px-5 py-2.5 text-xs font-bold text-white hover:bg-primary-dark transition-all">
        Browse Products
      </a>
    </div>

    <!-- Items List Container -->
    <div id="quote-items-list" class="space-y-4 hidden">
      <!-- Injected by Javascript -->
    </div>

    <!-- Inquiry Request Form Container -->
    <div id="quote-form-container" class="border-t border-light-darker pt-6 mt-6 hidden space-y-4">
      <h3 class="text-xs font-bold text-dark uppercase tracking-wider">Procurement Details</h3>
      
      <form id="drawer-inquiry-form" class="space-y-4">
        <div>
          <label for="drawer-name" class="block text-[10px] font-bold text-dark uppercase tracking-wider mb-1.5">Your Name *</label>
          <input
            type="text"
            id="drawer-name"
            required
            placeholder="John Doe"
            class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all"
          />
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="drawer-company" class="block text-[10px] font-bold text-dark uppercase tracking-wider mb-1.5">Company Name *</label>
            <input
              type="text"
              id="drawer-company"
              required
              placeholder="Apex Aquatics Ltd."
              class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all"
            />
          </div>
          <div>
            <label for="drawer-phone" class="block text-[10px] font-bold text-dark uppercase tracking-wider mb-1.5">Phone Number *</label>
            <input
              type="tel"
              id="drawer-phone"
              required
              placeholder="+1 (555) 019-9234"
              class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all"
            />
          </div>
        </div>

        <div>
          <label for="drawer-email" class="block text-[10px] font-bold text-dark uppercase tracking-wider mb-1.5">Corporate Email *</label>
          <input
            type="email"
            id="drawer-email"
            required
            placeholder="procurement@company.com"
            class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all"
          />
        </div>

        <div>
          <label for="drawer-message" class="block text-[10px] font-bold text-dark uppercase tracking-wider mb-1.5">Specific Requirements</label>
          <textarea
            id="drawer-message"
            rows="3"
            placeholder="Specify destination port, shipping urgency, or branding details..."
            class="w-full rounded-lg border border-light-darker bg-light px-3 py-2 text-xs focus:bg-white focus:border-primary focus:outline-none transition-all resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full inline-flex items-center justify-center rounded-full bg-primary py-3 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all"
        >
          Submit Bulk Quote Request
        </button>
      </form>
    </div>
  </div>

  <!-- Success Screen Overlay -->
  <div id="quote-success-overlay" class="absolute inset-0 bg-white z-20 flex flex-col items-center justify-center p-8 space-y-4 text-center transform translate-y-full transition-transform duration-300">
    <div class="h-16 w-16 bg-emerald-50 text-emerald-600 rounded-full flex items-center justify-center shadow-inner">
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-dark font-heading">Quote Sheet Submitted</h3>
    <p class="text-xs text-dark-muted max-w-[280px] leading-relaxed">
      Your inquiry list was sent to our procurement department. A representative will contact you with wholesale pricing terms.
    </p>
    <button id="close-success-overlay-btn" class="inline-flex justify-center rounded-full border border-light-darker bg-light px-6 py-2.5 text-xs font-bold text-dark hover:bg-white transition-all">
      Close Window
    </button>
  </div>
</div>

<script>
  interface QuoteItem {
    slug: string;
    name: string;
    image: string;
    moq: string;
    numericMoq: number;
    qty: number;
    printing: boolean;
    packaging: string;
  }

  // Quote Cart Manager Class
  class QuoteCartManager {
    static getCart(): QuoteItem[] {
      try {
        const data = localStorage.getItem('b2b_quote_cart');
        return data ? JSON.parse(data) : [];
      } catch (e) {
        return [];
      }
    }

    static saveCart(cart: QuoteItem[]) {
      try {
        localStorage.setItem('b2b_quote_cart', JSON.stringify(cart));
        window.dispatchEvent(new CustomEvent('quote-cart-updated'));
      } catch (e) {
        console.error("Failed to save quote cart state", e);
      }
    }

    static addItem(item: Omit<QuoteItem, 'qty' | 'printing' | 'packaging'> & { qty?: number; printing?: boolean; packaging?: string }) {
      const cart = this.getCart();
      const existing = cart.find(i => i.slug === item.slug);
      
      const targetQty = item.qty || item.numericMoq || 100;
      
      if (existing) {
        existing.qty = Math.max(existing.qty + (item.qty || 0), item.numericMoq);
        if (item.printing !== undefined) existing.printing = item.printing;
        if (item.packaging !== undefined) existing.packaging = item.packaging;
      } else {
        cart.push({
          slug: item.slug,
          name: item.name,
          image: item.image,
          moq: item.moq,
          numericMoq: item.numericMoq,
          qty: targetQty,
          printing: item.printing || false,
          packaging: item.packaging || 'standard'
        });
      }
      
      this.saveCart(cart);
      
      // Auto open drawer to show it was added
      setTimeout(() => {
        window.dispatchEvent(new CustomEvent('open-quote-drawer'));
      }, 50);
    }

    static removeItem(slug: string) {
      let cart = this.getCart();
      cart = cart.filter(i => i.slug !== slug);
      this.saveCart(cart);
    }

    static updateItemQty(slug: string, qty: number) {
      const cart = this.getCart();
      const item = cart.find(i => i.slug === slug);
      if (item) {
        item.qty = Math.max(qty, item.numericMoq);
        this.saveCart(cart);
      }
    }

    static updateItemPrinting(slug: string, printing: boolean) {
      const cart = this.getCart();
      const item = cart.find(i => i.slug === slug);
      if (item) {
        item.printing = printing;
        this.saveCart(cart);
      }
    }

    static updateItemPackaging(slug: string, packaging: string) {
      const cart = this.getCart();
      const item = cart.find(i => i.slug === slug);
      if (item) {
        item.packaging = packaging;
        this.saveCart(cart);
      }
    }

    static clearCart() {
      this.saveCart([]);
    }
  }

  // Bind globals
  (window as any).QuoteCart = QuoteCartManager;

  // DOM bindings
  document.addEventListener('DOMContentLoaded', () => {
    const drawer = document.getElementById('quote-drawer');
    const backdrop = document.getElementById('quote-drawer-backdrop');
    const closeBtn = document.getElementById('close-quote-drawer-btn');
    const openBtn = document.getElementById('open-quote-drawer-btn');
    
    const badgeCount = document.getElementById('quote-badge-count');
    const emptyState = document.getElementById('quote-empty-state');
    const itemsList = document.getElementById('quote-items-list');
    const formContainer = document.getElementById('quote-form-container');
    const successOverlay = document.getElementById('quote-success-overlay');
    const successCloseBtn = document.getElementById('close-success-overlay-btn');
    const form = document.getElementById('drawer-inquiry-form') as HTMLFormElement;

    const openDrawer = () => {
      drawer?.classList.remove('translate-x-full');
      backdrop?.classList.remove('opacity-0', 'pointer-events-none');
      document.body.classList.add('overflow-hidden');
    };

    const closeDrawer = () => {
      drawer?.classList.add('translate-x-full');
      backdrop?.classList.add('opacity-0', 'pointer-events-none');
      document.body.classList.remove('overflow-hidden');
      successOverlay?.classList.add('translate-y-full'); // Reset success overlay if open
    };

    // Global listeners
    window.addEventListener('open-quote-drawer', openDrawer);
    window.addEventListener('close-quote-drawer', closeDrawer);
    
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);
    successCloseBtn?.addEventListener('click', () => {
      closeDrawer();
      QuoteCartManager.clearCart();
    });

    // Render cart content
    const renderCart = () => {
      const cart = QuoteCartManager.getCart();
      
      // Update global badge indicators in navbar (if any)
      const navBadges = document.querySelectorAll('.nav-quote-badge');
      navBadges.forEach(b => {
        b.textContent = cart.length.toString();
        if (cart.length > 0) {
          b.classList.remove('hidden');
        } else {
          b.classList.add('hidden');
        }
      });

      if (badgeCount) {
        badgeCount.textContent = `${cart.length} item${cart.length === 1 ? '' : 's'}`;
      }

      if (cart.length === 0) {
        emptyState?.classList.remove('hidden');
        itemsList?.classList.add('hidden');
        formContainer?.classList.add('hidden');
        return;
      }

      emptyState?.classList.add('hidden');
      itemsList?.classList.remove('hidden');
      formContainer?.classList.remove('hidden');

      if (itemsList) {
        itemsList.innerHTML = cart.map(item => `
          <div class="flex gap-4 p-4 border border-light-darker rounded-xl bg-white hover:border-slate-300 transition-colors relative group">
            
            <!-- Product Photo -->
            <div class="h-20 w-24 shrink-0 rounded-lg overflow-hidden border border-light-darker bg-light">
              <img src="${item.image}" alt="${item.name}" class="h-full w-full object-cover" />
            </div>

            <!-- Content -->
            <div class="flex-grow space-y-2">
              <h4 class="text-xs font-bold text-dark font-heading leading-snug pr-6 line-clamp-1">${item.name}</h4>
              
              <!-- MOQ Badge -->
              <span class="inline-block text-[8px] font-extrabold text-primary-dark bg-primary-light px-1.5 py-0.5 rounded uppercase">MOQ: ${item.moq}</span>

              <!-- Configuration Rows -->
              <div class="grid grid-cols-2 gap-2 text-[10px] text-dark-muted font-medium pt-1">
                
                <!-- Qty Input -->
                <div class="flex flex-col gap-1">
                  <label class="font-bold text-[8px] uppercase tracking-wider text-dark-muted">Quantity</label>
                  <input
                    type="number"
                    min="${item.numericMoq}"
                    value="${item.qty}"
                    data-slug="${item.slug}"
                    class="qty-update-input w-full rounded border border-light-darker bg-light/50 px-2 py-1 focus:bg-white focus:outline-none font-bold text-dark"
                  />
                </div>

                <!-- Packaging Select -->
                <div class="flex flex-col gap-1">
                  <label class="font-bold text-[8px] uppercase tracking-wider text-dark-muted">Packaging</label>
                  <select
                    data-slug="${item.slug}"
                    class="packaging-update-select w-full rounded border border-light-darker bg-light/50 px-1 py-1 focus:bg-white focus:outline-none font-semibold text-dark"
                  >
                    <option value="standard" ${item.packaging === 'standard' ? 'selected' : ''}>Standard Bulk</option>
                    <option value="custom" ${item.packaging === 'custom' ? 'selected' : ''}>OEM Branded</option>
                    <option value="retail" ${item.packaging === 'retail' ? 'selected' : ''}>Retail Boxed</option>
                  </select>
                </div>
              </div>

              <!-- Custom Print Toggle -->
              <label class="flex items-center gap-1.5 text-[9px] font-bold text-dark-muted cursor-pointer select-none mt-2">
                <input
                  type="checkbox"
                  data-slug="${item.slug}"
                  class="printing-update-checkbox rounded border-light-darker text-primary focus:ring-primary h-3.5 w-3.5"
                  ${item.printing ? 'checked' : ''}
                />
                Custom Logo Printing (+ MOQ Setup)
              </label>
            </div>

            <!-- Remove Button -->
            <button
              data-slug="${item.slug}"
              class="remove-cart-item-btn absolute top-3 right-3 text-dark-muted/50 hover:text-red-600 transition-colors p-1 rounded hover:bg-red-50 focus:outline-none"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
            </button>

          </div>
        `).join('');

        // Attach event listeners to newly generated inputs
        document.querySelectorAll('.qty-update-input').forEach(input => {
          input.addEventListener('change', (e) => {
            const target = e.target as HTMLInputElement;
            const slug = target.getAttribute('data-slug') || '';
            let val = parseInt(target.value) || 0;
            const min = parseInt(target.getAttribute('min') || '0');
            if (val < min) {
              val = min;
              target.value = val.toString();
            }
            QuoteCartManager.updateItemQty(slug, val);
          });
        });

        document.querySelectorAll('.packaging-update-select').forEach(select => {
          select.addEventListener('change', (e) => {
            const target = e.target as HTMLSelectElement;
            const slug = target.getAttribute('data-slug') || '';
            QuoteCartManager.updateItemPackaging(slug, target.value);
          });
        });

        document.querySelectorAll('.printing-update-checkbox').forEach(checkbox => {
          checkbox.addEventListener('change', (e) => {
            const target = e.target as HTMLInputElement;
            const slug = target.getAttribute('data-slug') || '';
            QuoteCartManager.updateItemPrinting(slug, target.checked);
          });
        });

        document.querySelectorAll('.remove-cart-item-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const target = (e.target as HTMLElement).closest('.remove-cart-item-btn');
            if (target) {
              const slug = target.getAttribute('data-slug') || '';
              QuoteCartManager.removeItem(slug);
            }
          });
        });
      }
    };

    // Listen for state change
    window.addEventListener('quote-cart-updated', renderCart);

    // Initial render
    renderCart();

    // Form Submission
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const cart = QuoteCartManager.getCart();
      if (cart.length === 0) return;

      const name = (document.getElementById('drawer-name') as HTMLInputElement).value;
      const company = (document.getElementById('drawer-company') as HTMLInputElement).value;
      const phone = (document.getElementById('drawer-phone') as HTMLInputElement).value;
      const email = (document.getElementById('drawer-email') as HTMLInputElement).value;
      const message = (document.getElementById('drawer-message') as HTMLTextAreaElement).value;

      const inquiryData = {
        sender: { name, company, phone, email, message },
        items: cart.map(i => ({
          slug: i.slug,
          name: i.name,
          quantity: i.qty,
          printing: i.printing,
          packaging: i.packaging
        }))
      };

      console.log('Sending B2B Inquiry:', inquiryData);
      
      // Simulate API call
      setTimeout(() => {
        successOverlay?.classList.remove('translate-y-full');
        form.reset();
      }, 350);
    });

    // Handle quick add selectors from click listeners on body
    document.body.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      
      // Detect clicks on buttons with "data-add-to-quote"
      const addBtn = target.closest('[data-add-to-quote]');
      if (addBtn) {
        e.preventDefault();
        
        const slug = addBtn.getAttribute('data-slug') || '';
        const name = addBtn.getAttribute('data-name') || '';
        const image = addBtn.getAttribute('data-image') || '';
        const moq = addBtn.getAttribute('data-moq') || '100 units';
        const numericMoq = parseInt(addBtn.getAttribute('data-numeric-moq') || '100') || 100;
        
        let qty = numericMoq;
        
        // Check if there is an input field for quantity nearby
        const qtyInput = document.querySelector(`.qty-input-field[data-slug="${slug}"]`) as HTMLInputElement;
        if (qtyInput) {
          qty = parseInt(qtyInput.value) || numericMoq;
        }

        // Check if print options are selected
        const printCheckbox = document.querySelector(`.print-checkbox-field[data-slug="${slug}"]`) as HTMLInputElement;
        const printing = printCheckbox ? printCheckbox.checked : false;

        const pkgSelect = document.querySelector(`.packaging-select-field[data-slug="${slug}"]`) as HTMLSelectElement;
        const packaging = pkgSelect ? pkgSelect.value : 'standard';

        QuoteCartManager.addItem({
          slug,
          name,
          image,
          moq,
          numericMoq,
          qty,
          printing,
          packaging
        });
      }
    });

  });
</script>
