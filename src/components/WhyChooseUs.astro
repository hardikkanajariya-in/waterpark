---
const features = [
  {
    title: "Direct-to-Enterprise Capacity",
    description: "Operate massive high-output manufacturing lines with a streamlined B2B logistics model for international delivery.",
    icon: "factory"
  },
  {
    title: "Complete OEM & Branding Customization",
    description: "Provide in-factory custom screen-printing, molded logo integration, safety warning stencils, and Pantone matching.",
    icon: "adjustments"
  },
  {
    title: "Certified International Safety Standards",
    description: "Fully compliant with FINA, USCG, CE, ASTM, and ISO 9001 regulations to guarantee commercial compliance.",
    icon: "shield-check"
  },
  {
    title: "Rigorous Batch Quality Testing",
    description: "Conduct pressure seals, tear-resistance, and UV degradation tests in our state-of-the-art laboratory on all batches.",
    icon: "beaker"
  }
];
---

<section class="bg-light py-20 lg:py-28 border-y border-light-darker">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center lg:gap-8">
      
      <!-- Copy column -->
      <div class="lg:col-span-5 space-y-6">
        <h2 class="text-xs font-bold uppercase tracking-widest text-primary">
          Manufacturing Excellence
        </h2>
        <p class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl font-heading leading-tight">
          Why Procurement Officers Partner With Us
        </p>
        <div class="h-1 w-16 bg-primary rounded-full"></div>
        <p class="text-lg text-dark-muted font-sans leading-relaxed">
          We operate as a vertical manufacturing partner. By handling design, raw materials, molding, branding, and testing in-house, we eliminate secondary supply-chain markup and guarantee top-tier B2B quality control.
        </p>
        <div class="pt-4">
          <a
            href="/about"
            class="inline-flex items-center justify-center rounded-full bg-white border border-light-darker px-6 py-3.5 text-sm font-semibold text-dark hover:bg-light hover:text-primary transition-all duration-200"
          >
            Our Facility Tour
          </a>
        </div>
      </div>
      
      <!-- Grid features column -->
      <div class="lg:col-span-7 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {features.map((item) => (
          <div class="rounded-2xl border border-light-darker bg-white p-8 shadow-soft">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-light text-primary mb-6">
              {item.icon === "factory" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              )}
              {item.icon === "adjustments" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                </svg>
              )}
              {item.icon === "shield-check" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {item.icon === "beaker" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
              )}
            </div>
            <h3 class="text-lg font-bold text-dark font-heading mb-3">
              {item.title}
            </h3>
            <p class="text-sm text-dark-muted font-sans leading-relaxed">
              {item.description}
            </p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
