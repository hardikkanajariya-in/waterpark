---
---

<section class="relative overflow-hidden bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center lg:gap-8">
      
      <!-- Text content -->
      <div class="space-y-8 lg:col-span-6 slide-up">
        <div class="inline-flex items-center gap-2.5 rounded-full bg-primary/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary">
          <span class="flex h-2 w-2 rounded-full bg-primary animate-pulse"></span>
          Direct-to-Enterprise Manufacturer
        </div>
        
        <h1 class="text-4xl font-extrabold tracking-tight text-dark sm:text-5xl lg:text-6xl leading-[1.1] font-heading">
          Premium Aquatic Equipment <br class="hidden sm:inline" />
          <span class="text-primary font-bold">Engineered for Scale</span>
        </h1>
        
        <p class="text-lg text-dark-muted leading-relaxed font-sans max-w-xl">
          We manufacture and supply high-durability goggles, caps, waterproof covers, and commercial pool infrastructure. Built to rigorous safety standards for water parks, academies, and resorts worldwide.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/products"
            class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-sm font-semibold text-white shadow-soft hover:bg-primary-dark hover:shadow-soft-lg transition-all duration-200"
          >
            Browse Catalog
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-light-darker bg-white px-8 py-4 text-sm font-semibold text-dark hover:bg-light hover:text-primary transition-all duration-200"
          >
            Request B2B Quote
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="pt-6 border-t border-light-darker grid grid-cols-3 gap-4">
          <div>
            <span class="block text-2xl font-bold text-dark font-heading">ISO 9001</span>
            <span class="block text-xs text-dark-muted font-sans font-medium uppercase tracking-wider mt-1">Certified Plant</span>
          </div>
          <div>
            <span class="block text-2xl font-bold text-dark font-heading">150+</span>
            <span class="block text-xs text-dark-muted font-sans font-medium uppercase tracking-wider mt-1">Enterprise Clients</span>
          </div>
          <div>
            <span class="block text-2xl font-bold text-dark font-heading">20+</span>
            <span class="block text-xs text-dark-muted font-sans font-medium uppercase tracking-wider mt-1">Countries Served</span>
          </div>
        </div>
      </div>
      
      <!-- Visual side -->
      <div class="relative lg:col-span-6 fade-in">
        <div class="relative mx-auto max-w-[540px] lg:max-w-none">
          <!-- Outer border ring -->
          <div class="absolute -inset-4 rounded-3xl border border-light-darker/50 -rotate-2"></div>
          
          <!-- Image Container -->
          <div class="relative overflow-hidden rounded-2xl bg-light shadow-soft-xl border border-light-darker">
            <img
              src="/images/hero.png"
              alt="State of the art swimming pool equipment installation"
              class="h-[350px] w-full object-cover sm:h-[450px] hover:scale-105 transition-transform duration-700"
              loading="eager"
            />
          </div>
          
          <!-- Floating highlight card -->
          <div class="absolute -bottom-6 -left-6 hidden sm:flex items-center gap-4 rounded-2xl bg-white p-5 shadow-soft-lg border border-light-darker max-w-[280px]">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <span class="block text-sm font-bold text-dark font-heading">Commercial Durability</span>
              <span class="block text-xs text-dark-muted font-sans mt-0.5">Heavy-duty materials built for daily public use.</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
