---
import categories from "../data/categories.json";
import applications from "../data/applications.json";
import config from "../data/config.json";

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-slate-300 border-t border-slate-900 font-sans">
  <!-- Main Grid -->
  <div class="mx-auto max-w-7xl px-6 py-20 md:px-8 lg:py-24">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 lg:gap-8">
      
      <!-- Brand & Profile -->
      <div class="space-y-6 lg:col-span-1">
        <a href="/" class="flex flex-col items-start leading-none group">
          <span class="font-heading text-2xl font-extrabold tracking-wider text-white">
            {config.brandName}
          </span>
          <span class="text-[9px] font-bold tracking-[0.25em] text-primary uppercase mt-0.5">
            Retail Store
          </span>
        </a>
        <p class="text-xs text-slate-400 leading-relaxed font-medium">
          India's premium online store for high-quality swimming caps, goggles, training accessories, and water park float tubes.
        </p>
        
        <!-- Quality Badges -->
        <div class="pt-2 space-y-2">
          <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500 block">Quality Assured</span>
          <div class="flex flex-wrap gap-1.5 font-semibold text-slate-300">
            <span class="px-2 py-1 rounded bg-slate-900 border border-slate-800 text-[9px]">Fast Delivery</span>
            <span class="px-2 py-1 rounded bg-slate-900 border border-slate-800 text-[9px]">100% Original</span>
          </div>
        </div>
      </div>

      <!-- Categories Links -->
      <div>
        <h3 class="font-heading text-xs font-bold uppercase tracking-widest text-white mb-6">
          Categories
        </h3>
        <ul class="space-y-3 text-xs font-semibold">
          {categories.map((cat) => (
            <li>
              <a
                href={`/products?category=${cat.slug}`}
                class="text-slate-400 hover:text-white transition-colors duration-150"
              >
                {cat.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Applications Links -->
      <div>
        <h3 class="font-heading text-xs font-bold uppercase tracking-widest text-white mb-6">
          Use Cases
        </h3>
        <ul class="space-y-3 text-xs font-semibold">
          {applications.map((app) => (
            <li>
              <a
                href={`/products?category=swimming-goggles`}
                class="text-slate-400 hover:text-white transition-colors duration-150"
              >
                {app.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources & Support -->
      <div>
        <h3 class="font-heading text-xs font-bold uppercase tracking-widest text-white mb-6">
          Support
        </h3>
        <ul class="space-y-3 text-xs font-semibold">
          <li>
            <a href="/downloads" class="text-slate-400 hover:text-white transition-colors">Store Downloads</a>
          </li>
          <li>
            <a href="/brands" class="text-slate-400 hover:text-white transition-colors">Brands</a>
          </li>
          <li>
            <a href="/faq" class="text-slate-400 hover:text-white transition-colors">Help & FAQs</a>
          </li>
          <li>
            <a href="/about" class="text-slate-400 hover:text-white transition-colors">About Our Store</a>
          </li>
          <li>
            <a href="/contact" class="text-slate-400 hover:text-white transition-colors">Contact Support</a>
          </li>
        </ul>
      </div>

      <!-- Contact Coordinates -->
      <div class="space-y-6">
        <div>
          <h3 class="font-heading text-xs font-bold uppercase tracking-widest text-white mb-6">
            Store Contact
          </h3>
          <ul class="space-y-3 text-xs text-slate-400 font-semibold">
            <li class="flex items-start">
              <svg class="h-4 w-4 text-primary shrink-0 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <span>{config.contact.address}</span>
            </li>
            <li class="flex items-center">
              <svg class="h-4 w-4 text-primary shrink-0 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${config.contact.phoneRaw}`} class="hover:text-white transition-colors">
                {config.contact.phone}
              </a>
            </li>
            <li class="flex items-center">
              <svg class="h-4 w-4 text-primary shrink-0 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${config.contact.email}`} class="hover:text-white transition-colors font-medium">
                {config.contact.email}
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Legal & Copyright -->
  <div class="border-t border-slate-900 bg-slate-950 px-6 py-6 md:px-8">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-4 text-[11px] text-slate-500 font-semibold">
      <div class="space-y-1 md:space-y-0 text-center md:text-left">
        <span>&copy; {currentYear} {config.brandName} Online Store. All rights reserved.</span>
        <span class="block md:inline md:ml-4 text-slate-600">|</span>
        <a href="https://hardikkanajariya.in" target="_blank" rel="noopener noreferrer" class="block md:inline md:ml-4 hover:text-white transition-colors text-primary font-bold">
          hardikkanajariya.in
        </a>
      </div>
      <div class="flex space-x-6">
        <a href="/downloads" class="hover:text-white transition-colors">Resources</a>
        <a href="/faq" class="hover:text-white transition-colors">Help Desk</a>
        <a href="/contact" class="hover:text-white transition-colors">Store Location</a>
      </div>
    </div>
  </div>
</footer>
