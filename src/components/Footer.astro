---
import categories from "../data/categories.json";
import industries from "../data/industries.json";

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white border-t border-slate-800">
  <!-- Top Section: Links & Info -->
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-8 lg:py-20">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-4 lg:gap-8">
      
      <!-- Column 1: Company Profile -->
      <div class="space-y-6">
        <a href="/" class="flex flex-col items-start leading-none">
          <span class="font-heading text-2xl font-extrabold tracking-wider text-white">
            AQUADURA
          </span>
          <span class="text-[9px] font-semibold tracking-[0.25em] text-secondary uppercase mt-0.5">
            Commercial Aquatics
          </span>
        </a>
        <p class="font-sans text-sm text-slate-300 leading-relaxed max-w-xs">
          World-class B2B manufacturing and global supply of premium swimming pools, commercial water parks, and athletic training equipment.
        </p>
        <!-- Certification Badges -->
        <div class="pt-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-400 block mb-3">
            Standards & Certifications
          </span>
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded bg-slate-800 px-2 py-1 text-[10px] font-bold text-slate-200 border border-slate-700">
              ISO 9001:2015
            </span>
            <span class="inline-flex items-center rounded bg-slate-800 px-2 py-1 text-[10px] font-bold text-slate-200 border border-slate-700">
              CE COMPLIANT
            </span>
            <span class="inline-flex items-center rounded bg-slate-800 px-2 py-1 text-[10px] font-bold text-slate-200 border border-slate-700">
              BSCI AUDITED
            </span>
          </div>
        </div>
      </div>

      <!-- Column 2: Product Categories -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-secondary">
          Product Divisions
        </h3>
        <ul class="mt-6 space-y-3.5">
          {categories.slice(0, 6).map((cat) => (
            <li>
              <a
                href={`/products?category=${cat.slug}`}
                class="font-sans text-sm text-slate-300 hover:text-white transition-colors duration-150"
              >
                {cat.name}
              </a>
            </li>
          ))}
          {categories.length > 6 && (
            <li>
              <a href="/categories" class="font-sans text-sm text-secondary hover:text-white font-medium transition-colors duration-150">
                View All Categories &rarr;
              </a>
            </li>
          )}
        </ul>
      </div>

      <!-- Column 3: Industries Served -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-secondary">
          Target Sectors
        </h3>
        <ul class="mt-6 space-y-3.5">
          {industries.map((ind) => (
            <li>
              <a
                href="/about#industries"
                class="font-sans text-sm text-slate-300 hover:text-white transition-colors duration-150"
              >
                {ind.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Manufacturing Head Office -->
      <div class="space-y-6">
        <div>
          <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-secondary">
            Global Headquarters
          </h3>
          <ul class="mt-6 space-y-3.5 font-sans text-sm text-slate-300">
            <li class="flex items-start">
              <svg class="h-5 w-5 text-secondary shrink-0 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>Industrial Sector-4, Plot 89-B, Manufacturing Hub, TX 75001</span>
            </li>
            <li class="flex items-center">
              <svg class="h-5 w-5 text-secondary shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href="tel:+18005550199" class="hover:text-white transition-colors duration-150">
                +1 (800) 555-0199
              </a>
            </li>
            <li class="flex items-center">
              <svg class="h-5 w-5 text-secondary shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href="mailto:supply@aquadura.com" class="hover:text-white transition-colors duration-150">
                supply@aquadura.com
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Section: Legal & Copyright -->
  <div class="border-t border-slate-800 bg-slate-950 px-6 py-6 md:px-8">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row items-center justify-between gap-4 font-sans text-xs text-slate-400">
      <div>
        &copy; {currentYear} Aquadura Commercial Aquatics. All rights reserved.
      </div>
      <div class="flex space-x-6">
        <a href="/about" class="hover:text-white transition-colors duration-150">Manufacturing Facilities</a>
        <a href="/contact" class="hover:text-white transition-colors duration-150">Quality Guarantee</a>
        <a href="/products" class="hover:text-white transition-colors duration-150">Wholesale Terms</a>
      </div>
    </div>
  </div>
</footer>
