---
import products from '../data/products.json';
import categories from '../data/categories.json';

// Get 6 featured products (one from each primary category)
const featuredProducts = products.filter(p => 
  ["apex-racing-goggles", "pro-silicone-racing-cap", "floating-dry-bag-phone-pouch", "rfid-locker-key-wristband", "anti-wave-racing-lane-rope", "double-rider-commercial-water-tube"].includes(p.slug)
);

const getCategoryName = (catSlug: string) => {
  return categories.find(c => c.slug === catSlug)?.name || "";
};
---

<section class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div class="space-y-4 max-w-2xl">
        <h2 class="text-xs font-bold uppercase tracking-widest text-primary">
          Core Catalogue
        </h2>
        <p class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl font-heading">
          Featured Enterprise Products
        </p>
        <div class="h-1 w-16 bg-primary rounded-full mt-2"></div>
      </div>
      <div>
        <a 
          href="/products" 
          class="inline-flex items-center text-sm font-bold text-primary hover:text-primary-dark tracking-wide font-sans group"
        >
          View Full Catalogue ({products.length} Products)
          <svg class="ml-1.5 h-4 w-4 transform group-hover:translate-x-1 transition-transform duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {featuredProducts.map((product) => (
        <div
          class="group flex flex-col justify-between overflow-hidden rounded-2xl bg-white border border-light-darker shadow-soft hover:shadow-soft-lg transition-all duration-300"
        >
          <div>
            <!-- Product Image -->
            <div class="relative h-64 w-full overflow-hidden bg-light border-b border-light-darker">
              <img
                src={product.image}
                alt={product.name}
                class="h-full w-full object-cover group-hover:scale-102 transition-transform duration-500"
                loading="lazy"
              />
              <span class="absolute top-4 left-4 rounded-full bg-white px-3.5 py-1 text-xs font-bold text-dark border border-light-darker shadow-soft uppercase tracking-wider font-sans">
                {getCategoryName(product.category)}
              </span>
            </div>

            <!-- Content -->
            <div class="p-6 space-y-4">
              <h3 class="text-xl font-bold text-dark group-hover:text-primary transition-colors duration-150 font-heading">
                {product.name}
              </h3>
              <p class="text-sm text-dark-muted leading-relaxed font-sans line-clamp-3">
                {product.description}
              </p>
              
              <!-- Core Specifications / Features -->
              <ul class="space-y-2 pt-2 border-t border-light-darker">
                {product.features.slice(0, 2).map((feat) => (
                  <li class="flex items-center text-xs text-dark-muted font-sans font-medium">
                    <svg class="h-4 w-4 text-primary shrink-0 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    {feat}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Bottom Footer Area -->
          <div class="p-6 pt-0 flex items-center justify-between border-t border-light-darker/60 mt-4 bg-light/30">
            <div class="font-sans">
              <span class="block text-[10px] font-bold text-dark-muted uppercase tracking-wider">Min. Order (MOQ)</span>
              <span class="text-xs font-extrabold text-dark">{product.moq}</span>
            </div>
            <div class="flex gap-2">
              <a
                href={`/products/${product.slug}`}
                class="inline-flex items-center justify-center rounded-full bg-white border border-light-darker px-4 py-2 text-xs font-semibold text-dark hover:bg-light hover:text-primary transition-all duration-150"
              >
                Specifications
              </a>
              <a
                href={`/products/${product.slug}#quote`}
                class="inline-flex items-center justify-center rounded-full bg-primary px-4 py-2 text-xs font-semibold text-white shadow-soft hover:bg-primary-dark transition-all duration-150"
              >
                Get Quote
              </a>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
