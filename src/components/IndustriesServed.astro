---
import industries from '../data/industries.json';
---

<section class="bg-white py-20 lg:py-28" id="industries">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    
    <!-- Section Header -->
    <div class="mx-auto max-w-3xl text-center space-y-4 mb-16">
      <h2 class="text-xs font-bold uppercase tracking-widest text-primary">
        Target Markets
      </h2>
      <p class="text-3xl font-extrabold tracking-tight text-dark sm:text-4xl font-heading">
        Industries We Serve globally
      </p>
      <div class="h-1 w-16 bg-primary mx-auto rounded-full mt-4"></div>
      <p class="text-lg text-dark-muted font-sans mt-2 max-w-2xl mx-auto">
        Our products are customized to satisfy the unique standards, durability constraints, and purchase quantities of various B2B sectors.
      </p>
    </div>

    <!-- Industries Grid -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {industries.map((ind) => (
        <div class="group relative rounded-2xl border border-light-darker bg-white p-8 shadow-soft hover:shadow-soft-lg hover:-translate-y-0.5 transition-all duration-300">
          <div class="flex items-center gap-4 mb-6">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary-light text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              {ind.icon === "water-park" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
              {ind.icon === "academy" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              )}
              {ind.icon === "school" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              )}
              {ind.icon === "hotel" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
              )}
              {ind.icon === "distributor" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
              )}
              {ind.icon === "government" && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-dark font-heading group-hover:text-primary transition-colors duration-150">
              {ind.name}
            </h3>
          </div>
          <p class="text-sm text-dark-muted font-sans leading-relaxed">
            {ind.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
