---
import config from "../data/config.json";

const navLinks = [
  { href: "/products", label: "Shop All" },
  { href: "/products?category=swimming-goggles", label: "Goggles" },
  { href: "/products?category=swimming-caps", label: "Caps" },
  { href: "/products?category=water-park-tubes", label: "Tubes" },
  { href: "/products?category=pool-equipment", label: "Pool Hardware" },
  { href: "/team-branding", label: "Team Branding" },
  { href: "/contact", label: "Contact" },
];
---

<header 
  class="sticky top-0 w-full border-b border-light-darker bg-white/95 backdrop-blur-md transition-all duration-300 shadow-sm"
  style="z-index: 9999;"
>
  <!-- Thin Top Announcement Strip -->
  <div class="bg-dark text-slate-400 text-[11px] py-2 px-6 md:px-8 border-b border-slate-800">
    <div class="mx-auto max-w-7xl flex justify-between items-center">
      <div class="flex items-center space-x-4">
        <span class="font-medium text-slate-300">Free nationwide delivery on orders over $50</span>
      </div>
      <div class="flex items-center space-x-4 font-semibold text-white">
        <a href={`tel:${config.contact.phoneRaw}`} class="hover:text-primary transition-colors">{config.contact.phone}</a>
        <span class="text-slate-700">|</span>
        <a href="/contact" class="hover:text-primary transition-colors">Support Desk</a>
      </div>
    </div>
  </div>

  <!-- Main Navigation Bar -->
  <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-4 md:px-8">
    
    <!-- Logo -->
    <a href="/" class="flex flex-col items-start leading-none group shrink-0">
      <span class="font-heading text-xl font-bold tracking-wider text-dark group-hover:text-primary transition-colors duration-200">
        {config.brandName}
      </span>
      <span class="text-[9px] font-bold tracking-[0.25em] text-primary uppercase mt-0.5">
        Retail Store
      </span>
    </a>

    <!-- Flat Category Links (No massive dropdowns) -->
    <nav class="hidden lg:flex items-center space-x-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-sans text-xs font-semibold text-dark-muted hover:text-primary transition-colors duration-150"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right-side actions: Search and Cart -->
    <div class="flex items-center space-x-4">
      
      <!-- Search Input -->
      <form action="/products" method="GET" class="relative group/search hidden sm:block">
        <input
          type="text"
          name="search"
          placeholder="Search products..."
          class="w-36 rounded-full border border-light-darker bg-light/85 px-4 py-1.5 text-xs text-dark placeholder:text-dark-muted/60 focus:w-48 focus:bg-white focus:outline-none transition-all duration-300 font-medium"
        />
        <button type="submit" class="absolute right-3 top-2 text-dark-muted hover:text-primary focus:outline-none">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </form>
      
      <!-- Shopping Cart Button with Count Badge -->
      <button
        type="button"
        id="desktop-cart-trigger"
        class="relative inline-flex items-center justify-center rounded-full bg-light border border-light-darker p-2.5 text-dark hover:text-primary hover:bg-white hover:border-slate-300 transition-all focus:outline-none"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <span class="nav-cart-badge absolute -top-1 -right-1 bg-primary text-white text-[9px] font-bold h-5 w-5 rounded-full flex items-center justify-center hidden">0</span>
      </button>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="inline-flex items-center justify-center p-2 rounded-lg text-dark hover:bg-light hover:text-primary focus:outline-none lg:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="sr-only">Open main menu</span>
        <!-- Menu Icon -->
        <svg id="menu-icon-open" class="h-5 w-5 block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <!-- Close Icon -->
        <svg id="menu-icon-close" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Panel -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-light-darker bg-white px-6 py-6 shadow-soft">
    <div class="space-y-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block rounded-lg px-3 py-2 text-sm font-semibold text-dark hover:bg-light hover:text-primary transition-colors"
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile Search -->
      <form action="/products" method="GET" class="relative pt-2">
        <input
          type="text"
          name="search"
          placeholder="Search products..."
          class="w-full rounded-full border border-light-darker bg-light px-4 py-2 text-xs text-dark placeholder:text-dark-muted/60 focus:bg-white focus:outline-none transition-all"
        />
      </form>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  if (toggleBtn && mobileMenu && openIcon && closeIcon) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      
      toggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      mobileMenu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  }

  // Trigger side drawer event
  const openCart = () => {
    window.dispatchEvent(new CustomEvent('open-cart-drawer'));
  };

  document.getElementById('desktop-cart-trigger')?.addEventListener('click', openCart);
</script>
