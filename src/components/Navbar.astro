---
import categories from "../data/categories.json";
import config from "../data/config.json";

const navLinks = [
  { href: "/products", label: "Catalogue" },
  { href: "/team-branding", label: "Custom Branding" },
  { href: "/applications", label: "Applications" },
  { href: "/gallery", label: "Gallery" },
  { href: "/faq", label: "FAQ" },
  { href: "/about", label: "About" },
];
---

<header class="sticky top-0 z-9999 w-full border-b border-light-darker bg-white/90 backdrop-blur-md transition-all duration-300">
  
  <!-- Thin Info Bar (B2B Highlights) -->
  <div class="bg-dark text-slate-400 text-[11px] py-2 px-6 md:px-8 border-b border-slate-800">
    <div class="mx-auto max-w-7xl flex justify-between items-center">
      <div class="flex items-center space-x-4">
        <span class="font-medium">Global Supplier & Wholesaler</span>
        <span class="hidden sm:inline text-slate-700">|</span>
        <span class="hidden sm:inline font-medium">Certified Industrial Standard Materials</span>
      </div>
      <div class="flex items-center space-x-4 font-semibold text-white">
        <a href={`tel:${config.contact.phoneRaw}`} class="hover:text-primary transition-colors">{config.contact.phone}</a>
        <span class="text-slate-700">|</span>
        <a 
          href={`https://wa.me/${config.contact.whatsapp}?text=${encodeURIComponent(config.contact.whatsappMsg)}`} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center text-emerald-400 hover:text-emerald-300 transition-colors"
        >
          <svg class="h-3.5 w-3.5 mr-1" fill="currentColor" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.458L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.864-9.864.002-2.637-1.019-5.117-2.875-6.976C16.592 1.905 14.12 1.88 11.48 1.882c-5.436 0-9.862 4.422-9.865 9.867-.001 1.737.472 3.427 1.372 4.908l-.946 3.456 3.546-.931c1.472.8 3.085 1.218 4.673 1.218z"/>
          </svg>
          WhatsApp B2B Support
        </a>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl flex items-center justify-between px-6 py-3.5 md:px-8">
    
    <!-- Brand Logo -->
    <a href="/" class="flex flex-col items-start leading-none group shrink-0">
      <span class="font-heading text-xl sm:text-2xl font-black tracking-wider text-dark group-hover:text-primary transition-colors duration-200">
        {config.brandName}
      </span>
      <span class="text-[9px] font-extrabold tracking-[0.25em] text-primary uppercase mt-0.5">
        B2B Commerce
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center space-x-6">
      
      <!-- Products dropdown mega menu (Vanilla CSS hover action) -->
      <div class="relative group">
        <a
          href="/products"
          class="inline-flex items-center font-sans text-xs lg:text-sm font-bold text-dark hover:text-primary py-2 transition-colors duration-150"
        >
          Divisions
          <svg class="ml-1 h-3.5 w-3.5 text-dark-muted group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </a>

        <!-- Mega Menu dropdown panel -->
        <div class="absolute left-1/2 -translate-x-1/2 top-full hidden group-hover:block w-[720px] bg-white border border-light-darker rounded-2xl shadow-soft-lg p-6 grid grid-cols-2 gap-4 animate-fade-in mt-1 z-50">
          <div class="col-span-2 border-b border-light-darker pb-2 mb-2">
            <span class="text-[10px] font-extrabold uppercase tracking-widest text-primary font-heading">Product Divisions & Catalogue</span>
          </div>
          {categories.map(cat => (
            <a
              href={`/products?category=${cat.slug}`}
              class="flex items-start p-3 rounded-xl hover:bg-light transition-all group/item"
            >
              <div class="flex-grow font-sans text-xs">
                <span class="block font-bold text-dark group-hover/item:text-primary transition-colors">{cat.name}</span>
                <span class="block text-dark-muted leading-relaxed mt-0.5 line-clamp-1">{cat.description}</span>
              </div>
            </a>
          ))}
          <div class="col-span-2 pt-2 border-t border-light-darker text-center bg-light/35 rounded-b-xl -mx-6 -mb-6 p-4">
            <a href="/products" class="font-sans text-xs font-bold text-primary hover:underline">
              View Full Product Catalog ({categories.length} Divisions) &rarr;
            </a>
          </div>
        </div>
      </div>

      <!-- Other links -->
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-sans text-xs lg:text-sm font-bold text-dark-muted hover:text-primary transition-colors duration-150"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right-side actions -->
    <div class="hidden md:flex items-center space-x-4">
      
      <!-- Search Form -->
      <form action="/products" method="GET" class="relative group/search hidden lg:block">
        <input
          type="text"
          name="search"
          placeholder="Search catalog..."
          class="w-40 rounded-full border border-light-darker bg-light/85 px-4 py-1.5 text-xs text-dark placeholder:text-dark-muted/60 focus:w-52 focus:bg-white focus:outline-none transition-all duration-300"
        />
        <button type="submit" class="absolute right-3 top-2 text-dark-muted hover:text-primary">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
      </form>
      
      <!-- Quote Cart Trigger Button (Desktop) -->
      <button
        type="button"
        id="desktop-quote-drawer-trigger"
        class="relative inline-flex items-center justify-center rounded-full bg-light border border-light-darker p-2.5 text-dark hover:text-primary hover:bg-white hover:border-slate-300 transition-all focus:outline-none"
      >
        <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <span class="nav-quote-badge absolute -top-1 -right-1 bg-primary text-white text-[9px] font-black h-4.5 w-4.5 rounded-full flex items-center justify-center hidden">0</span>
      </button>

      <button
        type="button"
        class="open-inquiry-direct-btn inline-flex items-center justify-center rounded-full bg-primary px-5 py-2.5 text-xs font-bold text-white shadow-soft hover:bg-primary-dark transition-all duration-200"
      >
        Direct Inquiry
      </button>
    </div>

    <!-- Mobile Menu / Cart Actions -->
    <div class="flex items-center space-x-2 md:hidden">
      <!-- Quote Cart Trigger Button (Mobile) -->
      <button
        type="button"
        id="mobile-quote-drawer-trigger"
        class="relative inline-flex items-center justify-center rounded-full bg-light border border-light-darker p-2 text-dark hover:text-primary hover:bg-white focus:outline-none"
      >
        <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <span class="nav-quote-badge absolute -top-1 -right-1 bg-primary text-white text-[9px] font-black h-4 w-4 rounded-full flex items-center justify-center hidden">0</span>
      </button>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="inline-flex items-center justify-center p-2 rounded-lg text-dark hover:bg-light hover:text-primary focus:outline-none"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="sr-only">Open main menu</span>
        <!-- Menu Icon -->
        <svg id="menu-icon-open" class="h-6 w-6 block" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <!-- Close Icon -->
        <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation Panel -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-light-darker bg-white px-6 py-6 shadow-soft">
    <div class="space-y-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block rounded-lg px-3 py-2 text-base font-bold text-dark hover:bg-light hover:text-primary transition-colors"
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile Search -->
      <form action="/products" method="GET" class="relative pt-2">
        <input
          type="text"
          name="search"
          placeholder="Search catalog..."
          class="w-full rounded-full border border-light-darker bg-light px-4 py-2 text-sm text-dark placeholder:text-dark-muted/60 focus:bg-white focus:outline-none transition-all"
        />
      </form>

      <div class="pt-4 border-t border-light-darker">
        <button
          type="button"
          class="open-inquiry-direct-btn w-full flex items-center justify-center rounded-full bg-primary py-3 text-center text-sm font-bold text-white shadow-soft hover:bg-primary-dark transition-all"
        >
          Direct Bulk Inquiry
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  if (toggleBtn && mobileMenu && openIcon && closeIcon) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      
      toggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      mobileMenu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  }

  // Trigger side drawer event
  const openDrawer = () => {
    window.dispatchEvent(new CustomEvent('open-quote-drawer'));
  };

  document.getElementById('desktop-quote-drawer-trigger')?.addEventListener('click', openDrawer);
  document.getElementById('mobile-quote-drawer-trigger')?.addEventListener('click', openDrawer);
  
  document.querySelectorAll('.open-inquiry-direct-btn').forEach(btn => {
    btn.addEventListener('click', openDrawer);
  });
</script>
